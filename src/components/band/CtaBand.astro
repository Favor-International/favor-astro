---
export interface Props {
  heading: string;
  body?: string;
  ctaLabel: string;
  ctaHref: string;
  variant?: 'gold' | 'green' | 'sage';
}
const { heading, body, ctaLabel, ctaHref, variant = 'gold' } = Astro.props as Props;
---
<section class:list={['cta-band', `cta-band--${variant}`, 'band']}>
  <div class="container cta-band__inner">
    <h2>{heading}</h2>
    {body && <p>{body}</p>}
    <a class:list={['btn', variant === 'gold' ? 'btn--secondary' : 'btn--primary', 'btn--large']} href={ctaHref}>{ctaLabel}</a>
  </div>
</section>
<style>
  .cta-band { text-align: center; }
  .cta-band--gold { background: var(--color-gold); color: var(--color-ink); }
  .cta-band--green { background: var(--color-green); color: var(--color-white); }
  .cta-band--sage { background: color-mix(in srgb, var(--color-sage-light) 30%, var(--color-white)); }
  .cta-band--gold h2, .cta-band--green h2 { color: inherit; }
  .cta-band__inner { display: flex; flex-direction: column; gap: var(--space-6); align-items: center; max-width: 720px; margin: 0 auto; }
  .cta-band p { font-size: 1.1rem; margin: 0; opacity: 0.92; }
  .cta-band--gold .btn--secondary { color: var(--color-green); border-color: var(--color-green); }
  .cta-band--gold .btn--secondary:hover { background: var(--color-green); color: var(--color-white); }
</style>
