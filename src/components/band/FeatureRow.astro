---
// A LIGHT image + text split row (photo one side, copy on a light panel the
// other). Mirrors the OverlayFeature layout but stays light, so it reads as a
// separate beat from the green OverlayFeature sections. Use this right after a
// hero and to break up two green sections; use OverlayFeature for the green
// accent beats. `layout` maps to which side the photo is on.
export interface Props {
  image: string;
  imageAlt: string;
  eyebrow?: string;
  heading?: string;
  layout?: 'image-left' | 'image-right';
  background?: 'cream' | 'white';
  objectPosition?: string;
}
const { image, imageAlt, eyebrow, heading, layout = 'image-right', background = 'cream', objectPosition = 'center 30%' } = Astro.props as Props;
const side = layout === 'image-left' ? 'left' : 'right';
---
<section class:list={['feature-row', `feature-row--${side}`, `feature-row--${background}`]}>
  <div class="feature-row__panel">
    <div class="feature-row__inner">
      {eyebrow && <p class="label">{eyebrow}</p>}
      {heading && <h2>{heading}</h2>}
      <slot />
    </div>
  </div>
  <div class="feature-row__photo" style={`background-image: url(${image}); background-position: ${objectPosition};`} role="img" aria-label={imageAlt}></div>
</section>
<style>
  .feature-row { display: grid; grid-template-columns: 1fr 1fr; align-items: stretch; }
  .feature-row--cream { background: var(--color-cream); }
  .feature-row--white { background: var(--color-white); }
  .feature-row--right .feature-row__photo { order: -1; }
  .feature-row__panel {
    display: flex; align-items: center;
    padding: clamp(var(--space-12), 6vw, var(--space-24));
  }
  .feature-row__inner { width: 100%; max-width: 560px; margin: 0 auto; }
  .feature-row__inner h2 { color: var(--color-green); margin: 0 0 var(--space-6); }
  .feature-row__inner :global(p) {
    color: var(--color-ink-soft);
    line-height: 1.75; margin: 0 0 var(--space-5);
  }
  .feature-row__inner :global(p:last-child) { margin-bottom: 0; }
  .feature-row__inner :global(strong) { color: var(--color-green); font-weight: 700; }
  .feature-row__inner :global(a) { color: var(--color-gold-deep); font-weight: 700; }
  .feature-row__inner :global(h3) { color: var(--color-green); }
  .feature-row__inner :global(.lede),
  .feature-row__inner :global(.our-vision-line) {
    color: var(--color-green); font-style: italic; font-weight: 600;
  }
  .feature-row__photo {
    background-size: cover; background-repeat: no-repeat;
    min-height: clamp(340px, 42vh, 520px);
  }
  @media (max-width: 860px) {
    .feature-row { grid-template-columns: 1fr; }
    .feature-row--right .feature-row__photo { order: 0; }
    .feature-row__photo { min-height: 300px; }
  }
</style>
