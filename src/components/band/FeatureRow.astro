---
// An image + text row. Renders the immersive green split (solid green panel +
// full photo) so every "image beside text" section across the site uses the
// same green treatment. `layout` maps to which side the photo is on.
import OverlayFeature from './OverlayFeature.astro';
export interface Props {
  image: string;
  imageAlt: string;
  eyebrow?: string;
  heading?: string;
  layout?: 'image-left' | 'image-right';
  background?: string; // kept for backward-compat; ignored (always green)
  objectPosition?: string;
}
const { image, imageAlt, eyebrow, heading, layout = 'image-right', objectPosition } = Astro.props as Props;
const side = layout === 'image-left' ? 'left' : 'right';
---
<OverlayFeature
  image={image}
  imageAlt={imageAlt}
  eyebrow={eyebrow}
  heading={heading}
  side={side}
  objectPosition={objectPosition ?? 'center 30%'}
>
  <slot />
</OverlayFeature>
