---
// Immersive split: one half is a SOLID green panel holding the copy, the other
// half is a full, clean photo. No gradient washed over the image (that looked
// cheap). Reads premium and the text is always legible on solid green.
export interface Props {
  image: string;
  imageAlt: string;
  eyebrow?: string;
  heading?: string;
  side?: 'left' | 'right';
  objectPosition?: string;
}
const { image, imageAlt, eyebrow, heading, side = 'left', objectPosition = 'center 30%' } = Astro.props as Props;
---
<section class:list={['overlay-feature', `overlay-feature--${side}`]}>
  <div class="overlay-feature__panel">
    <div class="overlay-feature__inner">
      {eyebrow && <p class="label label--inverse">{eyebrow}</p>}
      {heading && <h2>{heading}</h2>}
      <slot />
    </div>
  </div>
  <div class="overlay-feature__photo" style={`background-image: url(${image}); background-position: ${objectPosition};`} role="img" aria-label={imageAlt}></div>
</section>
<style>
  .overlay-feature { display: grid; grid-template-columns: 1fr 1fr; align-items: stretch; }
  .overlay-feature--right .overlay-feature__photo { order: -1; }
  .overlay-feature__panel {
    position: relative;
    overflow: hidden;
    background: var(--color-green-deep);
    color: var(--color-white);
    display: flex; align-items: center;
    padding: clamp(var(--space-12), 6vw, var(--space-24));
  }
  /* Real African mud-cloth pattern (brand asset), kept subtle for life. */
  .overlay-feature__panel::before {
    content: ''; position: absolute; inset: 0; z-index: 0; pointer-events: none;
    background-image: url('/images/patterns/texture-mudcloth.webp');
    background-size: 560px auto;
    background-repeat: repeat;
    opacity: 0.06;
  }
  .overlay-feature__inner { position: relative; z-index: 1; width: 100%; max-width: 560px; margin: 0 auto; }
  .overlay-feature__inner h2 { color: var(--color-white); margin: 0 0 var(--space-6); }
  .overlay-feature__inner :global(p) {
    color: color-mix(in srgb, var(--color-white) 88%, transparent);
    line-height: 1.75; margin: 0 0 var(--space-5);
  }
  .overlay-feature__inner :global(p:last-child) { margin-bottom: 0; }
  .overlay-feature__inner :global(strong) { color: var(--color-gold); font-weight: 700; }
  .overlay-feature__inner :global(a) { color: var(--color-gold); }
  .overlay-feature__inner :global(h3) { color: var(--color-white); }
  .overlay-feature__inner :global(.lede),
  .overlay-feature__inner :global(.our-vision-line) { color: var(--color-gold-light); }
  .overlay-feature__photo {
    background-size: cover; background-repeat: no-repeat;
    min-height: clamp(340px, 42vh, 520px);
  }
  @media (max-width: 860px) {
    .overlay-feature { grid-template-columns: 1fr; }
    .overlay-feature--right .overlay-feature__photo { order: 0; }
    .overlay-feature__photo { min-height: 300px; }
  }
</style>
