---
// A real-person proof/testimony. Renders the immersive green split: the quote
// as the heading, name + place as the eyebrow, the outcome as the body, the
// photo filling the other half. Place this at the top level of a page (it is a
// full-bleed section, not a card inside a container).
import OverlayFeature from './OverlayFeature.astro';
export interface Props {
  name: string;
  place: string;
  outcome: string;
  quote?: string;
  image?: string;
  objectPosition?: string;
}
const { name, place, outcome, quote, image, objectPosition } = Astro.props as Props;
---
<OverlayFeature
  image={image ?? '/images/hero-congo-grads.jpg'}
  imageAlt={`${name}, ${place}`}
  eyebrow={`${name} · ${place}`}
  heading={quote ? `“${quote}”` : outcome}
  side="left"
  objectPosition={objectPosition ?? 'center 30%'}
>
  {quote && <p>{outcome}</p>}
</OverlayFeature>
