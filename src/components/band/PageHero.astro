---
// Standard internal-page hero: copy on the LEFT (eyebrow + serif title +
// promise + CTA) over a cream base, with the photo bleeding in from the RIGHT
// and softly fading into the cream. Symmetric, left-aligned, generous space.
export interface Props {
  label?: string;
  title: string;
  promise: string;
  image: string;
  imageAlt: string;
  ctaLabel?: string;
  ctaHref?: string;
  secondaryLabel?: string;
  secondaryHref?: string;
  variant?: string; // accepted for backward-compat; ignored
  objectPosition?: string;
}
const {
  label, title, promise, image, imageAlt,
  ctaLabel, ctaHref, secondaryLabel, secondaryHref,
  objectPosition = 'center',
} = Astro.props as Props;
---
<section class="page-hero">
  <div class="page-hero__media" style={`background-image: url(${image}); background-position: ${objectPosition};`} role="img" aria-label={imageAlt}></div>
  <div class="container">
    <div class="page-hero__copy">
      {label && <p class="label">{label}</p>}
      <h1>{title}</h1>
      <p class="page-hero__promise">{promise}</p>
      {(ctaLabel || secondaryLabel) && (
        <div class="page-hero__cta">
          {ctaLabel && ctaHref && <a class="btn btn--primary btn--large" href={ctaHref}>{ctaLabel}</a>}
          {secondaryLabel && secondaryHref && <a class="page-hero__secondary" href={secondaryHref}>{secondaryLabel} →</a>}
        </div>
      )}
    </div>
  </div>
</section>
<style>
  .page-hero {
    position: relative;
    display: flex;
    align-items: center;
    background: var(--color-cream);
    min-height: clamp(480px, 58vh, 620px);
    overflow: hidden;
  }
  .page-hero__media {
    position: absolute; top: 0; right: 0; bottom: 0;
    width: 50%;
    background-size: cover;
    background-repeat: no-repeat;
  }
  /* Soft cream fade on the photo's left edge so it blends into the copy side. */
  .page-hero__media::before {
    content: ''; position: absolute; inset: 0;
    background: linear-gradient(90deg, var(--color-cream) 0%, rgba(250, 247, 241, 0) 24%);
  }
  .page-hero .container { position: relative; z-index: 1; }
  .page-hero__copy { max-width: 47%; padding: var(--space-16) 0; }
  .page-hero__copy h1 { margin: var(--space-3) 0 var(--space-4); }
  .page-hero__promise {
    font-size: clamp(1.05rem, 1.4vw, 1.25rem);
    color: var(--color-ink-soft);
    line-height: 1.6;
    margin: 0 0 var(--space-6);
    max-width: 46ch;
  }
  .page-hero__cta { display: flex; gap: var(--space-6); align-items: center; flex-wrap: wrap; }
  .page-hero__secondary {
    color: var(--color-green); text-decoration: none; font-weight: 700;
    letter-spacing: 0.06em; text-transform: uppercase; font-size: 0.85rem;
    border-bottom: 2px solid var(--color-gold); padding-bottom: 4px;
  }
  .page-hero__secondary:hover { color: var(--color-gold-deep); }
  @media (max-width: 860px) {
    .page-hero { display: block; min-height: 0; }
    .page-hero__media { position: relative; width: 100%; height: 300px; }
    .page-hero__media::before { background: linear-gradient(0deg, var(--color-cream) 0%, rgba(250, 247, 241, 0) 40%); }
    .page-hero__copy { max-width: none; padding: var(--space-10) 0 var(--space-12); }
  }
</style>
