---
export interface Props {
  label?: string;
  title: string;
  promise: string;
  image: string;
  imageAlt: string;
  ctaLabel?: string;
  ctaHref?: string;
  secondaryLabel?: string;
  secondaryHref?: string;
  /* 'full-bleed' (default) and 'split' both render the full-bleed background
     hero. 'portrait' keeps a framed photo on the right, for portrait images
     (e.g. the founder). */
  variant?: 'full-bleed' | 'split' | 'portrait';
  /* CSS background-position for the hero photo, so the subject is not cut off.
     e.g. "center 30%" or "left center". Defaults to center. */
  objectPosition?: string;
}
const {
  label, title, promise, image, imageAlt,
  ctaLabel, ctaHref, secondaryLabel, secondaryHref,
  variant = 'full-bleed',
  objectPosition = 'center',
} = Astro.props as Props;
const isPortrait = variant === 'portrait';
---
{!isPortrait ? (
  <section class="page-hero page-hero--full">
    <div class="page-hero__photo" style={`background-image: url(${image}); background-position: ${objectPosition};`} role="img" aria-label={imageAlt}></div>
    <div class="page-hero__scrim"></div>
    <div class="container page-hero__inner">
      {label && <p class="label label--inverse">{label}</p>}
      <h1>{title}</h1>
      <p class="page-hero__promise">{promise}</p>
      {(ctaLabel || secondaryLabel) && (
        <div class="page-hero__cta">
          {ctaLabel && ctaHref && <a class="btn btn--primary btn--large" href={ctaHref}>{ctaLabel}</a>}
          {secondaryLabel && secondaryHref && <a class="page-hero__secondary" href={secondaryHref}>{secondaryLabel} →</a>}
        </div>
      )}
    </div>
  </section>
) : (
  <section class="page-hero page-hero--portrait">
    <div class="container page-hero__split-grid">
      <div class="page-hero__split-copy">
        {label && <p class="label">{label}</p>}
        <h1>{title}</h1>
        <p class="page-hero__promise page-hero__promise--dark">{promise}</p>
        {(ctaLabel || secondaryLabel) && (
          <div class="page-hero__cta">
            {ctaLabel && ctaHref && <a class="btn btn--primary btn--large" href={ctaHref}>{ctaLabel}</a>}
            {secondaryLabel && secondaryHref && <a class="page-hero__secondary page-hero__secondary--dark" href={secondaryHref}>{secondaryLabel} →</a>}
          </div>
        )}
      </div>
      <div class="page-hero__split-photo" style={`background-image: url(${image}); background-position: ${objectPosition};`} role="img" aria-label={imageAlt}></div>
    </div>
  </section>
)}

<style>
  /* ===== Standard hero: full-bleed background photo + green scrim ===== */
  .page-hero--full {
    position: relative;
    min-height: clamp(440px, 58vh, 600px);
    display: flex;
    align-items: center;
    color: var(--color-white);
    overflow: hidden;
  }
  .page-hero__photo {
    position: absolute; inset: 0;
    background-size: cover;
    background-repeat: no-repeat;
    z-index: 0;
  }
  /* Heavier on the left where the text sits, fading to show the photo on the
     right. Strong enough that white text always reads. */
  .page-hero__scrim {
    position: absolute; inset: 0; z-index: 1;
    background: linear-gradient(90deg,
      rgba(31, 58, 26, 0.92) 0%,
      rgba(31, 58, 26, 0.74) 38%,
      rgba(31, 58, 26, 0.30) 72%,
      rgba(31, 58, 26, 0.08) 100%);
  }
  .page-hero__inner {
    position: relative; z-index: 2;
    max-width: 720px;
    padding-top: var(--space-16);
    padding-bottom: var(--space-16);
  }
  .page-hero--full h1 { color: var(--color-white); margin: 0 0 var(--space-5); text-wrap: balance; }
  .page-hero__promise {
    font-size: clamp(1.05rem, 1.4vw, 1.25rem);
    color: color-mix(in srgb, var(--color-white) 92%, transparent);
    max-width: 56ch;
    margin: 0 0 var(--space-6);
    line-height: 1.6;
  }
  .page-hero__cta { display: flex; gap: var(--space-6); align-items: center; flex-wrap: wrap; }
  .page-hero__secondary {
    color: var(--color-white); text-decoration: none; font-weight: 700; letter-spacing: 0.08em;
    text-transform: uppercase; font-size: 0.85rem; border-bottom: 2px solid var(--color-gold); padding-bottom: 4px;
  }
  .page-hero__secondary--dark { color: var(--color-green); }
  .page-hero__secondary:hover { color: var(--color-gold); }
  @media (max-width: 700px) {
    .page-hero__scrim {
      background: linear-gradient(180deg,
        rgba(31, 58, 26, 0.55) 0%,
        rgba(31, 58, 26, 0.80) 55%,
        rgba(31, 58, 26, 0.92) 100%);
    }
  }

  /* ===== Portrait hero: text left, framed portrait right ===== */
  .page-hero--portrait { padding: var(--space-20) 0; background: var(--color-cream); }
  .page-hero__split-grid {
    display: grid; grid-template-columns: 1.05fr 0.95fr; gap: var(--space-16); align-items: center;
  }
  .page-hero__promise--dark { color: var(--color-ink-soft); }
  .page-hero__split-photo {
    aspect-ratio: 4 / 5;
    background-size: cover;
    background-repeat: no-repeat;
    border-radius: var(--radius-card);
    box-shadow: var(--shadow-card);
    min-height: 360px;
  }
  @media (max-width: 900px) {
    .page-hero__split-grid { grid-template-columns: 1fr; }
    .page-hero__split-photo { aspect-ratio: 16 / 10; min-height: 260px; }
  }
</style>
