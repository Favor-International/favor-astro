---
import { SITE } from '../../lib/site';
---
<footer class="site-footer">
  <div class="container site-footer__top">
    <div class="site-footer__brand">
      <img class="site-footer__logo" src="/images/favor-dove-white.png" alt={SITE.name} width="1000" height="1000" />
      <p class="site-footer__signature">{SITE.signature}</p>
      <address>
        <p>{SITE.mailing}</p>
        <p><a href={`tel:${SITE.phoneTel}`}>{SITE.phone}</a></p>
        <p><a href={`mailto:${SITE.emailGeneral}`}>{SITE.emailGeneral}</a></p>
        <p><a href={`mailto:${SITE.emailPrayer}`}>{SITE.emailPrayer}</a></p>
      </address>
    </div>

    <nav class="site-footer__col" aria-label="About">
      <p class="site-footer__col-title">About</p>
      <ul>
        <li><a href="/about/">Mission</a></li>
        <li><a href="/about/our-story/">Our Story</a></li>
        <li><a href="/about/where-we-work/">Where We Work</a></li>
        <li><a href="/about/team/">Team</a></li>
        <li><a href="/about/board/">Board</a></li>
        <li><a href="/about/accountability/">Accountability</a></li>
        <li><a href="/about/statement-of-faith/">Statement of Faith</a></li>
        <li><a href="/about/contact/">Contact</a></li>
      </ul>
    </nav>

    <nav class="site-footer__col" aria-label="Engage">
      <p class="site-footer__col-title">Engage</p>
      <ul>
        <li><a href="/pray/">Pray</a></li>
        <li><a href="/pray/30-day-guide/">30-Day Prayer Guide</a></li>
        <li><a href="/give/">Give</a></li>
        <li><a href="/give/partner-monthly/">Favor Partner</a></li>
        <li><a href="/go/vision-trips/">Vision Trips</a></li>
        <li><a href="/go/volunteer/">Volunteer</a></li>
      </ul>
    </nav>

    <nav class="site-footer__col" aria-label="Impact">
      <p class="site-footer__col-title">Impact</p>
      <ul>
        <li><a href="/impact/evangelism-discipleship/">Evangelism & Discipleship</a></li>
        <li><a href="/impact/education/">Education</a></li>
        <li><a href="/impact/community-development/">Community Development</a></li>
        <li><a href="/impact/economic-empowerment/">Economic Empowerment</a></li>
        <li><a href="/stories/">Stories</a></li>
        <li><a href="/impact/impact-reports/">Impact Reports</a></li>
      </ul>
    </nav>

    <div class="site-footer__col site-footer__trust">
      <p class="site-footer__col-title">Trust</p>
      <div class="site-footer__badges">
        <a href={SITE.trust.ecfa} target="_blank" rel="noopener" aria-label="ECFA Accredited">
          <img src="/images/trust/ecfa.png" alt="ECFA Accredited" width="80" height="80" />
        </a>
        <a href={SITE.trust.charityNavigator} target="_blank" rel="noopener" aria-label="Charity Navigator Four-Star">
          <img src="/images/trust/charity-navigator.svg" alt="Charity Navigator Four-Star" width="80" height="80" />
        </a>
        <a href={SITE.trust.candid} target="_blank" rel="noopener" aria-label="Candid Platinum">
          <img src="/images/trust/candid-platinum.svg" alt="Candid Platinum" width="80" height="80" />
        </a>
      </div>
      <p class="site-footer__ein">EIN {SITE.ein}</p>
      <ul class="site-footer__social" aria-label="Social">
        <li>
          <a href={SITE.social.facebook} target="_blank" rel="noopener" aria-label="Facebook">
            <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true">
              <path fill="currentColor" d="M22 12a10 10 0 1 0-11.56 9.88v-6.99H7.9V12h2.54V9.8c0-2.5 1.49-3.89 3.77-3.89 1.09 0 2.24.2 2.24.2v2.46h-1.26c-1.24 0-1.63.77-1.63 1.56V12h2.77l-.44 2.89h-2.33v6.99A10 10 0 0 0 22 12Z" />
            </svg>
          </a>
        </li>
        <li>
          <a href={SITE.social.instagram} target="_blank" rel="noopener" aria-label="Instagram">
            <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true">
              <path fill="currentColor" d="M12 2.16c3.2 0 3.58.01 4.85.07 1.17.05 1.8.25 2.23.41.56.22.96.48 1.38.9.42.42.68.82.9 1.38.16.42.36 1.06.41 2.23.06 1.27.07 1.65.07 4.85s-.01 3.58-.07 4.85c-.05 1.17-.25 1.8-.41 2.23-.22.56-.48.96-.9 1.38-.42.42-.82.68-1.38.9-.42.16-1.06.36-2.23.41-1.27.06-1.65.07-4.85.07s-3.58-.01-4.85-.07c-1.17-.05-1.8-.25-2.23-.41a3.7 3.7 0 0 1-1.38-.9 3.7 3.7 0 0 1-.9-1.38c-.16-.42-.36-1.06-.41-2.23C2.17 15.58 2.16 15.2 2.16 12s.01-3.58.07-4.85c.05-1.17.25-1.8.41-2.23.22-.56.48-.96.9-1.38.42-.42.82-.68 1.38-.9.42-.16 1.06-.36 2.23-.41C8.42 2.17 8.8 2.16 12 2.16Zm0 1.94c-3.14 0-3.51.01-4.75.07-1.07.05-1.65.23-2.04.38-.51.2-.88.44-1.26.82a3.4 3.4 0 0 0-.82 1.26c-.15.39-.33.97-.38 2.04-.06 1.24-.07 1.61-.07 4.75s.01 3.51.07 4.75c.05 1.07.23 1.65.38 2.04.2.51.44.88.82 1.26.38.38.75.62 1.26.82.39.15.97.33 2.04.38 1.24.06 1.61.07 4.75.07s3.51-.01 4.75-.07c1.07-.05 1.65-.23 2.04-.38.51-.2.88-.44 1.26-.82.38-.38.62-.75.82-1.26.15-.39.33-.97.38-2.04.06-1.24.07-1.61.07-4.75s-.01-3.51-.07-4.75c-.05-1.07-.23-1.65-.38-2.04a3.4 3.4 0 0 0-.82-1.26 3.4 3.4 0 0 0-1.26-.82c-.39-.15-.97-.33-2.04-.38-1.24-.06-1.61-.07-4.75-.07Zm0 3.3a4.6 4.6 0 1 1 0 9.2 4.6 4.6 0 0 1 0-9.2Zm0 1.94a2.66 2.66 0 1 0 0 5.32 2.66 2.66 0 0 0 0-5.32Zm5.85-2.16a1.08 1.08 0 1 1-2.15 0 1.08 1.08 0 0 1 2.15 0Z" />
            </svg>
          </a>
        </li>
        <li>
          <a href={SITE.social.youtube} target="_blank" rel="noopener" aria-label="YouTube">
            <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true">
              <path fill="currentColor" d="M23.5 6.2a3 3 0 0 0-2.12-2.12C19.5 3.56 12 3.56 12 3.56s-7.5 0-9.38.52A3 3 0 0 0 .5 6.2 31.3 31.3 0 0 0 0 12a31.3 31.3 0 0 0 .5 5.8 3 3 0 0 0 2.12 2.12C4.5 20.44 12 20.44 12 20.44s7.5 0 9.38-.52a3 3 0 0 0 2.12-2.12c.34-1.94.5-3.86.5-5.8a31.3 31.3 0 0 0-.5-5.8ZM9.6 15.57V8.43L15.82 12 9.6 15.57Z" />
            </svg>
          </a>
        </li>
        <li>
          <a href={SITE.social.linkedin} target="_blank" rel="noopener" aria-label="LinkedIn">
            <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true">
              <path fill="currentColor" d="M20.45 20.45h-3.55v-5.57c0-1.33-.03-3.04-1.85-3.04-1.85 0-2.14 1.45-2.14 2.94v5.67H9.36V9h3.41v1.56h.05a3.74 3.74 0 0 1 3.37-1.85c3.6 0 4.27 2.37 4.27 5.45v6.29ZM5.34 7.43a2.06 2.06 0 1 1 0-4.12 2.06 2.06 0 0 1 0 4.12ZM7.12 20.45H3.56V9h3.56v11.45ZM22.23 0H1.77C.79 0 0 .77 0 1.72v20.56C0 23.23.79 24 1.77 24h20.46C23.21 24 24 23.23 24 22.28V1.72C24 .77 23.21 0 22.23 0Z" />
            </svg>
          </a>
        </li>
        <li>
          <a href={SITE.social.twitter} target="_blank" rel="noopener" aria-label="X">
            <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true">
              <path fill="currentColor" d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231 5.45-6.231Zm-1.161 17.52h1.833L7.084 4.126H5.117L17.083 19.77Z" />
            </svg>
          </a>
        </li>
      </ul>
    </div>
  </div>

  <div class="container site-footer__bottom">
    <p>{SITE.tagline}</p>
    <p>&copy; {new Date().getFullYear()} {SITE.name}. All rights reserved. · <a href="/legal/privacy/">Privacy</a> · <a href="/legal/terms/">Terms</a></p>
  </div>
</footer>
<style>
  .site-footer {
    background: var(--color-green-deep);
    color: var(--color-white);
    padding: var(--space-16) 0 var(--space-6);
  }
  .site-footer a { color: var(--color-white); text-decoration: none; }
  .site-footer a:hover { color: var(--color-gold); text-decoration: underline; }

  .site-footer__top {
    display: grid;
    grid-template-columns: 1.4fr 1fr 1fr 1fr 1.1fr;
    gap: var(--space-12);
    padding-bottom: var(--space-12);
    border-bottom: 1px solid color-mix(in srgb, var(--color-white) 18%, transparent);
  }
  @media (max-width: 1100px) {
    .site-footer__top { grid-template-columns: 1fr 1fr 1fr; }
  }
  @media (max-width: 640px) {
    .site-footer__top { grid-template-columns: 1fr; gap: var(--space-8); }
  }

  .site-footer__logo {
    width: 128px;
    height: 128px;
    object-fit: contain;
    margin-bottom: var(--space-4);
    filter: drop-shadow(0 2px 6px rgba(0,0,0,0.4));
  }
  .site-footer__signature { font-style: italic; color: var(--color-gold-light); margin: 0 0 var(--space-4); }
  address { font-style: normal; font-size: 0.9rem; line-height: 1.7; color: color-mix(in srgb, var(--color-white) 80%, transparent); }
  address p { margin: 0; }

  .site-footer__col-title {
    font-size: var(--font-size-label);
    font-weight: 700;
    letter-spacing: var(--letter-spacing-label);
    text-transform: uppercase;
    color: var(--color-gold);
    margin: 0 0 var(--space-4);
  }
  .site-footer__col ul { list-style: none; padding: 0; margin: 0; }
  .site-footer__col li { margin-bottom: var(--space-2); font-size: 0.92rem; }

  .site-footer__trust-list { margin-bottom: var(--space-6) !important; }
  /* Three trust badges in a row, evenly sized columns so they fit inside
     the narrow Trust column without wrapping. */
  .site-footer__badges {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-3);
    align-items: center;
    margin-bottom: var(--space-4);
  }
  .site-footer__badges a {
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .site-footer__badges img {
    width: 100%;
    max-width: 56px;
    height: auto;
    background: white;
    border-radius: 50%;
    padding: 4px;
    transition: transform 160ms;
  }
  .site-footer__badges img[src$=".svg"] { background: transparent; padding: 0; }
  .site-footer__badges a:hover img { transform: scale(1.05); }
  .site-footer__ein {
    font-size: 0.95rem;
    font-weight: 800;
    letter-spacing: 0.04em;
    color: var(--color-white);
    margin: 0 0 var(--space-6);
    text-align: center;
  }

  /* Social row: all five icons on a single line. Smaller circles, no
     wrap, equal spacing. Narrow column forces tight icons. */
  .site-footer__social {
    display: flex;
    gap: var(--space-2);
    flex-wrap: nowrap;
    justify-content: flex-start;
  }
  .site-footer__social li { margin: 0; }
  .site-footer__social a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border: 1px solid color-mix(in srgb, var(--color-white) 35%, transparent);
    border-radius: 50%;
    color: var(--color-white);
    transition: background 160ms, color 160ms, border-color 160ms;
  }
  .site-footer__social a svg { display: block; }
  .site-footer__social a:hover { background: var(--color-gold); color: var(--color-green-deep); border-color: var(--color-gold); }

  .site-footer__bottom {
    padding-top: var(--space-6);
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--space-3);
    font-size: 0.85rem;
    color: color-mix(in srgb, var(--color-white) 72%, transparent);
  }
  .site-footer__bottom p { margin: 0; }
</style>
