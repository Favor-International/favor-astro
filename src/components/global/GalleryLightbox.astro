---
// Site-wide gallery lightbox. Any `.field-gallery` becomes a clickable gallery:
// clicking a tile opens a full-screen viewer with the large image, its caption
// and description, prev/next navigation, a counter, and keyboard + backdrop
// controls. Reads the image from each tile's background-image and the text from
// data-caption/data-desc (or the figcaption). Included once via PageLayout.
---
<div class="glb" id="glb" aria-hidden="true" role="dialog" aria-modal="true" aria-label="Image viewer">
  <button class="glb__close" type="button" aria-label="Close">&times;</button>
  <button class="glb__nav glb__prev" type="button" aria-label="Previous image">&#8249;</button>
  <figure class="glb__stage">
    <img class="glb__img" src="" alt="" />
    <figcaption class="glb__cap">
      <span class="glb__caption"></span>
      <span class="glb__desc"></span>
      <span class="glb__count"></span>
    </figcaption>
  </figure>
  <button class="glb__nav glb__next" type="button" aria-label="Next image">&#8250;</button>
</div>

<style is:global>
  .field-gallery .field-tile { cursor: zoom-in; transition: box-shadow 180ms, transform 180ms; }
  .field-gallery .field-tile:hover { transform: translateY(-3px); box-shadow: 0 22px 48px rgba(20,30,18,0.28); }

  .glb { position: fixed; inset: 0; z-index: 1100; display: none; grid-template-columns: auto 1fr auto; align-items: center; gap: clamp(8px, 2vw, 28px); padding: clamp(16px, 4vw, 56px); background: rgba(10, 14, 9, 0.94); opacity: 0; transition: opacity 200ms ease; }
  .glb.is-open { display: grid; opacity: 1; }
  .glb__stage { margin: 0; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: var(--space-4); min-width: 0; }
  .glb__img { max-width: min(92vw, 1200px); max-height: 76vh; width: auto; height: auto; border-radius: 12px; box-shadow: 0 30px 80px rgba(0,0,0,0.5); background: #000; opacity: 0; transform: scale(0.985); transition: opacity 240ms ease, transform 240ms ease; }
  .glb__img.is-ready { opacity: 1; transform: scale(1); }
  .glb__cap { max-width: 760px; text-align: center; color: #fff; display: flex; flex-direction: column; gap: 4px; }
  .glb__caption { font-family: var(--font-sans); font-weight: 800; font-size: 1.05rem; }
  .glb__desc { color: color-mix(in srgb, #fff 80%, transparent); font-size: 0.92rem; line-height: 1.5; }
  .glb__desc:empty { display: none; }
  .glb__count { margin-top: var(--space-2); color: color-mix(in srgb, #fff 60%, transparent); font-size: 0.78rem; letter-spacing: 0.1em; }
  .glb__nav, .glb__close { border: 0; cursor: pointer; color: #fff; background: rgba(255,255,255,0.12); display: inline-flex; align-items: center; justify-content: center; transition: background 140ms; }
  .glb__nav { width: 52px; height: 52px; border-radius: 50%; font-size: 1.8rem; line-height: 1; }
  .glb__nav:hover, .glb__close:hover { background: var(--color-gold); color: var(--color-ink); }
  .glb__close { position: absolute; top: clamp(12px, 3vw, 28px); right: clamp(12px, 3vw, 28px); width: 44px; height: 44px; border-radius: 50%; font-size: 1.6rem; }
  @media (max-width: 640px) {
    .glb { grid-template-columns: 1fr; }
    .glb__nav { position: absolute; top: 50%; transform: translateY(-50%); z-index: 2; }
    .glb__prev { left: 10px; } .glb__next { right: 10px; }
    .glb__img { max-height: 64vh; }
  }
</style>

<script>
  const lb = document.getElementById('glb');
  if (lb) {
    const imgEl = lb.querySelector('.glb__img') as HTMLImageElement;
    const capEl = lb.querySelector('.glb__caption') as HTMLElement;
    const descEl = lb.querySelector('.glb__desc') as HTMLElement;
    const countEl = lb.querySelector('.glb__count') as HTMLElement;
    let slides: { src: string; caption: string; desc: string }[] = [];
    let idx = 0;

    const urlFrom = (el: HTMLElement) => {
      const m = (el.style.backgroundImage || '').match(/url\(["']?(.*?)["']?\)/);
      return m ? m[1] : '';
    };

    function render() {
      const s = slides[idx];
      if (!s) return;
      imgEl.classList.remove('is-ready');
      const pre = new Image();
      pre.onload = () => { imgEl.src = s.src; imgEl.classList.add('is-ready'); };
      pre.src = s.src;
      imgEl.alt = s.caption || 'Photo';
      capEl.textContent = s.caption || '';
      descEl.textContent = s.desc || '';
      countEl.textContent = slides.length > 1 ? `${idx + 1} / ${slides.length}` : '';
    }
    function open(list: typeof slides, i: number) {
      slides = list; idx = i;
      lb!.classList.add('is-open');
      lb!.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
      render();
    }
    function close() {
      lb!.classList.remove('is-open');
      lb!.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
    }
    const step = (d: number) => { idx = (idx + d + slides.length) % slides.length; render(); };

    lb.querySelector('.glb__close')!.addEventListener('click', close);
    lb.querySelector('.glb__prev')!.addEventListener('click', () => step(-1));
    lb.querySelector('.glb__next')!.addEventListener('click', () => step(1));
    lb.addEventListener('click', (e) => { if (e.target === lb) close(); });
    document.addEventListener('keydown', (e) => {
      if (!lb!.classList.contains('is-open')) return;
      if (e.key === 'Escape') close();
      else if (e.key === 'ArrowLeft') step(-1);
      else if (e.key === 'ArrowRight') step(1);
    });

    document.querySelectorAll('.field-gallery').forEach((group) => {
      const tiles = Array.from(group.querySelectorAll('.field-tile')) as HTMLElement[];
      const list = tiles.map((t) => ({
        src: t.dataset.src || urlFrom(t),
        caption: t.dataset.caption || t.querySelector('figcaption')?.textContent?.trim() || '',
        desc: t.dataset.desc || '',
      }));
      tiles.forEach((t, i) => {
        t.setAttribute('role', 'button');
        t.tabIndex = 0;
        t.addEventListener('click', () => open(list, i));
        t.addEventListener('keydown', (e: KeyboardEvent) => {
          if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); open(list, i); }
        });
      });
    });
  }
</script>
