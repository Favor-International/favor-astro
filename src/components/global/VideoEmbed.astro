---
// Lightweight YouTube embed: shows the poster thumbnail with a play button.
// Clicking opens a full-screen lightbox player (no iframe loads until then, so
// the page stays fast). Pass the bare YouTube video id.
export interface Props {
  id: string;
  title: string;
  caption?: string;
}
const { id, title, caption } = Astro.props as Props;
---
<figure class="video-embed">
  <button class="video-embed__btn" type="button" data-ytid={id} data-yttitle={title} aria-label={`Play video: ${title}`}>
    <img
      class="video-embed__thumb"
      src={`https://i.ytimg.com/vi/${id}/maxresdefault.jpg`}
      alt=""
      loading="lazy"
      width="1280"
      height="720"
      onerror={`this.onerror=null;this.src='https://i.ytimg.com/vi/${id}/hqdefault.jpg';`}
    />
    <span class="video-embed__scrim" aria-hidden="true"></span>
    <span class="video-embed__play" aria-hidden="true">
      <svg viewBox="0 0 68 48" width="72" height="51"><path class="yt-bg" d="M66.52 7.74c-.78-2.93-2.49-5.41-5.42-6.19C55.79.13 34 0 34 0S12.21.13 6.9 1.55c-2.93.78-4.63 3.26-5.42 6.19C.06 13.05 0 24 0 24s.06 10.95 1.48 16.26c.78 2.93 2.49 5.41 5.42 6.19C12.21 47.87 34 48 34 48s21.79-.13 27.1-1.55c2.93-.78 4.64-3.26 5.42-6.19C67.94 34.95 68 24 68 24s-.06-10.95-1.48-16.26z" fill="#1f3a1a" fill-opacity="0.85"/><path d="M45 24 27 14v20z" fill="#fff"/></svg>
    </span>
    <span class="video-embed__label">{title}</span>
  </button>
  {caption && <figcaption class="video-embed__cap">{caption}</figcaption>}
</figure>
<style>
  .video-embed { margin: 0; }
  .video-embed__btn { position: relative; display: block; width: 100%; aspect-ratio: 16 / 9; border: 0; padding: 0; cursor: pointer; border-radius: var(--radius-card); overflow: hidden; background: var(--color-green-deep); box-shadow: var(--shadow-card); }
  .video-embed__thumb { width: 100%; height: 100%; object-fit: cover; display: block; }
  .video-embed__scrim { position: absolute; inset: 0; background: linear-gradient(180deg, rgba(20,30,18,0) 45%, rgba(20,30,18,0.6) 100%); }
  .video-embed__play { position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); transition: transform 160ms; }
  .video-embed__play .yt-bg { transition: fill 160ms, fill-opacity 160ms; }
  .video-embed__btn:hover .video-embed__play { transform: translate(-50%, -50%) scale(1.08); }
  .video-embed__btn:hover .yt-bg { fill: var(--color-gold); fill-opacity: 1; }
  .video-embed__label { position: absolute; left: var(--space-6); right: var(--space-6); bottom: var(--space-5); color: #fff; font-family: var(--font-sans); font-weight: 800; font-size: clamp(1rem, 1.8vw, 1.3rem); text-align: left; line-height: 1.2; text-shadow: 0 1px 10px rgba(0,0,0,0.55); }
  .video-embed__cap { margin-top: var(--space-3); color: var(--color-sage); font-size: 0.9rem; }
</style>

<style is:global>
  .video-lightbox { position: fixed; inset: 0; z-index: 1000; display: none; align-items: center; justify-content: center; padding: clamp(12px, 4vw, 48px); background: rgba(10, 14, 9, 0.92); opacity: 0; transition: opacity 180ms ease; }
  .video-lightbox.is-open { display: flex; opacity: 1; }
  .video-lightbox__frame { position: relative; width: min(92vw, calc((92vh - 0px) * 16 / 9)); aspect-ratio: 16 / 9; }
  .video-lightbox__frame iframe { width: 100%; height: 100%; border: 0; border-radius: 12px; box-shadow: 0 30px 80px rgba(0,0,0,0.5); background: #000; }
  .video-lightbox__close { position: absolute; top: -48px; right: 0; width: 40px; height: 40px; border-radius: 50%; border: 0; cursor: pointer; background: rgba(255,255,255,0.14); color: #fff; font-size: 1.4rem; line-height: 1; display: flex; align-items: center; justify-content: center; transition: background 140ms; }
  .video-lightbox__close:hover { background: var(--color-gold); color: var(--color-ink); }
  @media (max-width: 600px) { .video-lightbox__close { top: -44px; } }
</style>

<script>
  function getLightbox() {
    let lb = document.getElementById('video-lightbox') as HTMLElement | null;
    if (lb) return lb;
    lb = document.createElement('div');
    lb.id = 'video-lightbox';
    lb.className = 'video-lightbox';
    lb.setAttribute('role', 'dialog');
    lb.setAttribute('aria-modal', 'true');
    lb.innerHTML = '<div class="video-lightbox__frame"><button class="video-lightbox__close" type="button" aria-label="Close video">&times;</button></div>';
    document.body.appendChild(lb);

    const close = () => {
      lb!.classList.remove('is-open');
      const f = lb!.querySelector('iframe');
      if (f) f.remove();
      document.body.style.overflow = '';
    };
    lb.addEventListener('click', (e) => { if (e.target === lb) close(); });
    lb.querySelector('.video-lightbox__close')!.addEventListener('click', close);
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape') close(); });
    return lb;
  }

  function openVideo(id: string, title: string) {
    const lb = getLightbox();
    const frame = lb.querySelector('.video-lightbox__frame')!;
    const old = frame.querySelector('iframe');
    if (old) old.remove();
    const iframe = document.createElement('iframe');
    iframe.src = `https://www.youtube.com/embed/${id}?autoplay=1&rel=0`;
    iframe.allow = 'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; fullscreen';
    iframe.setAttribute('allowfullscreen', '');
    iframe.title = title || 'Video';
    frame.appendChild(iframe);
    lb.classList.add('is-open');
    document.body.style.overflow = 'hidden';
  }

  document.querySelectorAll('.video-embed__btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      openVideo(btn.getAttribute('data-ytid') || '', btn.getAttribute('data-yttitle') || '');
    });
  });
</script>
