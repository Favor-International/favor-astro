---
import PageLayout from '../layouts/PageLayout.astro';
---
<PageLayout title="Page not found" description="The page you were looking for isn't here." noindex>
  <section class="band band--cream">
    <div class="container container--narrow" style="text-align:center;">
      <p class="label">404</p>
      <h1>This page is off the map.</h1>
      <p>The page you were looking for isn't here, but the field is still moving. Pick a path below.</p>
      <p class="band__cta-row">
        <a class="btn btn--primary btn--large" href="/give/partner-monthly/">Become a Favor Partner</a>
        <a class="btn btn--secondary" href="/" style="margin-left: var(--space-3);">Back to home</a>
      </p>
    </div>
  </section>
</PageLayout>
