---
import PageLayout from '../../layouts/PageLayout.astro';
import PageHero from '../../components/band/PageHero.astro';
import PostCard from '../../components/band/PostCard.astro';
import OverlayCard from '../../components/global/OverlayCard.astro';
import CtaBand from '../../components/band/CtaBand.astro';
import { PILLARS, IMPACT_STATS } from '../../lib/site';

const pillarImages: Record<string, string> = {
  'evangelism-discipleship': '/images/pillar-evangelism-discipleship.jpg',
  'education': '/images/pillar-education.jpg',
  'community-development': '/images/pillar-community-care.jpg',
  'economic-empowerment': '/images/pillar-economic-empowerment.jpg',
};
const deeper = [
  { href: '/newsletter/', image: '/images/hero-newsletter-field.jpg', title: 'Field updates', desc: 'Monthly reports from the country teams, straight to your inbox.', action: 'Subscribe' },
  { href: '/about/accountability/', image: '/images/hero-bibles-stacks.jpg', title: 'Impact reports', desc: 'Quarterly and annual PDFs with audited numbers.', action: 'View reports' },
  { href: '/stories/', image: '/images/story-anaka-crusade.jpg', title: 'Stories of transformation', desc: 'Real names, real places, real outcomes.', action: 'Read stories' },
];
---
<PageLayout
  title="Impact"
  description="Four ministry pillars across East Africa. Field reports, real stories, and the indigenous leaders behind the work."
  image="/images/hero-pbs-graduation.jpg"
>
  <PageHero
    label="Impact"
    title="Four ministries. One Kingdom outcome."
    promise="Every Favor program flows from one conviction: transformed hearts transform nations."
    image="/images/hero-pbs-graduation.jpg"
    imageAlt="PBS graduates with certificates"
  />

  <section class="band band--white">
    <div class="container impact-head">
      <p class="label">Audited financials</p>
      <h2>The receipts behind the work.</h2>
      <p class="impact-lede">Every number below is sourced from Favor's FY2024 audited financials, filed with ECFA and IRS Form 990. No estimates. No projections.</p>
    </div>
    <div class="container impact-stats">
      {IMPACT_STATS.map((s) => (
        <div class="impact-stat">
          <span class="impact-stat__num">{s.value}</span>
          <span class="impact-stat__label">{s.label}</span>
          <span class="impact-stat__src">{s.source}</span>
        </div>
      ))}
    </div>
    <p class="impact-sources">
      Sources: <a href="https://www.ecfa.org/MemberProfile.aspx?ID=50004" target="_blank" rel="noopener">ECFA member profile</a> ·
      <a href="https://www.charitynavigator.org/ein/475225697" target="_blank" rel="noopener">Charity Navigator</a> ·
      <a href="https://app.candid.org/profile/9511233" target="_blank" rel="noopener">Candid (Guidestar)</a>
    </p>
  </section>

  <section class="band band--cream">
    <div class="container impact-head">
      <p class="label">The pillars</p>
      <h2>How the work breaks down.</h2>
    </div>
    <div class="container pillar-grid">
      {PILLARS.map((p) => (
        <OverlayCard
          href={`/impact/${p.slug}/`}
          image={pillarImages[p.slug]}
          title={p.label}
          desc={p.blurb}
          cta="See the work"
          ratio="16 / 10"
        />
      ))}
    </div>
  </section>

  <section class="band band--white">
    <div class="container impact-head">
      <p class="label">Deeper</p>
      <h2>Reports, stories, and the field record.</h2>
    </div>
    <div class="container grid grid-3">
      {deeper.map((d) => (
        <PostCard href={d.href} image={d.image} imageAlt={d.title} title={d.title} desc={d.desc} actionLabel={d.action} />
      ))}
    </div>
  </section>

  <CtaBand
    heading="Want the field report in your inbox?"
    body="One email a month. The team's honest take on what worked and what didn't."
    ctaLabel="Send Me the Field Report"
    ctaHref="/newsletter/"
  />
</PageLayout>

<style>
  .impact-head { text-align: center; max-width: 760px; margin-left: auto; margin-right: auto; }
  .impact-lede { margin: var(--space-3) auto 0; color: var(--color-ink-soft); max-width: 60ch; }
  .impact-stats { display: grid; grid-template-columns: repeat(4, 1fr); gap: var(--space-8); margin-top: var(--space-12); text-align: center; }
  @media (max-width: 760px) { .impact-stats { grid-template-columns: repeat(2, 1fr); gap: var(--space-10) var(--space-6); } }
  .impact-stat__num { display: block; font-family: var(--font-display); font-weight: 700; font-size: clamp(2.4rem, 5.5vw, 3.8rem); color: var(--color-green-deep); line-height: 1; letter-spacing: -0.02em; }
  .impact-stat__label { display: block; margin-top: var(--space-3); font-weight: 800; font-size: 0.8rem; letter-spacing: 0.1em; text-transform: uppercase; color: var(--color-gold-deep); }
  .impact-stat__src { display: block; margin-top: var(--space-2); font-size: 0.78rem; color: var(--color-sage); }
  .impact-sources { text-align: center; margin: var(--space-10) 0 0; color: var(--color-sage); font-size: 0.85rem; }
  .impact-sources a { color: var(--color-gold-deep); }

  .pillar-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: var(--space-8); margin-top: var(--space-10); }
  @media (max-width: 680px) { .pillar-grid { grid-template-columns: 1fr; } }
  .grid-3 { margin-top: var(--space-10); }
</style>
