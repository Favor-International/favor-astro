---
import PageLayout from '../../layouts/PageLayout.astro';
import PageHero from '../../components/band/PageHero.astro';
import ProofBlock from '../../components/band/ProofBlock.astro';
import VideoEmbed from '../../components/global/VideoEmbed.astro';
import CtaBand from '../../components/band/CtaBand.astro';

const programs = [
  { name: 'Sustainability Projects', desc: 'Agriculture, water, and small-livestock programs that move villages off relief and onto their own feet. Goats for widows. Boreholes for villages.' },
  { name: 'Women’s Empowerment', desc: 'Skills training, micro-business cohorts, and Bible study for women, many of them widows, all of them leaders in their families.' },
  { name: 'Vocational Programs', desc: 'Tailoring, carpentry, motorcycle repair, and small-business training for young adults. Indigenous trainers, locally-sourced tools.' },
];
---
<PageLayout
  title="Economic Empowerment"
  description="Sustainability projects, women's empowerment, and vocational programs: Favor International's economic empowerment pillar."
>
  <PageHero
    label="Pillar 4 of 4"
    title="Economic Empowerment."
    promise="Sustainability projects, vocational programs, and women's empowerment that change a whole village."
    image="/images/pillar-economic-empowerment.jpg"
    imageAlt="Women's empowerment program"
    ctaLabel="Fund the work"
    ctaHref="/give/partner-monthly/"
  />

  <section class="band band--cream">
    <div class="container">
      <div class="video-feature">
        <div class="video-feature__copy">
          <p class="label">From the field</p>
          <h2>To reach a village, reach a woman.</h2>
          <p>When a widow receives training and a small project, the whole village changes. Watch how economic empowerment multiplies across a community.</p>
        </div>
        <div class="video-feature__player">
          <VideoEmbed id="JCjHdG0NnLQ" title="To Reach a Village, Reach a Woman" />
        </div>
      </div>
    </div>
  </section>

  <section class="band band--white">
    <div class="container">
      <header class="ee-head">
        <p class="label">The three programs</p>
        <h2>From relief to self-reliance.</h2>
      </header>
      <div class="acard-grid">
        {programs.map((p) => (
          <article class="acard has-texture">
            <h3>{p.name}</h3>
            <p>{p.desc}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <ProofBlock
    name="The Women of Puranga"
    place="Uganda"
    outcome="A Women's Empowerment cohort received two goats each after a year of training. The herds pay for school fees, food, and medical care across the village."
    quote="They praised and worshiped God as they waited to receive two goats for each member of their Women's Empowerment group."
    image="/images/stories/goats-for-women.jpg"
  />

  <section class="band band--white">
    <div class="container">
      <header class="ee-head">
        <p class="label">The programs in depth</p>
        <h2>From relief to self-reliance, program by program.</h2>
      </header>
      <div class="acard-grid">
        <article class="acard has-texture">
          <h3>Sustainability Projects</h3>
          <p>God has provided Favor with a 270 acre farm. Wanting to be good stewards of what we&rsquo;ve been given to work with and lead by example, we have a few sustainability projects that help provide for our ministry teams and support our programs directly. The farm is located just outside of Gulu which includes vegetables and fruit trees, and then a poultry house and fisheries are within our Education compound. The fish farm breeds and sells fingerlings and grows table fish for market and for consumption.</p>
        </article>
        <article class="acard has-texture">
          <h3>Women Empowerment</h3>
          <p>Favor&rsquo;s Women Empowerment ministry ends this cycle by equipping women to generate their own income through training in skills, trauma healing, entrepreneurship, parenting, and financial management. The women are empowered and given a project to begin. This income gains them a measure of respect from their husbands and funds the medical and educational needs of all their children.</p>
        </article>
        <article class="acard has-texture">
          <h3>Vocational Program</h3>
          <p>Favor seeks to equip and empower youth in their late teens and early twenties with the opportunity to choose and study a vocation of their choice. Some of the offerings are mechanics, farming, fisheries, animal husbandry, landscaping, tailoring, hairdressing, bakery, and many more. Being part of a larger government program, we&rsquo;re able to award our vocational graduates, who rank among the top graduates in the nation, government-recognized certificates that give them an edge.</p>
        </article>
      </div>
    </div>
  </section>

  <CtaBand
    heading="Fund a cohort that funds itself."
    body="Sustainability tools, vocational training, and women’s programs are built to multiply. Favor Partners get them started."
    ctaLabel="Become a Favor Partner"
    ctaHref="/give/partner-monthly/"
    image="/images/field/women-empowerment-uganda.webp"
    imageAlt="Women receiving livestock at a Favor empowerment cohort in Uganda"
    variant="green"
  />
</PageLayout>

<style>
  .ee-head { max-width: 720px; margin: 0 auto var(--space-10); text-align: center; }
  .acard-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--space-6); }
  @media (max-width: 860px) { .acard-grid { grid-template-columns: 1fr; } }
  .acard { background: var(--color-white); border-radius: var(--radius-card); padding: var(--space-6); border: 2px solid var(--accent, var(--color-gold)); box-shadow: var(--shadow-soft); }
  .acard h3 { margin: 0 0 var(--space-3); color: var(--color-green); font-size: 1.2rem; }
  .acard p { margin: 0; color: var(--color-ink-soft); line-height: 1.65; }
  .acard:nth-child(4n+1) { --accent: var(--color-gold-deep); }
  .acard:nth-child(4n+2) { --accent: var(--color-green-bright); }
  .acard:nth-child(4n+3) { --accent: var(--color-terracotta); }
  .acard:nth-child(4n+4) { --accent: var(--color-sage); }
</style>
