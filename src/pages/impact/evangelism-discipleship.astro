---
import PageLayout from '../../layouts/PageLayout.astro';
import PageHero from '../../components/band/PageHero.astro';
import OverlayFeature from '../../components/band/OverlayFeature.astro';
import VideoEmbed from '../../components/global/VideoEmbed.astro';
import Figure from '../../components/global/Figure.astro';
import CtaBand from '../../components/band/CtaBand.astro';

const programs = [
  { name: 'Portable Bible Schools (PBS)', image: '/images/pbs-karamoja.jpg', desc: 'Three- to six-month church-based training that goes where no seminary can. Cohorts move village to village in places like Karamoja, the Mundari cattle camps of South Sudan, and the Ethiopian highlands. Most students will never see the inside of a Bible college; PBS is the Bible college.' },
  { name: 'GIFT Leadership Institute', image: '/images/gift-bishoftu-tot.jpg', desc: 'A two-year residential training program for the next generation of indigenous African pastors. Bishoftu, Ethiopia campus. Students are sent home equipped to plant churches, lead trainings, and disciple their own people.' },
  { name: 'House of Prayer', image: '/images/ministry-house-of-prayer.jpg', desc: 'Continuous intercession from the field. Trains local prayer warriors and connects them to a global prayer network. Many of Favor’s field decisions are made in this room first.' },
  { name: 'Favor FM (Christian Radio)', image: '/images/ministry-radio.jpg', desc: 'FM stations broadcasting in northern Uganda and South Sudan. Discipleship content in local languages, on-demand pastoral care by call-in, and Gospel reach into villages without churches.' },
];

const gallery = [
  { src: '/images/story-anaka-crusade.jpg', caption: 'A field crusade in Anaka, northern Uganda' },
  { src: '/images/hero-bibles-stacks.jpg', caption: 'Bibles staged for distribution by PBS teams' },
  { src: '/images/hero-pastor-preaching.jpg', caption: 'An indigenous pastor preaching in the field' },
  { src: '/images/hero-congo-grads.jpg', caption: 'Portable Bible School graduates, DR Congo' },
];
---
<PageLayout
  title="Evangelism & Discipleship"
  description="Portable Bible Schools, GIFT Leadership Institute, House of Prayer, and Favor FM: the four programs by which Favor International equips indigenous pastors to evangelize and disciple across East Africa."
>
  <PageHero
    label="Pillar 1 of 4"
    title="Evangelism & Discipleship."
    promise="Indigenous pastors and teachers reaching villages and tribes others will not. PBS, GIFT, House of Prayer, Favor FM."
    image="/images/pillar-evangelism-discipleship.jpg"
    imageAlt="Portable Bible School mobilization in the field"
    objectPosition="center 18%"
    ctaLabel="Fund a pastor"
    ctaHref="/give/specific-project/gift-dormitory/"
  />

  <section class="band band--white">
    <div class="container">
      <div class="ed-video">
        <div class="ed-video__copy">
          <p class="label">From the field</p>
          <h2>See it where it happens.</h2>
          <p>Before you read a word of program description, watch the work. This is evangelism and discipleship in Africa, led by the indigenous pastors who live there.</p>
        </div>
        <div class="ed-video__player">
          <VideoEmbed id="C5VBPhA50Mg" title="Evangelism in Africa: Building Lasting Disciples Through God's Word" />
        </div>
      </div>
    </div>
  </section>

  <section class="band band--cream">
    <div class="container">
      <header class="band__header">
        <p class="label">The four programs</p>
        <h2>How indigenous pastors get equipped.</h2>
      </header>
      <div class="ed-programs">
        {programs.map((p) => (
          <article class="ed-prog">
            <Figure src={p.image} alt={p.name} ratio="16 / 10" />
            <div class="ed-prog__body">
              <h3>{p.name}</h3>
              <p>{p.desc}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <OverlayFeature
    image="/images/stories/daniel-kidia.jpg"
    imageAlt="Daniel Kidia, a Favor field pastor in South Sudan"
    eyebrow="Daniel Kidia &middot; South Sudan"
    heading="&ldquo;There are so many precious to God in Africa that need to know the truth. They are ready for a change in their villages, towns, and nations.&rdquo;"
    side="left"
  >
    <p>A former Mundari cattle warrior, now a Favor field pastor leading Portable Bible School classes among his own people.</p>
  </OverlayFeature>

  <section class="band band--white">
    <div class="container container--narrow">
      <header class="band__header">
        <p class="label">The programs in depth</p>
        <h2>How the work happens on the ground.</h2>
      </header>
      <div class="faq ed-depth">
        <details open>
          <summary>Portable Bible Schools (PBS)</summary>
          <p>Favor&rsquo;s Portable Bible Schools (PBSs) mobilize new disciple-makers into physical and spiritual war zones. Whether a life-time believer or brand-new convert, all come hungry for the Word and for training. These emerging leaders come from hidden corners, of nations restrictive of and hostile to the Gospel, for the two-month discipleship training that Favor brings to rural villages, always moving further outward into the unreached tribes.</p>
        </details>
        <details>
          <summary>Houses of Prayer</summary>
          <p>Our Houses of Prayer in Gulu, Uganda, and in Juba, South Sudan were our first operational centers, before offices, schools, radio, or leadership training facilities. Prayer always comes first and then everything else follows.</p>
          <p>Our House of Prayer ministry teams do so much, from leading morning devotions and noon-hour prayers every weekday to all-night prayer events. They also launch local and rural outreaches and ministries on the streets, in hospitals, and in prisons. They provide a 24/7 prayer covering for new believers, organize pastors&rsquo; fellowships and national prayer gatherings, and coordinate local crusades.</p>
        </details>
        <details>
          <summary>Christian Radio</summary>
          <p>Favor operates two radio stations that cover Gulu, Uganda, and Juba, South Sudan, reaching people in the right place at the right time. Our programming is a mix of teaching, music, news, testimonies, prayer, preaching, education, and more. We have become one of the highest preferred radio stations in the regions of both nations, with a high level of daily community involvement and call-ins.</p>
        </details>
      </div>
    </div>
  </section>

  <section class="band band--cream">
    <div class="container">
      <header class="band__header">
        <p class="label">From the field</p>
        <h2>Real people, real places.</h2>
      </header>
      <div class="ed-gallery">
        {gallery.map((g) => (
          <figure class="ed-tile" style={`background-image:url(${g.src})`} role="img" aria-label={g.caption}>
            <figcaption>{g.caption}</figcaption>
          </figure>
        ))}
      </div>
    </div>
  </section>

  <CtaBand
    heading="Send a pastor into the unreached."
    body="Fund a PBS cohort, sponsor a GIFT student, or become a Favor Partner to keep all four programs going."
    ctaLabel="Become a Favor Partner"
    ctaHref="/give/partner-monthly/"
    image="/images/highlight-crowd.jpg"
    imageAlt="A field gathering in northern Uganda"
    variant="green"
  />
</PageLayout>

<style>
  .ed-video { display: block; text-align: center; }
  .ed-video__copy { max-width: 680px; margin: 0 auto var(--space-8); }
  .ed-video__copy h2 { margin: 0 0 var(--space-4); }
  .ed-video__copy p { color: var(--color-ink-soft); line-height: 1.7; margin: 0; }
  .ed-video__player { max-width: 940px; margin: 0 auto; }

  .ed-programs { display: grid; grid-template-columns: repeat(2, 1fr); gap: var(--space-8); }
  @media (max-width: 760px) { .ed-programs { grid-template-columns: 1fr; } }
  .ed-prog { background: var(--color-white); border-radius: var(--radius-card); overflow: hidden; box-shadow: var(--shadow-card); display: flex; flex-direction: column; }
  .ed-prog :global(.figure__img) { border-radius: 0; box-shadow: none; }
  .ed-prog__body { padding: var(--space-6); }
  .ed-prog__body h3 { margin: 0 0 var(--space-3); color: var(--color-green); font-size: 1.25rem; }
  .ed-prog__body p { margin: 0; color: var(--color-ink-soft); line-height: 1.65; }

  .ed-depth { margin-top: var(--space-2); }
  .ed-depth details { border: 2px solid var(--accent, var(--color-gold)); }
  .ed-depth details:nth-of-type(4n+1) { --accent: var(--color-gold-deep); }
  .ed-depth details:nth-of-type(4n+2) { --accent: var(--color-green-bright); }
  .ed-depth details:nth-of-type(4n+3) { --accent: var(--color-terracotta); }
  .ed-depth details:nth-of-type(4n+4) { --accent: var(--color-sage); }

  /* Field gallery: 2x2 of larger photos with the caption baked onto the image. */
  .ed-gallery { display: grid; grid-template-columns: repeat(2, 1fr); gap: var(--space-6); max-width: 1040px; margin: 0 auto; }
  @media (max-width: 560px) { .ed-gallery { grid-template-columns: 1fr; } }
  .ed-tile { position: relative; margin: 0; aspect-ratio: 3 / 2; background-size: cover; background-position: center 30%; border-radius: var(--radius-card); overflow: hidden; box-shadow: var(--shadow-card); }
  .ed-tile figcaption {
    position: absolute; left: 0; right: 0; bottom: 0;
    padding: var(--space-8) var(--space-6) var(--space-5);
    background: linear-gradient(180deg, rgba(20,30,18,0) 0%, rgba(20,30,18,0.82) 100%);
    color: #fff; font-weight: 700; font-size: 1.02rem; line-height: 1.3;
    text-shadow: 0 1px 8px rgba(0,0,0,0.4);
  }
</style>
