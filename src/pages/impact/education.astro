---
import PageLayout from '../../layouts/PageLayout.astro';
import PageHero from '../../components/band/PageHero.astro';
import ProofBlock from '../../components/band/ProofBlock.astro';
import CtaBand from '../../components/band/CtaBand.astro';

const programs = [
  { name: 'Village Learning Centers (VLCs)', desc: 'Local-language literacy and Bible foundations for kids in places no formal school will reach. 18 active VLCs across Uganda and South Sudan.' },
  { name: 'Primary + Secondary Schools', desc: 'Six accredited Favor schools serving 1,400+ students. Christ-centered curriculum, Ugandan and South Sudanese teaching staff.' },
  { name: 'Leadership Training', desc: 'Teacher development and school administrator training cohorts. Builds the long-term pipeline so the schools stay indigenous.' },
];
---
<PageLayout
  title="Education"
  description="Village Learning Centers, primary and secondary schools, and leadership training: Favor International's education pillar."
>
  <PageHero
    label="Pillar 2 of 4"
    title="Education."
    promise="Village learning centers and schools that pull children out of poverty and into the Kingdom."
    image="/images/pillar-education.jpg"
    imageAlt="Village learning center in South Sudan"
    ctaLabel="Sponsor a student"
    ctaHref="/give/specific-project/gulu-primary-school/"
  />

  <section class="band band--white">
    <div class="container container--narrow">
      <p class="label">The three programs</p>
      <h2>From letters to leaders.</h2>
      <ul class="program-list">
        {programs.map((p) => (
          <li>
            <h3>{p.name}</h3>
            <p>{p.desc}</p>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <section class="band band--cream">
    <div class="container container--narrow" style="text-align:center;">
      <p class="label">What this looks like on the ground</p>
      <h2 style="margin-bottom: var(--space-4);">Read field stories from the schools.</h2>
      <p style="max-width: 56ch; margin: 0 auto var(--space-6) auto;">
        Every student photo in this section is from a real classroom in northern Uganda,
        South Sudan, or Ethiopia. The field teams publish a new field report most weeks. Each one is a named teacher, a named village, and an outcome they can stand behind.
      </p>
      <a class="btn btn--secondary btn--large" href="/stories/">See stories from the field</a>
    </div>
  </section>

  <section class="band band--white">
    <div class="container container--narrow">
      <p class="label">The programs in depth</p>
      <h2>From letters to leaders, program by program.</h2>
      <div class="depth">
        <article>
          <h3>Village Learning Centers</h3>
          <p>Our approach is to increase access to quality education by implementing village learning centers, in church buildings, that younger students in a village locale can reach on foot. We use the Roots to Fruit curriculum, which is a Bible-based, Christian approach to education approved by the Ugandan government, for primary school.</p>
        </article>
        <article>
          <h3>Favor Primary School</h3>
          <p>The mission of Favor Primary Schools is to educate the next generation of Uganda&rsquo;s and South Sudan&rsquo;s leadership on the Word of God, prayer, and academic excellence. Our schools in both Gulu and Juba receive kids from all walks of life, religions, and income levels. We strive to maintain a 30:1 student-to-teacher ratio, and the schools have gained a reputation of excellence with some of our students in Uganda scoring the highest in the Gulu district of 160 schools.</p>
        </article>
        <article>
          <h3>Favor Secondary School</h3>
          <p>Our Favor Secondary School opened to the public for the first time in February 2023. We have welcomed 135 registered students from all walks of life, religions, and income levels. We openly teach and practice the Word of God, and these amazing young men and women routinely come to know the love of Jesus as they pray and see God move.</p>
        </article>
        <article>
          <h3>Leadership Training Institute</h3>
          <p>Favor&rsquo;s Leadership Training Institute addresses both in a blend of in-class and hands-on instruction tailored to produce powerful ministers of spiritual and cultural transformation. All our indigenous staff participate in constant training including Bible training, prayer, marriage enrichment, household finances, small business entrepreneurship, and much much more!</p>
        </article>
      </div>
    </div>
  </section>

  <CtaBand
    heading="Stand with the schools."
    body="Favor Partners make Village Learning Centers and the primary and secondary schools possible every month. Pick the tier that fits."
    ctaLabel="Become a Favor Partner"
    ctaHref="/give/partner-monthly/"
    variant="green"
  />
</PageLayout>

<style>
  .program-list { list-style: none; padding: 0; margin: var(--space-8) 0 0; display: grid; gap: var(--space-4); }
  .program-list li { padding: var(--space-6); background: var(--color-cream); border-left: 4px solid var(--color-gold); border-radius: var(--radius-input); }
  .program-list h3 { margin: 0 0 var(--space-3); color: var(--color-green); font-size: 1.15rem; }
  .program-list p { margin: 0; color: var(--color-ink-soft); }
  .depth { display: grid; gap: var(--space-6); margin-top: var(--space-6); }
  .depth article { padding: var(--space-6); background: var(--color-cream); border-left: 4px solid var(--color-gold); border-radius: var(--radius-input); }
  .depth h3 { margin: 0 0 var(--space-3); color: var(--color-green); font-size: 1.15rem; }
  .depth p { margin: 0 0 var(--space-3); color: var(--color-ink-soft); }
  .depth p:last-child { margin-bottom: 0; }
</style>
