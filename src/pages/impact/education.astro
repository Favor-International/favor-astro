---
import PageLayout from '../../layouts/PageLayout.astro';
import PageHero from '../../components/band/PageHero.astro';
import OverlayFeature from '../../components/band/OverlayFeature.astro';
import CtaBand from '../../components/band/CtaBand.astro';

const programs = [
  { name: 'Village Learning Centers (VLCs)', desc: 'Local-language literacy and Bible foundations for kids in places no formal school will reach. 18 active VLCs across Uganda and South Sudan.' },
  { name: 'Primary + Secondary Schools', desc: 'Six accredited Favor schools serving 1,400+ students. Christ-centered curriculum, Ugandan and South Sudanese teaching staff.' },
  { name: 'Leadership Training', desc: 'Teacher development and school administrator training cohorts. Builds the long-term pipeline so the schools stay indigenous.' },
];

const depth = [
  { name: 'Village Learning Centers', body: 'Our approach is to increase access to quality education by implementing village learning centers, in church buildings, that younger students in a village locale can reach on foot. We use the Roots to Fruit curriculum, which is a Bible-based, Christian approach to education approved by the Ugandan government, for primary school.' },
  { name: 'Favor Primary School', body: 'The mission of Favor Primary Schools is to educate the next generation of Uganda’s and South Sudan’s leadership on the Word of God, prayer, and academic excellence. Our schools in both Gulu and Juba receive kids from all walks of life, religions, and income levels. We strive to maintain a 30:1 student-to-teacher ratio, and the schools have gained a reputation of excellence with some of our students in Uganda scoring the highest in the Gulu district of 160 schools.' },
  { name: 'Favor Secondary School', body: 'Our Favor Secondary School opened to the public for the first time in February 2023. We have welcomed 135 registered students from all walks of life, religions, and income levels. We openly teach and practice the Word of God, and these amazing young men and women routinely come to know the love of Jesus as they pray and see God move.' },
  { name: 'Leadership Training Institute', body: 'Favor’s Leadership Training Institute addresses both in a blend of in-class and hands-on instruction tailored to produce powerful ministers of spiritual and cultural transformation. All our indigenous staff participate in constant training including Bible training, prayer, marriage enrichment, household finances, small business entrepreneurship, and much much more!' },
];
---
<PageLayout
  title="Education"
  description="Village Learning Centers, primary and secondary schools, and leadership training: Favor International's education pillar."
>
  <PageHero
    label="Pillar 2 of 4"
    title="Education."
    promise="Village learning centers and schools that pull children out of poverty and into the Kingdom."
    image="/images/pillar-education.jpg"
    imageAlt="Village learning center in South Sudan"
    ctaLabel="Sponsor a student"
    ctaHref="/give/specific-project/gulu-primary-school/"
  />

  <section class="band band--white">
    <div class="container">
      <header class="ed-head">
        <p class="label">The three programs</p>
        <h2>From letters to leaders.</h2>
      </header>
      <div class="acard-grid">
        {programs.map((p) => (
          <article class="acard has-texture">
            <h3>{p.name}</h3>
            <p>{p.desc}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <OverlayFeature
    image="/images/education-vlc-jondoru.jpg"
    imageAlt="A village learning center class in Jondoru"
    eyebrow="On the ground"
    heading="A real classroom, in a real village."
    side="left"
  >
    <p>Every student photo in this section is from a real classroom in northern Uganda, South Sudan, or Ethiopia. The field teams publish a new field report most weeks. Each one is a named teacher, a named village, and an outcome they can stand behind.</p>
    <p><a href="/stories/">See stories from the field &rarr;</a></p>
  </OverlayFeature>

  <section class="band band--cream">
    <div class="container">
      <header class="ed-head">
        <p class="label">The programs in depth</p>
        <h2>From letters to leaders, program by program.</h2>
      </header>
      <div class="acard-grid acard-grid--2">
        {depth.map((d) => (
          <article class="acard has-texture">
            <h3>{d.name}</h3>
            <p>{d.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <CtaBand
    heading="Stand with the schools."
    body="Favor Partners make Village Learning Centers and the primary and secondary schools possible every month. Pick the tier that fits."
    ctaLabel="Become a Favor Partner"
    ctaHref="/give/partner-monthly/"
    variant="green"
  />
</PageLayout>

<style>
  .ed-head { max-width: 720px; margin: 0 auto var(--space-10); text-align: center; }
  .acard-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--space-6); }
  .acard-grid--2 { grid-template-columns: repeat(2, 1fr); }
  @media (max-width: 860px) { .acard-grid, .acard-grid--2 { grid-template-columns: 1fr; } }
  .acard { background: var(--color-white); border-radius: var(--radius-card); padding: var(--space-6); border-top: 5px solid var(--accent, var(--color-gold)); box-shadow: var(--shadow-soft); }
  .acard h3 { margin: 0 0 var(--space-3); color: var(--color-green); font-size: 1.2rem; }
  .acard p { margin: 0; color: var(--color-ink-soft); line-height: 1.65; }
  .acard:nth-child(4n+1) { --accent: var(--color-gold-deep); }
  .acard:nth-child(4n+2) { --accent: var(--color-green-bright); }
  .acard:nth-child(4n+3) { --accent: var(--color-terracotta); }
  .acard:nth-child(4n+4) { --accent: var(--color-sage); }
</style>
