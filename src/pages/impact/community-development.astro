---
import PageLayout from '../../layouts/PageLayout.astro';
import PageHero from '../../components/band/PageHero.astro';
import OverlayFeature from '../../components/band/OverlayFeature.astro';
import VideoEmbed from '../../components/global/VideoEmbed.astro';
import CtaBand from '../../components/band/CtaBand.astro';

const gallery = [
  { src: '/images/field/medical-uganda.webp', caption: 'A Favor medical clinic in Uganda' },
  { src: '/images/field/baptism-south-sudan.webp', caption: 'A baptism on the water in South Sudan' },
  { src: '/images/field/church-dedication-uganda.webp', caption: 'A church gathered for dedication in Uganda' },
  { src: '/images/ministry-church-planting.jpg', caption: 'Believers gathering where a church was planted' },
];

const programs = [
  { name: 'Medical', accent: 'var(--color-green-bright)', body: 'In both Uganda and South Sudan, we have Favor clinics that provide basic medical care to our staff and their families, and to our former street youth who are in residence. In Uganda, where 50% or more of the population lives in extreme poverty, our clinic just opened to the public providing low-cost medical assistance to the community.' },
  { name: 'Church Planting', accent: 'var(--color-gold-deep)', body: 'In many rural communities there are no churches, so following a Portable Bible School small churches are planted, sometimes meeting in a hut or under a mango tree. Churches are also planted as a result of church construction. Once a church is constructed the mandate is for them to plant 3 more churches in 5 years.' },
  { name: 'Church Construction', accent: 'var(--color-terracotta)', body: 'Favor partners with International Cooperating Ministries (ICM) to fund the new church construction, and ICM has helped Favor build many churches across Uganda and South Sudan. These churches don’t belong to Favor but to the community of believers and their leadership from that local church.' },
];
---
<PageLayout
  title="Community Development"
  description="Trauma counseling, medical services, and church planting: Favor International's community development pillar."
>
  <PageHero
    label="Pillar 3 of 4"
    title="Community Development."
    promise="Trauma counseling, medical services, and church planting in places no other ministry will go."
    image="/images/pillar-community-care.jpg"
    imageAlt="Field medical care in South Sudan"
    ctaLabel="Fund a clinic"
    ctaHref="/give/specific-project/"
  />

  <section class="band band--white">
    <div class="container">
      <div class="video-feature">
        <div class="video-feature__copy">
          <p class="label">From the field</p>
          <h2>Where medicine meets miracles.</h2>
          <p>Medical care, church planting, and trauma healing reach places no other ministry will go. Watch the work, then read how each program runs.</p>
        </div>
        <div class="video-feature__player">
          <VideoEmbed id="4YpOvDoc6k4" title="Where Medicine Meets Miracles" />
        </div>
      </div>
    </div>
  </section>

  <section class="band band--cream">
    <div class="container">
      <header class="cd-head">
        <p class="label">The work</p>
        <h2>Bringing healing to the whole person.</h2>
      </header>
      <div class="cd-grid">
        {programs.map((p) => (
          <article class="cd-card has-texture" style={`--accent: ${p.accent}`}>
            <h3>{p.name}</h3>
            <p>{p.body}</p>
          </article>
        ))}
      </div>
      <p class="cd-cta-row"><a class="btn btn--secondary btn--large" href="/stories/">See field stories</a></p>
    </div>
  </section>

  <OverlayFeature
    image="/images/hero-trauma-counseling.jpg"
    imageAlt="A trauma counseling session in the field"
    eyebrow="Trauma counseling"
    heading="Healing the whole person."
    side="left"
  >
    <p>Our trauma healing program has two parts. The first section focuses on developing emotional strength, and the second teaches about forgiveness. Throughout the program, the counselors teach people how to connect to one another and counter stress with positive activity.</p>
    <p>The original Trauma Counseling curriculum that we use was <strong>written by Christ-believing psychologists from Australia, peer-reviewed through publications at Boston University</strong>, and for many years has been adapted and contextualized for the many people groups we serve throughout South Sudan and Uganda.</p>
  </OverlayFeature>

  <section class="band band--white">
    <div class="container">
      <header class="band__header">
        <p class="label">From the field</p>
        <h2>Healing, planting, baptizing.</h2>
      </header>
      <div class="field-gallery">
        {gallery.map((g) => (
          <figure class="field-tile" style={`background-image:url(${g.src})`} role="img" aria-label={g.caption}>
            <figcaption>{g.caption}</figcaption>
          </figure>
        ))}
      </div>
    </div>
  </section>

  <CtaBand
    heading="Help carry the cost of healing."
    body="Trauma counseling, medical clinics, and church planting are field-led. Favor Partners keep them funded."
    ctaLabel="Become a Favor Partner"
    ctaHref="/give/partner-monthly/"
    image="/images/pillar-community.jpg"
    imageAlt="A Favor community gathering"
  />
</PageLayout>

<style>
  .cd-head { text-align: center; max-width: 720px; margin: 0 auto var(--space-12); }
  .cd-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--space-6); }
  @media (max-width: 860px) { .cd-grid { grid-template-columns: 1fr; } }
  .cd-card { background: var(--color-white); border-radius: var(--radius-card); padding: var(--space-6); border-top: 5px solid var(--accent, var(--color-gold)); box-shadow: var(--shadow-soft); }
  .cd-card h3 { margin: 0 0 var(--space-3); color: var(--color-green); font-size: 1.25rem; }
  .cd-card p { margin: 0; color: var(--color-ink-soft); line-height: 1.65; }
  .cd-cta-row { text-align: center; margin-top: var(--space-16); }
</style>
