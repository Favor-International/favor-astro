---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteHeader from '../components/global/SiteHeader.astro';
import SiteFooter from '../components/global/SiteFooter.astro';
import PatternDivider from '../components/global/PatternDivider.astro';
import AfricaMap from '../components/global/AfricaMap.astro';
import { SITE } from '../lib/site';

// =====================================================================
// HOMEPAGE v15 — Compassion-style structural cut.
// Five sections only: Hero, Proof + Trust, Map, One Missionary Story,
// Give. Every other band has been removed and lives on a deeper page.
// The through-line is the indigenous missionary. The partner sends them.
// Everything else (4 pillars, vision/mission, vision trips, prayer
// guide, stories index, scripture pause) moves to dedicated routes.
// =====================================================================

// The featured missionary anchors the entire story. Real name,
// real place, real before/after. The partner gift literally
// keeps this person on the trail. One name beats six.
const missionary = {
  name: 'Daniel Kidia',
  country: 'South Sudan',
  before: 'A Mundari cattle warrior.',
  after: 'A Favor field pastor leading Portable Bible Schools among his own people.',
  image: '/images/stories/daniel-kidia.jpg',
  href: '/stories/daniel-kidia/',
};

// The giving tiers come straight from the Website Language Strategy
// doc (Section 9). Numbers are placeholders pending Carole's final
// review of dollar-to-impact math, but the structure is set.
const tiers = [
  { amount: '$25',    label: 'Equip',     line: 'A Bible and discipleship materials for a new believer.' },
  { amount: '$50',    label: 'Send',      line: 'One month of support for an indigenous missionary.', featured: true },
  { amount: '$100',   label: 'Educate',   line: 'A child’s schooling, meals, and Gospel teaching.' },
  { amount: '$250',   label: 'Heal',      line: 'Trauma counseling for a community recovering from war.' },
  { amount: '$500',   label: 'Transform', line: 'A Portable Bible School session for 20+ church planters.' },
  { amount: '$1,000', label: 'Movement',  line: 'Launches a church plant in an unreached village.' },
];
---
<BaseLayout
  title={SITE.name}
  description="You can send an indigenous missionary where the Gospel has not reached. Favor International equips local church planters across 14 nations of East and Central Africa. ECFA-accredited."
  image="/images/hero-pastor-preaching.jpg"
>
  <SiteHeader variant="transparent" />
  <main id="main">

    <!-- ====================================================
         1. HERO
         ==================================================== -->
    <section class="hero" aria-label="You can send the Gospel where no one else will go">
      <video
        class="hero__video"
        autoplay
        muted
        loop
        playsinline
        preload="metadata"
        poster="/videos/home-hero-poster.jpg"
        aria-hidden="true"
      >
        <source src="/videos/home-hero.mp4" type="video/mp4" />
      </video>
      <div class="hero__scrim" aria-hidden="true"></div>
      <div class="hero__inner container">
        <div class="hero__copy">
          <p class="hero__eyebrow">Become a sender</p>
          <h1 class="hero__h1">You can send the Gospel where no one else will go.</h1>
          <p class="hero__sub">Favor equips indigenous missionaries to plant churches in the hardest places on earth, across 14 nations of East and Central Africa. Your $50 a month keeps one of them on the trail.</p>
          <div class="hero__cta">
            <a class="btn btn--primary btn--large hero__primary" href="/give/partner-monthly/">Send a missionary for $50/month <span aria-hidden="true">&rarr;</span></a>
            <a class="hero__secondary" href="/give/once/">Or give a one-time gift</a>
          </div>
        </div>
      </div>
    </section>

    <!-- ====================================================
         2. PROOF + TRUST (numbers and watchdog badges in one breath)
         ==================================================== -->
    <section class="proof" aria-label="What your partnership has done">
      <div class="container proof__inner">
        <div class="proof__stats">
          <div class="proof__stat">
            <span class="proof__num">195,773</span>
            <span class="proof__label">Came to Christ in 2025</span>
          </div>
          <span class="proof__divider" aria-hidden="true"></span>
          <div class="proof__stat">
            <span class="proof__num">119,182</span>
            <span class="proof__label">Discipled in 2025</span>
          </div>
          <span class="proof__divider" aria-hidden="true"></span>
          <div class="proof__stat">
            <span class="proof__num">14</span>
            <span class="proof__label">Nations served</span>
          </div>
        </div>
        <p class="proof__line">
          Audited by three independent watchdogs.
          <a href="/about/accountability/">See the financials &rarr;</a>
        </p>
        <ul class="proof__badges" aria-label="Accountability">
          <li><a href={SITE.trust.ecfa} target="_blank" rel="noopener"><img src="/images/trust/ecfa.png" alt="ECFA Accredited" loading="lazy" /></a></li>
          <li><a href={SITE.trust.charityNavigator} target="_blank" rel="noopener"><img src="/images/trust/charity-navigator.svg" alt="Charity Navigator Four-Star" loading="lazy" /></a></li>
          <li><a href={SITE.trust.candid} target="_blank" rel="noopener"><img src="/images/trust/candid-platinum.svg" alt="Candid Platinum Transparency" loading="lazy" /></a></li>
        </ul>
      </div>
    </section>

    <PatternDivider variant="cream" height="110px" />

    <!-- ====================================================
         3. AFRICA MAP
         ==================================================== -->
    <AfricaMap />

    <PatternDivider variant="cream" height="110px" />

    <!-- ====================================================
         4. ONE MISSIONARY STORY — Daniel Kidia, anchor of the page.
         Carole's voice lives inside this band as the spiritual anchor.
         ==================================================== -->
    <section class="missionary" aria-label="Meet a missionary your partnership supports">
      <div class="container missionary__grid">
        <figure class="missionary__photo">
          <img src={missionary.image} alt={`${missionary.name}, a Favor field pastor in ${missionary.country}.`} loading="lazy" />
          <figcaption class="missionary__caption">{missionary.name} &middot; {missionary.country}</figcaption>
        </figure>
        <div class="missionary__copy">
          <p class="eyebrow eyebrow--gold">A missionary your partnership supports</p>
          <h2 class="missionary__h2">Before he was a pastor, he was a cattle warrior.</h2>
          <p class="missionary__lede">
            {missionary.before} Today, Daniel leads Portable Bible Schools across South Sudan,
            training other former warriors to plant churches in their own villages.
            Your $50 a month feeds him, fuels his motorbike, and stocks the Bibles he hands out.
          </p>
          <blockquote class="missionary__carole">
            <p class="missionary__carole-quote">&ldquo;Send me where no one else will go.&rdquo;</p>
            <footer class="missionary__carole-attr">
              <span class="missionary__carole-name">Carole Ward</span>
              <span class="missionary__carole-role">Founder &middot; the prayer that started Favor</span>
            </footer>
          </blockquote>
          <a class="btn btn--primary btn--large missionary__cta" href="/give/partner-monthly/">Send Daniel and missionaries like him <span aria-hidden="true">&rarr;</span></a>
          <a class="missionary__read" href={missionary.href}>Read Daniel&rsquo;s full story &rarr;</a>
        </div>
      </div>
    </section>

    <PatternDivider variant="green" height="140px" />

    <!-- ====================================================
         5. GIVE (tiers + final CTA + Florida disclosure)
         ==================================================== -->
    <section class="give" id="give" aria-label="Pick the partnership that fits your life">
      <!-- Background video. Source is NOT attached on page load — an
           IntersectionObserver attaches it when the section is within
           800px of the viewport, so the give-bg.mp4 (235 KB) never
           counts against initial page-load metrics. The poster JPG
           covers the section until the video boots. -->
      <video
        class="give__bg"
        muted
        loop
        playsinline
        preload="none"
        poster="/videos/give-bg-poster.jpg"
        data-lazy-src="/videos/give-bg.mp4"
        aria-hidden="true"
      ></video>
      <div class="give__scrim" aria-hidden="true"></div>
      <div class="container give__inner">
        <header class="give__head">
          <p class="eyebrow eyebrow--gold-on-dark">Become a Favor Partner</p>
          <h2 class="give__h2">Pick the partnership that fits your life.</h2>
          <p class="give__lede">Monthly partners are the engine of the movement. Every gift is tax-deductible. Cancel anytime.</p>
        </header>
        <ul class="give__tiers">
          {tiers.map((t) => (
            <li class:list={['give__tier', t.featured && 'give__tier--featured']}>
              {t.featured && <span class="give__tier-flag">Most partners start here</span>}
              <span class="give__tier-amount">{t.amount}</span>
              <span class="give__tier-label">{t.label}</span>
              <p class="give__tier-line">{t.line}</p>
            </li>
          ))}
        </ul>
        <div class="give__final">
          <a class="btn btn--primary btn--large give__cta" href="/give/partner-monthly/">Become a Favor Partner <span aria-hidden="true">&rarr;</span></a>
          <p class="give__line">Tax-deductible. ECFA-accredited since 2019. <a href="/give/once/">Or give a one-time gift &rarr;</a></p>
        </div>
        <p class="give__fdacs">
          A copy of the official registration and financial information for Favor International, Inc. (CH57842) may be obtained from the Florida Division of Consumer Services by visiting fdacs.gov or calling toll-free 1-800-HELP-FLA (1-800-435-7352) within the state. Registration does not imply endorsement, approval, or recommendation by the State. EIN {SITE.ein}.
        </p>
      </div>
    </section>

  </main>
  <SiteFooter />
</BaseLayout>

<script>
  // Lazy-load the Give-section background video. Attach the real source
  // and start playback only when the section is within 800px of the
  // viewport. Until then the poster JPG covers the section.
  const give = document.querySelector('.give__bg') as HTMLVideoElement | null;
  if (give && 'IntersectionObserver' in window) {
    const src = give.dataset.lazySrc;
    if (src) {
      const io = new IntersectionObserver((entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            if (!give.querySelector('source')) {
              const s = document.createElement('source');
              s.src = src;
              s.type = 'video/mp4';
              give.appendChild(s);
              give.load();
              give.play().catch(() => { /* autoplay may be blocked; poster stays */ });
            }
            io.disconnect();
          }
        }
      }, { rootMargin: '800px 0px' });
      io.observe(give);
    }
  } else if (give) {
    // Fallback for environments without IntersectionObserver — just load it
    const src = give.dataset.lazySrc;
    if (src) {
      const s = document.createElement('source');
      s.src = src;
      s.type = 'video/mp4';
      give.appendChild(s);
      give.load();
      give.play().catch(() => {});
    }
  }
</script>

<style>
  /* ========== SHARED ========== */
  .eyebrow {
    margin: 0 0 var(--space-3) 0;
    font-family: var(--font-sans);
    font-size: 0.82rem;
    font-weight: 800;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: var(--color-sage);
  }
  .eyebrow--gold       { color: var(--color-gold-deep); }
  .eyebrow--green      { color: var(--color-green-deep); }
  .eyebrow--gold-on-dark { color: var(--color-gold); }

  /* ========== HERO ========== */
  .hero {
    position: relative;
    min-height: clamp(680px, 96vh, 920px);
    display: flex; align-items: center;
    color: var(--color-white);
    overflow: hidden;
  }
  .hero__video {
    position: absolute; inset: 0;
    width: 100%; height: 100%;
    object-fit: cover;
    object-position: 50% 50%;
    z-index: 0;
    display: block;
  }
  .hero__scrim {
    position: absolute; inset: 0; z-index: 1;
    background: linear-gradient(90deg,
      rgba(11, 64, 36, 0.96) 0%,
      rgba(11, 64, 36, 0.90) 28%,
      rgba(11, 64, 36, 0.55) 52%,
      rgba(11, 64, 36, 0.10) 72%,
      rgba(11, 64, 36, 0) 100%);
  }
  .hero__inner { position: relative; z-index: 2; width: 100%; padding-top: 120px; padding-bottom: var(--space-12); }
  .hero__copy  { max-width: 740px; }
  .hero__eyebrow {
    margin: 0 0 var(--space-5) 0;
    font-family: var(--font-sans);
    font-size: 0.95rem;
    font-weight: 800;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: var(--color-gold);
  }
  .hero__h1 {
    margin: 0 0 var(--space-6) 0;
    font-family: var(--font-display);
    font-size: clamp(2.6rem, 6vw, 5rem);
    font-weight: 700; line-height: 1.02;
    letter-spacing: -0.02em;
    color: var(--color-white);
    text-wrap: balance;
  }
  .hero__sub {
    margin: 0 0 var(--space-8) 0;
    font-size: clamp(1.05rem, 1.4vw, 1.2rem);
    line-height: 1.6;
    color: color-mix(in srgb, var(--color-white) 92%, transparent);
    max-width: 56ch;
  }
  .hero__cta { display: flex; align-items: center; gap: var(--space-6); flex-wrap: wrap; }
  .hero__primary {
    border-radius: 999px; padding: 20px 36px;
    font-size: 1.05rem; gap: var(--space-3);
    box-shadow: 0 18px 40px rgba(0, 0, 0, 0.25);
  }
  .hero__primary:hover { transform: translateY(-2px); box-shadow: 0 22px 48px rgba(0, 0, 0, 0.32); }
  .hero__secondary {
    color: color-mix(in srgb, var(--color-white) 92%, transparent);
    font-size: 0.95rem; font-weight: 600;
    text-decoration: none;
    border-bottom: 1px solid color-mix(in srgb, var(--color-gold) 80%, transparent);
    padding-bottom: 3px;
    transition: color 200ms, border-color 200ms;
  }
  .hero__secondary:hover { color: var(--color-gold); border-color: var(--color-gold); }
  @media (max-width: 900px) {
    .hero__inner { padding-top: 110px; }
    .hero__scrim { background: linear-gradient(180deg, rgba(11,64,36,0.65) 0%, rgba(11,64,36,0.82) 40%, rgba(11,64,36,0.94) 100%); }
  }

  /* ========== 2. PROOF + TRUST ========== */
  .proof { background: var(--color-white); padding: clamp(var(--space-12), 8vw, var(--space-16)) 0; }
  .proof__inner {
    display: flex; flex-direction: column; align-items: center;
    gap: clamp(var(--space-6), 4vw, var(--space-8));
  }
  .proof__stats {
    display: flex; align-items: center; justify-content: center;
    gap: clamp(var(--space-6), 5vw, var(--space-12));
    flex-wrap: wrap;
  }
  .proof__stat { display: flex; flex-direction: column; align-items: center; gap: 6px; text-align: center; }
  .proof__num {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(2.4rem, 5vw, 3.8rem);
    color: var(--color-green-deep);
    line-height: 1;
    letter-spacing: -0.02em;
  }
  .proof__label {
    font-family: var(--font-sans);
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--color-gold-deep);
  }
  .proof__divider { width: 1px; height: 56px; background: var(--color-gold); opacity: 0.4; }
  @media (max-width: 700px) { .proof__divider { display: none; } }
  .proof__line {
    margin: 0;
    color: var(--color-ink-soft);
    font-size: 0.95rem;
    text-align: center;
  }
  .proof__line a {
    color: var(--color-green-deep);
    font-weight: 700;
    text-decoration: none;
    border-bottom: 1px solid var(--color-gold);
    padding-bottom: 2px;
  }
  .proof__badges {
    list-style: none; margin: var(--space-4) 0 0 0; padding: 0;
    display: flex; align-items: center; justify-content: center;
    gap: clamp(var(--space-16), 10vw, 120px);
    flex-wrap: wrap;
  }
  .proof__badges img {
    height: 112px; width: auto;
    opacity: 0.9;
    transition: opacity 200ms, transform 200ms;
  }
  .proof__badges a:hover img { opacity: 1; transform: translateY(-3px); }

  /* ========== 4. MISSIONARY STORY ========== */
  .missionary {
    background: var(--color-white);
    padding: clamp(var(--space-20), 11vw, var(--space-24)) 0;
  }
  .missionary__grid {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: clamp(var(--space-12), 8vw, var(--space-20));
    align-items: center;
  }
  @media (max-width: 900px) { .missionary__grid { grid-template-columns: 1fr; } }
  .missionary__photo {
    margin: 0;
    position: relative;
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 18px 48px rgba(11, 64, 36, 0.20);
    aspect-ratio: 4 / 5;
  }
  .missionary__photo img {
    width: 100%; height: 100%;
    object-fit: cover;
    display: block;
  }
  .missionary__caption {
    position: absolute; left: var(--space-5); bottom: var(--space-5);
    background: rgba(11, 64, 36, 0.85);
    color: var(--color-white);
    padding: 8px 14px;
    border-radius: 999px;
    font-family: var(--font-sans);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }
  .missionary__h2 {
    margin: 0 0 var(--space-5) 0;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(2rem, 4.4vw, 3.2rem);
    line-height: 1.08;
    color: var(--color-green-deep);
    letter-spacing: -0.018em;
  }
  .missionary__lede {
    margin: 0 0 var(--space-8) 0;
    color: var(--color-ink);
    font-size: 1.08rem;
    line-height: 1.7;
    max-width: 54ch;
  }
  .missionary__carole {
    margin: 0 0 var(--space-8) 0;
    padding: var(--space-4) 0 var(--space-4) var(--space-8);
    border-left: 3px solid var(--color-gold);
  }
  .missionary__carole-quote {
    margin: 0 0 var(--space-3) 0;
    font-family: var(--font-script);
    font-weight: 600;
    font-size: clamp(1.5rem, 3vw, 2.1rem);
    line-height: 1.2;
    color: var(--color-green-deep);
  }
  .missionary__carole-attr {
    display: flex; flex-direction: column; gap: 2px;
  }
  .missionary__carole-name {
    font-family: var(--font-sans);
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--color-gold-deep);
  }
  .missionary__carole-role {
    font-family: var(--font-sans);
    font-size: 0.82rem;
    color: var(--color-sage);
    font-style: italic;
  }
  .missionary__cta {
    border-radius: 999px;
    padding: 18px 32px;
    font-size: 1rem;
    box-shadow: 0 12px 28px rgba(11, 64, 36, 0.18);
  }
  .missionary__cta:hover { transform: translateY(-2px); box-shadow: 0 16px 36px rgba(11, 64, 36, 0.25); }
  .missionary__read {
    display: inline-block;
    margin-top: var(--space-4);
    margin-left: var(--space-5);
    color: var(--color-green-deep);
    text-decoration: none;
    font-weight: 700;
    font-size: 0.92rem;
    border-bottom: 1px solid var(--color-gold);
    padding-bottom: 2px;
  }
  .missionary__read:hover { color: var(--color-gold-deep); }

  /* ========== 5. GIVE ========== */
  .give {
    position: relative;
    background: var(--color-green-deep);
    color: var(--color-white);
    padding: clamp(var(--space-20), 12vw, var(--space-24)) 0;
    overflow: hidden;
    isolation: isolate;
  }
  .give__bg {
    position: absolute; inset: 0;
    width: 100%; height: 100%;
    object-fit: cover;
    object-position: 50% 50%;
    z-index: 0;
    display: block;
  }
  /* Green tint overlay so the video is visible but the dollar tiers and
     CTA still read clearly. Adjustable: bump opacity if buttons feel weak. */
  .give__scrim {
    position: absolute; inset: 0;
    z-index: 1;
    /* ~20% green over the video as Danny requested. Slightly heavier
       at the top/bottom edges so the section blends into the green
       divider above and the dark footer below. */
    background: linear-gradient(
      180deg,
      rgba(11, 64, 36, 0.45) 0%,
      rgba(11, 64, 36, 0.20) 35%,
      rgba(11, 64, 36, 0.20) 65%,
      rgba(11, 64, 36, 0.55) 100%
    );
    pointer-events: none;
  }
  .give__inner {
    position: relative;
    z-index: 2;
    display: flex; flex-direction: column;
    gap: clamp(var(--space-12), 6vw, var(--space-16));
  }
  .give__head { text-align: center; max-width: 700px; margin: 0 auto; padding-top: var(--space-8); }
  .give__h2 {
    margin: var(--space-3) 0 var(--space-3) 0;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(2rem, 4.4vw, 3.2rem);
    line-height: 1.08;
    color: var(--color-white);
    letter-spacing: -0.018em;
  }
  .give__lede {
    margin: 0;
    color: color-mix(in srgb, var(--color-white) 80%, transparent);
    font-size: 1rem;
    line-height: 1.6;
  }
  .give__tiers {
    list-style: none; padding: 0; margin: 0;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: clamp(var(--space-8), 3vw, var(--space-12));
  }
  @media (max-width: 900px) { .give__tiers { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 560px) { .give__tiers { grid-template-columns: 1fr; } }
  .give__tier {
    position: relative;
    display: flex; flex-direction: column; gap: var(--space-2);
    padding: var(--space-6);
    /* Dark translucent so the cards read as defined boxes against
       the savanna video, instead of barely-visible white overlays. */
    background: rgba(0, 0, 0, 0.32);
    border: 1px solid color-mix(in srgb, var(--color-gold) 25%, transparent);
    border-radius: 14px;
    transition: transform 200ms, border-color 200ms, background 200ms;
    backdrop-filter: blur(2px);
  }
  .give__tier:hover {
    transform: translateY(-3px);
    border-color: var(--color-gold);
    background: rgba(0, 0, 0, 0.50);
  }
  .give__tier--featured {
    background: rgba(0, 0, 0, 0.45);
    border-color: var(--color-gold);
    box-shadow: 0 16px 40px rgba(225, 167, 48, 0.25);
  }
  .give__tier-flag {
    position: absolute;
    top: -10px; right: var(--space-4);
    background: var(--color-gold);
    color: var(--color-green-deep);
    font-family: var(--font-sans);
    font-size: 0.68rem;
    font-weight: 800;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    padding: 4px 12px;
    border-radius: 999px;
  }
  .give__tier-amount {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(1.8rem, 3.4vw, 2.4rem);
    color: var(--color-white);
    line-height: 1;
  }
  .give__tier-label {
    font-family: var(--font-sans);
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--color-gold);
  }
  .give__tier-line {
    margin: 4px 0 0 0;
