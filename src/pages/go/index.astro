---
import PageLayout from '../../layouts/PageLayout.astro';
import PageHero from '../../components/band/PageHero.astro';
import CtaBand from '../../components/band/CtaBand.astro';

const paths = [
  { href: '/go/vision-trips/', label: 'Vision Trips', desc: 'Walk a village with a Favor field leader. 7–14 day trips, 2–4 times a year.', image: '/images/story-vision-trip-team.jpg' },
  { href: '/go/volunteer/', label: 'Volunteer in the US', desc: 'Ambassadors, prayer warriors, intercession teams. The field needs you wherever you are.', image: '/images/gift-bishoftu-tot.jpg' },
  { href: '/go/volunteer/', label: 'Internships', desc: 'Field and US-side internships for college students and recent grads.', image: '/images/education-vlc-jondoru.jpg' },
  { href: '/go/volunteer/#positions', label: 'Career Opportunities', desc: 'Open roles on the US team and on the field. Director, partner care, comms.', image: '/images/partner-with-us.jpg' },
  { href: '/give/church-partnership/', label: 'Church Partnerships', desc: 'Mobilize your church around an indigenous Favor field team.', image: '/images/evangelism-discipleship.jpg' },
];
---
<PageLayout
  title="Go"
  description="Walk the field. Volunteer from home. Lead a vision trip. Five paths to go with Favor International."
  image="/images/story-vision-trip-team.jpg"
>
  <PageHero
    label="Go"
    title="Travel with us. Or send someone in your place."
    promise="Five ways to go: vision trips, volunteering, internships, careers, and church partnerships."
    image="/images/story-vision-trip-team.jpg"
    imageAlt="PBS graduation in Karamoja, Uganda"
    ctaLabel="See vision trips"
    ctaHref="/go/vision-trips/"
    secondaryLabel="Serve from home"
    secondaryHref="/go/volunteer/"
  />

  <section class="band band--cream">
    <div class="container">
      <header class="band__header">
        <p class="label">Five paths</p>
        <h2>Pick how you go.</h2>
      </header>
      <div class="go-grid">
        {paths.map((p) => (
          <a class="go-tile" href={p.href}>
            <div class="go-tile__photo" style={`background-image: url(${p.image})`} role="img" aria-label={p.label}></div>
            <div class="go-tile__body">
              <h3>{p.label}</h3>
              <p>{p.desc}</p>
              <span class="go-tile__cta">See the details →</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <CtaBand
    heading="Not sure which fits?"
    body="Email us a one-line note about your time and your context. We will point you to the right path."
    ctaLabel="Email the Go team"
    ctaHref="/about/contact/?topic=go"
    variant="green"
  />
</PageLayout>

<style>
  .go-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--space-6); }
  @media (max-width: 1024px) { .go-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 640px) { .go-grid { grid-template-columns: 1fr; } }
  .go-tile { background: var(--color-white); border-radius: var(--radius-card); box-shadow: var(--shadow-soft); overflow: hidden; text-decoration: none; color: inherit; transition: transform 160ms, box-shadow 160ms; display: flex; flex-direction: column; }
  .go-tile:hover { transform: translateY(-3px); box-shadow: var(--shadow-card); }
  .go-tile__photo { aspect-ratio: 4 / 3; background-size: cover; background-position: center; background-color: var(--color-sage-light); }
  .go-tile__body { padding: var(--space-6); display: flex; flex-direction: column; gap: var(--space-2); flex: 1; }
  .go-tile h3 { margin: 0; color: var(--color-green); font-size: 1.15rem; }
  .go-tile p { margin: 0; font-size: 0.92rem; color: var(--color-ink-soft); }
  .go-tile__cta { margin-top: auto; padding-top: var(--space-2); font-weight: 700; color: var(--color-gold); font-size: 0.85rem; }
</style>
