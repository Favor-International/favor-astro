---
import PageLayout from '../../layouts/PageLayout.astro';
import PageHero from '../../components/band/PageHero.astro';
import CtaBand from '../../components/band/CtaBand.astro';
import { SITE } from '../../lib/site';
---
<PageLayout
  title="Stocks, Crypto, and Non-Cash Giving"
  description="Donate appreciated stock, cryptocurrency, real estate, or other non-cash assets to Favor International."
>
  <PageHero
    label="Non-cash giving"
    title="Stocks. Crypto. Real estate. Vehicles."
    promise="Non-cash gifts are often the most tax-efficient way to give. We will route them with care."
    image="/images/ministry-medical-clinic.jpg"
    imageAlt="Partners gathering"
    variant="split"
  />

  <section class="band band--white">
    <div class="container">
      <header class="nc-head">
        <p class="label">Asset types we accept</p>
        <h2>How to send each.</h2>
      </header>
      <div class="acard-grid">
        <article class="acard has-texture">
          <h3>Appreciated stock</h3>
          <p>Brokerage transfer or DAFpay route. Avoid capital gains; deduct full market value. We will send our DTC instructions on request.</p>
        </article>
        <article class="acard has-texture">
          <h3>Cryptocurrency</h3>
          <p>BTC, ETH, USDC, plus most major chains. Routed through TrustBridge Global. We will email the wallet address after a quick KYC.</p>
        </article>
        <article class="acard has-texture">
          <h3>Real estate, vehicles, equipment</h3>
          <p>Case-by-case. We work with a partner network to handle the transfer and convert to cash. Email the executive team first.</p>
        </article>
        <article class="acard has-texture">
          <h3>Matching gifts</h3>
          <p>Most large employers will match charitable gifts. Search your benefits portal for "Favor International" and EIN {SITE.ein}.</p>
        </article>
      </div>
    </div>
  </section>

  <CtaBand
    heading="Start the non-cash gift."
    body="Email the executive team. We will reply within one business day with the right routing form."
    ctaLabel="Start the gift"
    ctaHref={`mailto:${SITE.emailGeneral}?subject=Non-cash gift`}
    image="/images/hero-bibles-stacks.jpg"
    imageAlt="Bibles staged for distribution"
    variant="gold"
  />
</PageLayout>

<style>
  .nc-head { max-width: 720px; margin: 0 auto var(--space-10); text-align: center; }
  .acard-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: var(--space-6); }
  @media (max-width: 760px) { .acard-grid { grid-template-columns: 1fr; } }
  .acard { background: var(--color-white); border-radius: var(--radius-card); padding: var(--space-6); border: 2px solid var(--accent, var(--color-gold)); box-shadow: var(--shadow-soft); }
  .acard h3 { margin: 0 0 var(--space-2); color: var(--color-green); font-size: 1.1rem; }
  .acard p { margin: 0; color: var(--color-ink-soft); line-height: 1.6; }
  .acard:nth-child(4n+1) { --accent: var(--color-gold-deep); }
  .acard:nth-child(4n+2) { --accent: var(--color-green-bright); }
  .acard:nth-child(4n+3) { --accent: var(--color-terracotta); }
  .acard:nth-child(4n+4) { --accent: var(--color-sage); }
</style>
