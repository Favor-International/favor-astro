---
import PageLayout from '../../layouts/PageLayout.astro';
import PageHero from '../../components/band/PageHero.astro';
import CtaBand from '../../components/band/CtaBand.astro';
---
<PageLayout
  title="Church Partnership"
  description="Mobilize your church around an indigenous Favor field team. Tiered partnerships, vision trips, and ambassador resources."
>
  <PageHero
    label="For churches"
    title="Your church can be part of what God is doing in East Africa."
    promise="Three partnership tiers. Vision trips. Promo resources. A real relationship with a real field team."
    image="/images/ministry-gift-staff.jpg"
    imageAlt="Church partnership gathering"
    ctaLabel="Inquire about a partnership"
    ctaHref="/about/contact/?topic=church"
    variant="split"
  />

  <section class="band band--white">
    <div class="container">
      <header class="band__header">
        <p class="label">Three tiers</p>
        <h2>Pick the level that fits your church.</h2>
      </header>
      <div class="grid grid-3">
        <article class="church-tile">
          <h3>Ambassador church</h3>
          <p class="church-tile__amount">From $250/mo</p>
          <ul>
            <li>Monthly field-team prayer letter</li>
            <li>Quarterly video update for your missions team</li>
            <li>Annual vision-trip invite</li>
          </ul>
        </article>
        <article class="church-tile church-tile--featured">
          <span class="church-tile__badge">Most chosen</span>
          <h3>Sending church</h3>
          <p class="church-tile__amount">From $1,000/mo</p>
          <ul>
            <li>All ambassador benefits</li>
            <li>Direct sponsorship of one field worker</li>
            <li>Yearly vision-trip slot for two leaders</li>
            <li>Stage Sunday slot with a Favor field leader</li>
          </ul>
        </article>
        <article class="church-tile">
          <h3>Catalyst church</h3>
          <p class="church-tile__amount">From $3,000/mo</p>
          <ul>
            <li>All sending-church benefits</li>
            <li>Funded village partnership (school, VLC, or PBS site)</li>
            <li>Custom storytelling assets for your services</li>
            <li>Annual on-site visit from Favor leadership</li>
          </ul>
        </article>
      </div>
    </div>
  </section>

  <section class="band band--cream">
    <div class="container">
      <header class="band__header">
        <p class="label">What you are part of</p>
        <h2>Your church can be part of this.</h2>
      </header>
      <div class="field-gallery cp-gallery">
        <figure class="field-tile" style="background-image:url('/images/field/pbs-chad.webp')" role="img" aria-label="A Portable Bible School congregation in Chad">
          <figcaption>Portable Bible Schools train new disciple-makers, Chad</figcaption>
        </figure>
        <figure class="field-tile" style="background-image:url('/images/field/bibles-south-sudan.webp')" role="img" aria-label="A young woman receives a Bible in South Sudan">
          <figcaption>A Bible placed in new hands, South Sudan</figcaption>
        </figure>
        <figure class="field-tile" style="background-image:url('/images/field/street-outreach-south-sudan.webp')" role="img" aria-label="Street outreach to a family in a rural settlement">
          <figcaption>Street outreach, village by village</figcaption>
        </figure>
        <figure class="field-tile" style="background-image:url('/images/field/youth-south-sudan.webp')" role="img" aria-label="Young men reached through youth ministry in South Sudan">
          <figcaption>Reaching street youth with the Gospel</figcaption>
        </figure>
      </div>
    </div>
  </section>

  <CtaBand
    heading="Start a conversation."
    body="Tell us about your church and the missions vision your team has been carrying. We will recommend a tier and a field team."
    ctaLabel="Send the church team an email"
    ctaHref="/about/contact/?topic=church"
    image="/images/ministry-gift-staff.jpg"
    imageAlt="A Favor field team"
    variant="green"
  />
</PageLayout>

<style>
  .church-tile { position: relative; background: var(--color-white); border-radius: var(--radius-card); padding: var(--space-8); display: flex; flex-direction: column; gap: var(--space-3); border: 2px solid var(--color-gold-deep); box-shadow: var(--shadow-soft); transition: transform 180ms, box-shadow 180ms; }
  .church-tile:hover { transform: translateY(-4px); box-shadow: 0 20px 44px rgba(31, 58, 26, 0.16); }
  .church-tile--featured { background: var(--color-green); color: var(--color-white); border-color: var(--color-green-deep); border-top-color: var(--color-gold); }
  .church-tile__badge { position: absolute; top: 0; right: var(--space-6); transform: translateY(-50%); background: var(--color-gold); color: var(--color-ink); font-size: 0.7rem; font-weight: 800; letter-spacing: 0.1em; text-transform: uppercase; padding: 6px 14px; border-radius: var(--radius-pill); }
  .church-tile h3 { margin: 0; color: var(--color-green); font-size: 1.2rem; }
  .church-tile--featured h3 { color: var(--color-gold); }
  .church-tile__amount { font-weight: 800; font-size: 1.4rem; color: var(--color-gold-deep); margin: 0; }
  .church-tile--featured .church-tile__amount { color: var(--color-gold); }
  .church-tile ul { list-style: none; padding: 0; margin: var(--space-2) 0 0; display: grid; gap: var(--space-2); }
  .church-tile li { position: relative; padding: 4px 0 4px var(--space-6); font-size: 0.92rem; line-height: 1.45; }
  .church-tile li::before { content: '✓'; position: absolute; left: 0; top: 4px; color: var(--color-green-bright); font-weight: 800; }
  .church-tile--featured li::before { color: var(--color-gold); }
</style>
