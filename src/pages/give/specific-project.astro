---
import PageLayout from '../../layouts/PageLayout.astro';
import PageHero from '../../components/band/PageHero.astro';
import PostCard from '../../components/band/PostCard.astro';
import CtaBand from '../../components/band/CtaBand.astro';

const projects = [
  { slug: 'gulu-primary-school', category: 'Education', name: 'Primary school in Gulu, Uganda', goal: 80000, raised: 47200, image: '/images/ministry-church-planting.jpg', summary: 'A new primary school building serving 220 students. Two classrooms ready, four to go.' },
  { slug: 'gift-dormitory', category: 'Care', name: 'GIFT Institute dormitory', goal: 65000, raised: 51800, image: '/images/gift-bishoftu-tot.jpg', summary: 'Beds and study rooms for the next cohort of pastor-trainees. Doors open Q3.' },
  { slug: 'arabic-bible-curriculum', category: 'Evangelism', name: 'Arabic-translated Bible curriculum', goal: 18000, raised: 12400, image: '/images/hero-pbs-graduation.jpg', summary: 'Translating the PBS curriculum into Arabic for Sudan and Chad field teams.' },
  { slug: 'solar-radio', category: 'Community', name: 'Solar power for two radio stations', goal: 22000, raised: 9100, image: '/images/pillar-community.jpg', summary: 'Off-grid solar arrays for Favor FM radio sites. Keeps the Gospel on air through the dry season.' },
];

function pct(raised: number, goal: number) { return Math.min(100, Math.round((raised / goal) * 100)); }
---
<PageLayout
  title="Specific Project"
  description="Fund a specific Favor International project directly. School buildings, dormitories, Bible curriculum, off-grid power."
>
  <PageHero
    label="Specific project"
    title="Fund the exact thing the field needs."
    promise="Pick a project. Watch the progress bar. Receive direct field updates from the team you funded."
    image="/images/ministry-church-planting.jpg"
    imageAlt="Primary school in Gulu, Uganda under construction"
    variant="split"
  />

  <section class="band band--white">
    <div class="container">
      <header class="band__header">
        <p class="label">Active projects</p>
        <h2>What's open today.</h2>
      </header>
      <div class="proj-grid">
        {projects.map((p) => (
          <PostCard
            href={`/give/specific-project/${p.slug}/`}
            image={p.image}
            imageAlt={p.name}
            chip={p.category}
            title={p.name}
            desc={p.summary}
            progress={pct(p.raised, p.goal)}
            metaLabel="Reached"
            metaValue={`$${p.raised.toLocaleString()}`}
            actionLabel="Fund this project"
          />
        ))}
      </div>
    </div>
  </section>

  <CtaBand
    heading="Not seeing what you want to fund?"
    body="Email info@favorintl.org. We will route your gift to the field team most likely to use it well."
    ctaLabel="Email the team"
    ctaHref="mailto:info@favorintl.org"
    variant="sage"
  />
</PageLayout>

<style>
  .proj-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: var(--space-8); }
  @media (max-width: 800px) { .proj-grid { grid-template-columns: 1fr; } }
  .proj-card {
    display: flex; flex-direction: column;
    background: var(--color-white);
    border-radius: var(--radius-card);
    box-shadow: var(--shadow-soft);
    overflow: hidden;
    text-decoration: none; color: inherit;
    transition: transform 180ms, box-shadow 180ms;
  }
  .proj-card:hover { transform: translateY(-3px); box-shadow: var(--shadow-card); }
  .proj-card__photo { position: relative; aspect-ratio: 16 / 9; background-size: cover; background-position: center; background-color: var(--color-sage-light); }
  .proj-card__chip {
    position: absolute; top: var(--space-3); left: var(--space-3);
    background: color-mix(in srgb, var(--color-white) 92%, transparent);
    color: var(--color-green-deep);
    padding: 6px 14px; border-radius: var(--radius-pill);
    font-size: 0.7rem; font-weight: 800; letter-spacing: 0.14em; text-transform: uppercase;
    backdrop-filter: blur(2px);
  }
  .proj-card__body { padding: var(--space-6); display: flex; flex-direction: column; gap: var(--space-3); flex: 1; }
  .proj-card h3 { margin: 0; font-size: 1.4rem; color: var(--color-green); line-height: 1.2; }
  .proj-card p { margin: 0; font-size: 0.95rem; color: var(--color-ink-soft); }
  .proj-card__progress { height: 8px; background: var(--color-sage-light); border-radius: 999px; overflow: hidden; }
  .proj-card__bar { height: 100%; width: var(--pct); background: var(--color-gold); border-radius: 999px; }
  .proj-card__foot { margin-top: auto; padding-top: var(--space-2); display: flex; justify-content: space-between; align-items: center; gap: var(--space-4); }
  .proj-card__meta { display: flex; flex-direction: column; line-height: 1.2; }
  .proj-card__meta-label { font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.12em; color: var(--color-sage); font-weight: 700; }
  .proj-card__meta strong { color: var(--color-green); font-size: 1.25rem; }
  .proj-card__goal { font-size: 0.78rem; color: var(--color-sage); }
  .proj-card__btn {
    background: var(--color-green); color: var(--color-white);
    padding: 11px 20px; border-radius: var(--radius-pill);
    font-weight: 700; font-size: 0.85rem; white-space: nowrap;
    transition: background 140ms;
  }
  .proj-card:hover .proj-card__btn { background: var(--color-green-deep); }
</style>
