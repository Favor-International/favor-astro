---
import PageLayout from '../../layouts/PageLayout.astro';
import PageHero from '../../components/band/PageHero.astro';
import OverlayCard from '../../components/global/OverlayCard.astro';
import { PARTNER_TIERS, SITE } from '../../lib/site';

const tiles = [
  { slug: 'partner-monthly', label: 'Become a Favor Partner', desc: 'Monthly partnership. The lead path. Pick a tier.', featured: true, image: '/images/highlight-crowd.jpg' },
  { slug: 'one-time', label: 'Give Once', desc: 'Any amount, any time. Direct to Blackbaud.', image: '/images/hero-bibles-stacks.jpg' },
  { slug: 'specific-project', label: 'Specific Project', desc: 'Choose a current project to fund directly.', image: '/images/school-construction.jpg' },
  { slug: 'foundation', label: 'Foundation Giving', desc: 'Grants and DAFs. We will send the package.', image: '/images/hero-foundation-cohort.jpg' },
  { slug: 'church-partnership', label: 'Church Partnership', desc: 'Mobilize your church around an indigenous team.', image: '/images/ministry-gift-staff.jpg' },
  { slug: 'international', label: 'International Giving', desc: 'UK, Canada, EU. Tax-receipt routes available.', image: '/images/hero-pbs-students.jpg' },
  { slug: 'legacy', label: 'Legacy Giving', desc: 'Wills, estates, charitable trusts.', image: '/images/hero-legacy-history.jpg' },
  { slug: 'non-cash', label: 'Stocks, Crypto, Non-Cash', desc: 'DAFpay, TrustBridge, equities.', image: '/images/pillar-economic.jpg' },
];

const otherWays = ['Stocks', 'Crypto', 'Non-Cash', 'Matching Gifts'];
---
<PageLayout
  title="Give"
  description="Every giving pathway powered by Blackbaud. ECFA-accredited. Tax-deductible. Choose how you stand with Favor International: monthly partnership, one-time, foundation, DAF, or international."
  image="/images/partner-with-us.jpg"
>
  <PageHero
    label="Give"
    title="One gift. Real, recurring impact."
    promise="Every giving pathway powered by Blackbaud. ECFA-accredited. Tax-deductible. Pick your path."
    image="/images/partner-with-us.jpg"
    imageAlt="A Favor Partner gathering"
    ctaLabel="Become a Favor Partner"
    ctaHref="/give/partner-monthly/"
    secondaryLabel="Give a one-time gift"
    secondaryHref="/give/one-time/"
  />

  <section class="band band--cream">
    <div class="container">
      <header class="band__header">
        <p class="label">Pick your path</p>
        <h2>Eight ways to stand with Favor.</h2>
      </header>
      <div class="give-grid">
        {tiles.map((t) => (
          t.featured ? (
            <div class="give-grid__feature">
              <OverlayCard href={`/give/${t.slug}/`} image={t.image} kicker="Recommended" title={t.label} desc={t.desc} cta="Start your partnership" ratio="21 / 9" />
            </div>
          ) : (
            <OverlayCard href={`/give/${t.slug}/`} image={t.image} title={t.label} desc={t.desc} cta="Learn the details" ratio="4 / 3" />
          )
        ))}
      </div>
    </div>
  </section>

  <section class="band band--white">
    <div class="container container--narrow">
      <p class="label">Why give through Favor</p>
      <h2>Your gift goes further here.</h2>
      <div class="why-grid">
        <div class="why-card"><h3>Indigenous-led</h3><p>Every program on the field is run by African nationals who live where they serve.</p></div>
        <div class="why-card"><h3>Prayer-birthed</h3><p>Favor began as a prayer movement, and prayer still comes before everything else.</p></div>
        <div class="why-card"><h3>Accountable</h3><p>ECFA-accredited and independently audited every year. 89 cents of every dollar went to program in FY2024.</p></div>
        <div class="why-card"><h3>Where others will not go</h3><p>Favor's teams reach the hardest, most unreached places across East and Central Africa.</p></div>
      </div>
    </div>
  </section>

  <section class="band band--cream">
    <div class="container container--narrow">
      <p class="label">Featured tiers</p>
      <h2>Favor Partner monthly amounts.</h2>
      <p>Custom amounts welcome. These are the suggested tiers from the v2.1 partnership model.</p>
      <ul class="tier-list">
        {PARTNER_TIERS.map((t) => (
          <li class:list={[t.featured && 'tier-list--featured']}>
            <span class="tier-list__amount">${t.amount}<span class="tier-list__period">/mo</span></span>
            <span class="tier-list__label">{t.label}</span>
          </li>
        ))}
      </ul>
      <p class="band__cta-row">
        <a class="btn btn--primary btn--large" href="/give/partner-monthly/">Become a Favor Partner</a>
      </p>
    </div>
  </section>

  <section class="band band--sage">
    <div class="container container--narrow">
      <p class="label">Other ways to give</p>
      <h2>Stocks, crypto, non-cash, employer match.</h2>
      <p>If a non-cash gift fits your situation better, we have a route. Email <a href={`mailto:${SITE.emailGeneral}`}>{SITE.emailGeneral}</a> and we will send the right form.</p>
      <ul class="other-ways">
        {otherWays.map((w) => <li>{w}</li>)}
      </ul>
      <p class="band__cta-row">
        <a class="btn btn--secondary" href="/give/non-cash/">Non-cash giving details</a>
      </p>
    </div>
  </section>

  <section class="band band--white">
    <div class="container container--narrow">
      <p class="label">Questions</p>
      <h2>Common questions about giving.</h2>
      <div class="faq">
        <details><summary>Is my gift tax-deductible?</summary><p>Yes. Favor International is a registered 501(c)(3) public charity (EIN {SITE.ein}). You receive a tax-deductible receipt by email.</p></details>
        <details><summary>How much of my gift reaches the field?</summary><p>In FY2024, 89 cents of every dollar went to program work. The figures are audited and filed with ECFA and on IRS Form 990. See the <a href="/about/accountability/">accountability page</a>.</p></details>
        <details><summary>Can I give monthly?</summary><p>Yes. <a href="/give/partner-monthly/">Become a Favor Partner</a> and choose a tier or a custom amount.</p></details>
        <details><summary>What are all the ways I can give?</summary><p>Online card and ACH, monthly partnership, check, Zelle (admin@favorintl.org), CashApp ($FavorIntl), appreciated stock, donor-advised funds, and international routes. See <a href="/give/non-cash/">non-cash giving</a>.</p></details>
        <details><summary>Can I give to a specific project?</summary><p>Yes. Choose a current project on the <a href="/give/specific-project/">specific projects</a> page and your gift is directed there.</p></details>
      </div>
    </div>
  </section>

  <section class="band band--green-deep">
    <div class="container container--narrow trust-band">
      <p class="trust-band__line">All giving pathways powered by Blackbaud · ECFA-accredited · Tax-deductible</p>
      <div class="trust-band__links">
        <a href={SITE.trust.ecfa} target="_blank" rel="noopener">ECFA profile →</a>
        <a href="/about/accountability/">990s and financials →</a>
        <a href={SITE.trust.charityNavigator} target="_blank" rel="noopener">Charity Navigator →</a>
      </div>
    </div>
  </section>
</PageLayout>

<style>
  .give-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-6);
  }
  @media (max-width: 1100px) { .give-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 540px) { .give-grid { grid-template-columns: 1fr; } }
  .give-grid__feature { grid-column: span 2; }
  @media (max-width: 540px) { .give-grid__feature { grid-column: span 1; } }

  .tier-list { list-style: none; padding: 0; margin: var(--space-8) 0 0; display: grid; gap: var(--space-3); }
  .tier-list li {
    display: grid;
    grid-template-columns: 140px 1fr;
    gap: var(--space-6);
    align-items: center;
    padding: var(--space-4) var(--space-6);
    background: var(--color-cream);
    border-radius: var(--radius-input);
    border: 2px solid var(--color-gold);
  }
  .tier-list--featured { background: var(--color-green) !important; color: var(--color-white); }
  .tier-list--featured .tier-list__amount { color: var(--color-gold); }
  .tier-list--featured .tier-list__label, .tier-list--featured .tier-list__tagline { color: var(--color-white); }
  .tier-list__amount { font-weight: 800; font-size: 1.4rem; color: var(--color-green); }
  .tier-list__period { font-size: 0.85rem; color: var(--color-sage); font-weight: 600; }
  .tier-list__label { font-weight: 700; letter-spacing: 0.04em; color: var(--color-green-deep); text-transform: uppercase; font-size: 0.85rem; }
  .tier-list__tagline { color: var(--color-ink-soft); font-size: 0.92rem; }
  @media (max-width: 720px) {
    .tier-list li { grid-template-columns: 1fr; gap: var(--space-1); }
  }

  .other-ways { display: flex; gap: var(--space-3); flex-wrap: wrap; padding: 0; margin: var(--space-6) 0; list-style: none; }
  .other-ways li {
    padding: var(--space-3) var(--space-6);
    background: var(--color-white);
    border-radius: var(--radius-pill);
    font-weight: 600;
    font-size: 0.9rem;
    color: var(--color-green);
  }

  .trust-band { text-align: center; color: var(--color-white); }
  .trust-band__line { font-size: 1.05rem; margin: 0 0 var(--space-4); }
  .trust-band__links { display: flex; gap: var(--space-6); justify-content: center; flex-wrap: wrap; }
  .trust-band__links a { color: var(--color-gold); font-weight: 700; font-size: 0.9rem; text-decoration: none; }
  .trust-band__links a:hover { text-decoration: underline; }
</style>
