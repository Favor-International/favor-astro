---
import PageLayout from '../../layouts/PageLayout.astro';
import PageHero from '../../components/band/PageHero.astro';
import CtaBand from '../../components/band/CtaBand.astro';
import { SITE } from '../../lib/site';
---
<PageLayout
  title="Foundation Giving"
  description="Foundation, donor-advised fund, and grant-maker inquiries. Due-diligence-ready financials and program reports."
>
  <PageHero
    label="For foundations and DAFs"
    title="Due-diligence-ready. Field-result-ready."
    promise="ECFA accreditation, audited financials, and program-restricted reporting. We will send the package the next business day."
    image="/images/hero-foundation-cohort.jpg"
    imageAlt="PBS graduation in South Sudan"
    ctaLabel="Request the foundation packet"
    ctaHref="/about/contact/?topic=foundation"
    variant="split"
  />

  <section class="band band--white">
    <div class="container">
      <header class="fnd-head">
        <p class="label">What you can expect</p>
        <h2>Due diligence on day one.</h2>
      </header>
      <div class="acard-grid">
        <article class="acard has-texture"><h3>Audited financials</h3><p>FY2022, FY2023, FY2024. FY2025 audit available in Q3.</p></article>
        <article class="acard has-texture"><h3>IRS Form 990</h3><p>Most recent three years. Public on Candid.</p></article>
        <article class="acard has-texture"><h3>Program restriction options</h3><p>All four pillars and individual projects accept restricted gifts with quarterly reporting.</p></article>
        <article class="acard has-texture"><h3>ECFA accreditation</h3><p>Current and continuous.</p></article>
        <article class="acard has-texture"><h3>DAFpay and TrustBridge</h3><p>Both are wired up for DAF and donor-advised fund routing.</p></article>
        <article class="acard has-texture"><h3>Site visits</h3><p>Field site visits available for grant officers. Two-week scheduling lead time.</p></article>
      </div>
    </div>
  </section>

  <section class="band band--cream">
    <div class="container container--narrow">
      <p class="label">Contact</p>
      <h2>Talk to a real human.</h2>
      <p>Foundation officers, family-office staff, DAF advisors. Email the executive team directly. We will respond within one business day with the packet you need.</p>
      <p><strong>{SITE.emailGeneral}</strong> · {SITE.phone}</p>
      <p>EIN {SITE.ein} · 501(c)(3) public charity · ECFA member ID 50004.</p>
    </div>
  </section>

  <CtaBand
    heading="Already routing a DAF gift?"
    body="DAFpay and TrustBridge are wired up. Use them or send a direct check; we will receipt within 48 hours."
    ctaLabel="Email for routing instructions"
    ctaHref={`mailto:${SITE.emailGeneral}?subject=DAF gift routing`}
    image="/images/hero-foundation-cohort.jpg"
    imageAlt="A PBS graduation cohort in South Sudan"
    variant="sage"
  />
</PageLayout>

<style>
  .fnd-head { max-width: 720px; margin: 0 auto var(--space-10); text-align: center; }
  .acard-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--space-6); }
  @media (max-width: 860px) { .acard-grid { grid-template-columns: 1fr; } }
  .acard { background: var(--color-white); border-radius: var(--radius-card); padding: var(--space-6); border-top: 5px solid var(--accent, var(--color-gold)); box-shadow: var(--shadow-soft); }
  .acard h3 { margin: 0 0 var(--space-2); color: var(--color-green); font-size: 1.1rem; }
  .acard p { margin: 0; color: var(--color-ink-soft); line-height: 1.6; }
  .acard:nth-child(4n+1) { --accent: var(--color-gold-deep); }
  .acard:nth-child(4n+2) { --accent: var(--color-green-bright); }
  .acard:nth-child(4n+3) { --accent: var(--color-terracotta); }
  .acard:nth-child(4n+4) { --accent: var(--color-sage); }
</style>
