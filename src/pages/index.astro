---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteHeader from '../components/global/SiteHeader.astro';
import SiteFooter from '../components/global/SiteFooter.astro';
import { PILLARS, PARTNER_TIERS, SITE } from '../lib/site';
import { CTA } from '../lib/cta';

const pillarImages: Record<string, string> = {
  'evangelism-discipleship': '/images/hero-pbs-graduation.jpg',
  'education': '/images/pillar-education.jpg',
  'community-development': '/images/pillar-community-care.jpg',
  'economic-empowerment': '/images/hero-women-celebrating.jpg',
};

// Real published stories from the Webflow CMS (Stories.csv).
// One lead story carries the editorial weight; two stacked supporting stories
// give a 1+2 magazine layout.
const leadStory = {
  title: '"More Bibles for Ethiopia, please!"',
  country: 'Ethiopia',
  excerpt: 'After two months of Portable Bible Schools in Ethiopia, field teachers graduated 763 students, led 112 to salvation, and baptized 57. Then they ran out of Bibles.',
  image: '/images/stories/more-bibles-for-ethiopia-please.jpg',
  href: '/stories/more-bibles-for-ethiopia-please/',
};
const supportingStories = [
  {
    title: 'Daniel Kidia',
    country: 'South Sudan',
    excerpt: 'A former Mundari cattle warrior, now a Favor field pastor leading PBS classes among his own people.',
    image: '/images/stories/daniel-kidia.jpg',
    href: '/stories/daniel-kidia/',
  },
  {
    title: 'Goats for Women',
    country: 'Uganda',
    excerpt: 'Women of Puranga praised and worshipped God as they waited to receive two goats each, the fruit of a year of training.',
    image: '/images/stories/goats-for-women.jpg',
    href: '/stories/goats-for-women/',
  },
];
---
<BaseLayout
  title={`${SITE.name} — ${SITE.tagline}`}
  description="Favor International equips indigenous African leaders to advance the Gospel through Portable Bible Schools, the GIFT Institute, education, medical care, church planting, and economic empowerment. ECFA-accredited. Carole Ward, Founder."
  image="/images/pillar-evangelism-discipleship.jpg"
>
  <SiteHeader variant="transparent" />
  <main id="main">

    <!-- BAND 1: Hero (locked) -->
    <section class="hero hero--fullbleed" aria-label="Send a pastor where the gospel has not reached">
      <div class="hero__bg" style="background-image: url(/images/hero-pastor-preaching.jpg)" aria-hidden="true"></div>
      <div class="hero__scrim" aria-hidden="true"></div>
      <div class="hero__inner container">
        <div class="hero__copy">
          <p class="hero__eyebrow">Where others will not go</p>
          <h1 class="hero__h1">Send a pastor where the gospel has not reached.</h1>
          <p class="hero__sub">Indigenous missionaries equipped and sent into 14 nations across East and Central Africa.</p>
          <div class="hero__cta">
            <a class="btn btn--primary btn--large hero__primary" href="/give/partner-monthly/">{CTA.partnerMonthly} <span aria-hidden="true">&rarr;</span></a>
          </div>
          <ul class="hero__trust">
            <li class="hero__trust-item hero__trust-item--badge">
              <span class="hero__trust-ecfa">ECFA</span>
            </li>
            <li class="hero__trust-divider" aria-hidden="true"></li>
            <li class="hero__trust-item">501(c)(3)</li>
            <li class="hero__trust-divider" aria-hidden="true"></li>
            <li class="hero__trust-item">On the field since 2002</li>
          </ul>
        </div>
      </div>
    </section>

    <!-- BAND 2: Signature phrase ("Where others will not go") -->
    <section class="signature">
      <div class="container signature__grid">
        <div class="signature__copy">
          <span class="signature__rule" aria-hidden="true"></span>
          <p class="signature__eyebrow">The Favor signature</p>
          <h2 class="signature__phrase">Where others will not go.</h2>
          <p class="signature__body">
            The hardest places on earth still belong to Jesus. Favor sends indigenous
            pastors and teachers into villages, refugee camps, and tribal lands no
            outside agency will enter. <strong>You make that possible.</strong>
          </p>
          <p class="signature__scripture">
            &ldquo;{SITE.scripture.text}&rdquo;
            <span class="signature__cite">John 9:4 &middot; AMPC</span>
          </p>
        </div>
        <div class="signature__photo" style="background-image: url(/images/pillar-evangelism-discipleship.jpg)" role="img" aria-label="Two indigenous pastors walking through floodwaters to reach a remote village"></div>
      </div>
    </section>

    <!-- BAND 3: Four ministry pillars (light sage, editorial photo cards) -->
    <section class="pillars">
      <div class="container">
        <header class="band-head">
          <p class="band-head__eyebrow">Where your partnership goes</p>
          <h2 class="band-head__h2">Four fronts. One Gospel.</h2>
          <span class="gold-rule" aria-hidden="true"></span>
          <p class="band-head__lede">You fund four kinds of work at once. A pastor on the trail. A child at her desk. A widow with a goat. A clinic with antibiotics on the shelf.</p>
        </header>
        <div class="pillars__grid">
          {PILLARS.map((p, i) => (
            <a class="pillar" href={`/impact/${p.slug}/`}>
              <div class="pillar__photo" style={`background-image: url(${pillarImages[p.slug]})`} role="img" aria-label={p.label}></div>
              <div class="pillar__body">
                <span class="pillar__num">0{i + 1}</span>
                <h3 class="pillar__title">{p.label}</h3>
                <p class="pillar__blurb">{p.blurb}</p>
                <span class="pillar__cta">Explore this pillar <span aria-hidden="true">&rarr;</span></span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- BAND 4: Stories (white, asymmetric 1 lead + 2 stacked) -->
    <section class="stories">
      <div class="container">
        <header class="band-head band-head--row">
          <div>
            <p class="band-head__eyebrow">Stories from the field</p>
            <h2 class="band-head__h2">Real names. Real places.</h2>
            <p class="band-head__lede band-head__lede--left">You can read the names of the pastors, women, and children your partnership is sending us to.</p>
          </div>
          <a class="band-head__all" href="/stories/">Every story <span aria-hidden="true">&rarr;</span></a>
        </header>
        <div class="stories__grid">
          <a class="story story--lead" href={leadStory.href}>
            <div class="story__photo" style={`background-image: url(${leadStory.image})`} role="img" aria-label={leadStory.title}></div>
            <div class="story__body">
              <span class="story__country">{leadStory.country}</span>
              <h3 class="story__title story__title--lead">{leadStory.title}</h3>
              <p class="story__excerpt">{leadStory.excerpt}</p>
              <span class="story__cta">Read the full story <span aria-hidden="true">&rarr;</span></span>
            </div>
          </a>
          <div class="stories__sidecol">
            {supportingStories.map((s) => (
              <a class="story story--side" href={s.href}>
                <div class="story__photo story__photo--side" style={`background-image: url(${s.image})`} role="img" aria-label={s.title}></div>
                <div class="story__body story__body--side">
                  <span class="story__country">{s.country}</span>
                  <h3 class="story__title">{s.title}</h3>
                  <p class="story__excerpt story__excerpt--side">{s.excerpt}</p>
                  <span class="story__cta">Read <span aria-hidden="true">&rarr;</span></span>
                </div>
              </a>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- BAND 5: Impact numbers (deep green, big gold numbers, field-photo backdrop) -->
    <section class="impact" aria-label="Audited impact numbers">
      <div class="impact__bg" style="background-image: url(/images/hero-congo-grads.jpg)" aria-hidden="true"></div>
      <div class="impact__scrim" aria-hidden="true"></div>
      <div class="container impact__inner">
        <header class="impact__head">
          <p class="band-head__eyebrow impact__eyebrow">The receipts</p>
          <h2 class="impact__h2">Audit-grade numbers, every year.</h2>
        </header>
        <ul class="impact__grid">
          <li class="impact-stat">
            <span class="impact-stat__value">89<span class="impact-stat__unit">%</span></span>
            <span class="impact-stat__label">To the field</span>
            <span class="impact-stat__note">FY2024 program-expense ratio, ECFA-audited</span>
          </li>
          <li class="impact-stat">
            <span class="impact-stat__value">14</span>
            <span class="impact-stat__label">Nations reached</span>
            <span class="impact-stat__note">East and Central Africa</span>
          </li>
          <li class="impact-stat">
            <span class="impact-stat__value">$8.36<span class="impact-stat__unit">M</span></span>
            <span class="impact-stat__label">FY2024 revenue</span>
            <span class="impact-stat__note">Filed Form 990</span>
          </li>
        </ul>
        <p class="impact__sources">
          Verified by
          <a href={SITE.trust.ecfa} target="_blank" rel="noopener">ECFA</a>,
          <a href={SITE.trust.charityNavigator} target="_blank" rel="noopener">Charity Navigator</a>, and
          <a href={SITE.trust.candid} target="_blank" rel="noopener">Candid</a>.
        </p>
      </div>
    </section>

    <!-- BAND 6: Partner. Full-bleed gold band, field-leader photo, white tier cards -->
    <section class="partner" id="partner" aria-label="Become a Favor Partner">
      <div class="partner__photo" style="background-image: url(/images/hero-pastor-preaching.jpg)" aria-hidden="true"></div>
      <div class="partner__scrim" aria-hidden="true"></div>
      <div class="container partner__inner">
        <div class="partner__copy">
          <p class="partner__eyebrow">Become a Favor Partner</p>
          <h2 class="partner__h2">Monthly partnership is the most-chosen way to send.</h2>
          <p class="partner__body">
            You can keep an indigenous pastor on the trail in a place no other
            ministry will go. Pick a tier, or set your own amount. Every gift is
            tax-deductible. ECFA-accredited since 2019.
          </p>
          <a class="btn partner__cta" href="/give/partner-monthly/">{CTA.partnerMonthly} <span aria-hidden="true">&rarr;</span></a>
          <p class="partner__altgive">
            <a href="/give/">See all ways to give <span aria-hidden="true">&rarr;</span></a>
          </p>
        </div>
        <div class="partner__tiers">
          <p class="partner__tiers-label">Monthly partner tiers</p>
          <div class="partner__tiers-grid">
            {PARTNER_TIERS.map((t) => (
              <a class:list={['tier', t.featured && 'tier--featured']} href={`/give/partner-monthly/?amount=${t.amount}`}>
                {t.featured && <span class="tier__badge">Lead tier</span>}
                <span class="tier__amount">${t.amount.toLocaleString()}<span class="tier__period">/mo</span></span>
                <span class="tier__label">{t.label}</span>
              </a>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- BAND 7: Pray + Go (split-band) -->
    <section class="praygo">
      <a class="praygo__panel praygo__panel--pray" href="/pray/30-day-guide/">
        <div class="praygo__photo" style="background-image: url(/images/hero-prayer-team.jpg)" aria-hidden="true"></div>
        <div class="praygo__scrim praygo__scrim--green" aria-hidden="true"></div>
        <div class="praygo__body">
          <p class="praygo__eyebrow">Pray with us</p>
          <h3 class="praygo__h3">You can pray where they cannot reach.</h3>
          <p class="praygo__lede">One specific request a day, across 14 nations Favor serves. Free PDF, no signup.</p>
          <span class="praygo__cta">Get the 30-Day Prayer Guide <span aria-hidden="true">&rarr;</span></span>
        </div>
      </a>
      <a class="praygo__panel praygo__panel--go" href="/go/vision-trips/">
        <div class="praygo__photo praygo__photo--light" style="background-image: url(/images/pbs-karamoja.jpg)" aria-hidden="true"></div>
        <div class="praygo__scrim praygo__scrim--cream" aria-hidden="true"></div>
        <div class="praygo__body">
          <p class="praygo__eyebrow praygo__eyebrow--dark">Walk with us</p>
          <h3 class="praygo__h3 praygo__h3--dark">See it for yourself.</h3>
          <p class="praygo__lede praygo__lede--dark">Small-team vision trips to Uganda, South Sudan, and Ethiopia. Spring and Fall 2026.</p>
          <ul class="praygo__trips" aria-label="Upcoming vision trips">
            <li><span class="praygo__trip-date">Mar 2026</span> Uganda &middot; Karamoja</li>
            <li><span class="praygo__trip-date">Oct 2026</span> South Sudan &middot; Bor</li>
            <li><span class="praygo__trip-date">Nov 2026</span> Ethiopia &middot; Bishoftu</li>
          </ul>
          <span class="praygo__cta praygo__cta--dark">See open vision trips <span aria-hidden="true">&rarr;</span></span>
        </div>
      </a>
    </section>

    <!-- BAND 8: Newsletter (sage-light, single-field) -->
    <section class="newsletter">
      <div class="container container--narrow newsletter__inner">
        <p class="band-head__eyebrow newsletter__eyebrow">Field report</p>
        <h2 class="newsletter__h2">One short email. Every other week.</h2>
        <p class="newsletter__body">Real names, real numbers, real prayer requests from the field. Unsubscribe in one click.</p>
        <form class="newsletter__form" action="/newsletter/" method="get">
          <label class="visually-hidden" for="newsletter-email">Email address</label>
          <input class="newsletter__input" id="newsletter-email" type="email" name="email" required placeholder="you@example.com" autocomplete="email" />
          <button class="btn btn--primary newsletter__submit" type="submit">Subscribe <span aria-hidden="true">&rarr;</span></button>
        </form>
        <p class="newsletter__privacy">We never sell or share your email. Read our <a href="/about/accountability/">accountability practice</a>.</p>
      </div>
    </section>

    <!-- BAND 9: Trust strip (compact, horizontal, near footer) -->
    <section class="trust">
      <div class="container trust__inner">
        <p class="trust__lede">You can verify every dollar.</p>
        <ul class="trust__row">
          <li class="trust__item">
            <a href={SITE.trust.ecfa} target="_blank" rel="noopener" class="trust__link">
              <span class="trust__badge" aria-hidden="true">
                <svg viewBox="0 0 64 64" width="56" height="56" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M32 4 8 14v18c0 13 11 25 24 28 13-3 24-15 24-28V14L32 4z"/><path d="M22 33l7 7 13-15"/></svg>
                <span class="trust__badge-text">ECFA</span>
              </span>
              <span class="trust__label">ECFA-accredited <em>since 2019</em></span>
            </a>
          </li>
          <li class="trust__item">
            <a href={SITE.trust.charityNavigator} target="_blank" rel="noopener" class="trust__link">
              <span class="trust__badge" aria-hidden="true">
                <svg viewBox="0 0 64 64" width="56" height="56" fill="currentColor"><path d="M32 6l7.4 14.9L56 23.3l-12 11.7 2.8 16.6L32 43.8l-14.8 7.8L20 35 8 23.3l16.6-2.4L32 6z"/></svg>
                <span class="trust__badge-text">4★</span>
              </span>
              <span class="trust__label">Charity Navigator <em>Four-Star rating</em></span>
            </a>
          </li>
          <li class="trust__item">
            <a href={SITE.trust.candid} target="_blank" rel="noopener" class="trust__link">
              <span class="trust__badge" aria-hidden="true">
                <svg viewBox="0 0 64 64" width="56" height="56" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="32" cy="32" r="26"/><path d="M44 24c-2-4-6-6-12-6-6 0-12 4-12 14s6 14 12 14c6 0 10-2 12-6"/></svg>
                <span class="trust__badge-text">Platinum</span>
              </span>
              <span class="trust__label">Candid Platinum <em>transparency seal</em></span>
            </a>
          </li>
        </ul>
        <p class="trust__ein">EIN {SITE.ein} · FY2024 Form 990 on file · Tax-deductible · 501(c)(3)</p>
      </div>
    </section>

  </main>
  <SiteFooter />
</BaseLayout>

<style>
  /* ===== SHARED PRIMITIVES ===== */
  .band-head {
    text-align: center;
    max-width: 720px;
    margin: 0 auto var(--space-12) auto;
  }
  .band-head--row {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    text-align: left;
    max-width: none;
    gap: var(--space-8);
    flex-wrap: wrap;
  }
  .band-head__eyebrow {
    margin: 0 0 var(--space-3) 0;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-sage);
  }
  .band-head__h2 {
    margin: 0;
    font-size: clamp(2.2rem, 4vw, 3.2rem);
    color: var(--color-green-deep);
    line-height: 1.05;
    font-weight: 800;
    letter-spacing: -0.018em;
  }
  .band-head__lede {
    margin: var(--space-5) auto 0 auto;
    color: var(--color-ink-soft);
    font-size: 1.08rem;
    line-height: 1.6;
    max-width: 56ch;
  }
  .band-head__lede--left { margin-left: 0; }
  .band-head__all {
    color: var(--color-green-deep);
    text-decoration: none;
    font-weight: 700;
    font-size: 0.95rem;
    letter-spacing: 0.02em;
    border-bottom: 2px solid var(--color-gold);
    padding-bottom: 3px;
    white-space: nowrap;
  }
  .band-head__all:hover { color: var(--color-gold); }
  .gold-rule {
    display: block;
    width: 64px;
    height: 3px;
    background: var(--color-gold);
    margin: var(--space-5) auto var(--space-4) auto;
    border-radius: 2px;
  }
  .visually-hidden {
    position: absolute; width: 1px; height: 1px;
    padding: 0; margin: -1px; overflow: hidden;
    clip: rect(0, 0, 0, 0); white-space: nowrap; border: 0;
  }

  /* ===== HERO (unchanged from v9.1) ===== */
  .hero--fullbleed {
    position: relative;
    min-height: clamp(680px, 96vh, 920px);
    display: flex; align-items: center;
    color: var(--color-white);
    overflow: hidden;
    padding-top: 0; padding-bottom: 0;
  }
  .hero__bg {
    position: absolute; inset: 0;
    background-size: cover;
    background-position: 70% 65%;
    z-index: 0;
  }
  .hero__scrim {
    position: absolute; inset: 0; z-index: 1;
    background: linear-gradient(90deg,
      rgba(11, 64, 36, 0.96) 0%,
      rgba(11, 64, 36, 0.92) 28%,
      rgba(11, 64, 36, 0.55) 52%,
      rgba(11, 64, 36, 0.10) 72%,
      rgba(11, 64, 36, 0) 100%);
  }
  .hero__inner {
    position: relative; z-index: 2; width: 100%;
    padding-top: 120px; padding-bottom: var(--space-12);
  }
  .hero__copy { max-width: 720px; }
  .hero__eyebrow {
    margin: 0 0 var(--space-5) 0;
    font-size: 0.85rem;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    font-weight: 700;
    color: var(--color-gold);
  }
  .hero__h1 {
    margin: 0 0 var(--space-6) 0;
    font-size: clamp(2.5rem, 5.6vw, 4.6rem);
    font-weight: 800;
    line-height: 1.04;
    letter-spacing: -0.02em;
    color: var(--color-white);
    max-width: 14ch;
  }
  .hero__sub {
    margin: 0 0 var(--space-8) 0;
    font-size: clamp(1.05rem, 1.4vw, 1.2rem);
    line-height: 1.5;
    color: color-mix(in srgb, var(--color-white) 92%, transparent);
    max-width: 48ch;
  }
  .hero__cta { margin-bottom: var(--space-10); }
  .hero__primary {
    border-radius: 999px;
    padding: 20px 36px;
    font-size: 1.05rem;
    box-shadow: 0 18px 40px rgba(0, 0, 0, 0.25);
    gap: var(--space-3);
  }
  .hero__primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 22px 48px rgba(0, 0, 0, 0.32);
  }
  .hero__trust {
    list-style: none; padding: 0; margin: 0;
    display: flex; align-items: center; gap: var(--space-4); flex-wrap: wrap;
  }
  .hero__trust-item {
    font-size: 0.82rem; letter-spacing: 0.06em;
    font-weight: 600;
    color: color-mix(in srgb, var(--color-white) 86%, transparent);
  }
  .hero__trust-item--badge {
    width: 44px; height: 44px;
    border: 2px solid color-mix(in srgb, var(--color-white) 70%, transparent);
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
  }
  .hero__trust-ecfa {
    font-size: 0.7rem; font-weight: 800;
    letter-spacing: 0.04em; color: var(--color-white);
  }
  .hero__trust-divider {
    width: 1px; height: 20px;
    background: color-mix(in srgb, var(--color-white) 35%, transparent);
  }
  @media (max-width: 900px) {
    .hero__inner { padding-top: 110px; }
    .hero__scrim {
      background: linear-gradient(180deg,
        rgba(11, 64, 36, 0.65) 0%,
        rgba(11, 64, 36, 0.82) 40%,
        rgba(11, 64, 36, 0.94) 100%);
    }
  }
  @media (max-width: 720px) {
    .hero--fullbleed { min-height: 600px; }
    .hero__h1 { font-size: clamp(2rem, 8vw, 2.8rem); }
  }

  /* ===== BAND 2: SIGNATURE PHRASE (asymmetric photo + text) ===== */
  .signature {
    background: var(--color-white);
    padding: clamp(var(--space-16), 11vw, var(--space-24)) 0;
    position: relative;
  }
  .signature__grid {
    display: grid;
    grid-template-columns: 1.05fr 1fr;
    gap: clamp(var(--space-8), 5vw, var(--space-16));
    align-items: center;
  }
  @media (max-width: 900px) {
    .signature__grid { grid-template-columns: 1fr; }
  }
  .signature__copy { max-width: 56ch; }
  .signature__rule {
    display: block;
    width: 56px; height: 3px;
    background: var(--color-gold);
    margin-bottom: var(--space-6);
    border-radius: 2px;
  }
  .signature__eyebrow {
    margin: 0 0 var(--space-4) 0;
    font-size: 0.78rem;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    font-weight: 700;
    color: var(--color-sage);
  }
  .signature__phrase {
    margin: 0 0 var(--space-6) 0;
    font-size: clamp(2.4rem, 5.2vw, 4.2rem);
    font-weight: 800;
    line-height: 1.02;
    color: var(--color-green-deep);
    letter-spacing: -0.025em;
    max-width: 14ch;
  }
  .signature__body {
    margin: 0 0 var(--space-8) 0;
    font-size: 1.08rem;
    line-height: 1.65;
    color: var(--color-ink);
  }
  .signature__body strong {
    color: var(--color-green-deep);
    font-weight: 700;
  }
  .signature__scripture {
    margin: 0;
    padding: var(--space-5) var(--space-7);
    border-left: 3px solid var(--color-gold);
    background: var(--color-cream);
    font-size: 0.98rem;
    font-style: italic;
    line-height: 1.55;
    color: var(--color-green-deep);
  }
  .signature__cite {
    display: block;
    margin-top: var(--space-2);
    font-style: normal;
    font-size: 0.72rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-sage);
    font-weight: 700;
  }
  .signature__photo {
    background-size: cover;
    background-position: center;
    border-radius: 14px;
    aspect-ratio: 4 / 5;
    box-shadow: 0 24px 60px rgba(11, 64, 36, 0.22);
    position: relative;
  }
  .signature__photo::after {
    content: '';
    position: absolute; inset: 0;
    border-radius: 14px;
    background: linear-gradient(135deg, rgba(11, 64, 36, 0) 60%, rgba(11, 64, 36, 0.25) 100%);
    pointer-events: none;
  }
  @media (max-width: 900px) {
    .signature__photo { aspect-ratio: 16 / 10; }
  }

  /* ===== BAND 3: PILLARS (photo top, white card below, no scrim) ===== */
  .pillars {
    background: color-mix(in srgb, var(--color-sage-light) 50%, var(--color-white));
    padding: clamp(var(--space-16), 10vw, var(--space-24)) 0;
  }
  .pillars__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-6);
  }
  @media (max-width: 1100px) { .pillars__grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 560px)  { .pillars__grid { grid-template-columns: 1fr; } }
  .pillar {
    display: flex;
    flex-direction: column;
    background: var(--color-white);
    border-radius: 14px;
    overflow: hidden;
    text-decoration: none;
    color: var(--color-ink);
    box-shadow: 0 8px 24px rgba(11, 64, 36, 0.10);
    transition: transform 280ms ease, box-shadow 280ms ease;
  }
  .pillar:hover {
    transform: translateY(-6px);
    box-shadow: 0 22px 50px rgba(11, 64, 36, 0.20);
  }
  .pillar__photo {
    aspect-ratio: 5 / 4;
    background-size: cover;
    background-position: center;
    transition: transform 700ms ease;
  }
  .pillar:hover .pillar__photo { transform: scale(1.04); }
  .pillar__body {
    padding: var(--space-6);
    display: flex; flex-direction: column;
    gap: var(--space-2);
    flex: 1;
  }
  .pillar__num {
    font-size: 0.7rem;
    letter-spacing: 0.28em;
    font-weight: 800;
    color: var(--color-gold);
    margin-bottom: var(--space-2);
  }
  .pillar__title {
    margin: 0;
    font-size: clamp(1.15rem, 1.4vw, 1.35rem);
    font-weight: 800;
    line-height: 1.15;
    color: var(--color-green-deep);
    letter-spacing: -0.01em;
  }
  .pillar__blurb {
    margin: var(--space-2) 0 var(--space-4) 0;
    font-size: 0.92rem;
    line-height: 1.55;
    color: var(--color-ink-soft);
    flex: 1;
  }
  .pillar__cta {
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--color-green-deep);
    letter-spacing: 0.02em;
    border-bottom: 2px solid var(--color-gold);
    align-self: flex-start;
    padding-bottom: 2px;
    transition: color 200ms;
  }
  .pillar:hover .pillar__cta { color: var(--color-gold); }

  /* ===== BAND 4: STORIES (white, 1 lead + 2 stacked) ===== */
  .stories {
    background: var(--color-white);
    padding: clamp(var(--space-16), 10vw, var(--space-24)) 0;
  }
  .stories__grid {
    display: grid;
    grid-template-columns: 1.15fr 1fr;
    gap: var(--space-8);
  }
  @media (max-width: 980px) { .stories__grid { grid-template-columns: 1fr; } }
  .story {
    display: block;
    text-decoration: none;
    color: var(--color-ink);
    border-radius: 14px;
    overflow: hidden;
    background: var(--color-white);
    transition: transform 240ms, box-shadow 240ms;
  }
  .story--lead {
    box-shadow: 0 6px 20px rgba(11, 64, 36, 0.08);
    border: 1px solid color-mix(in srgb, var(--color-sage) 18%, transparent);
    display: grid;
    grid-template-rows: auto 1fr;
  }
  .story--lead .story__photo {
    aspect-ratio: 5 / 3;
  }
  .story--lead .story__body {
    padding: var(--space-7) var(--space-7) var(--space-8) var(--space-7);
    gap: var(--space-3);
  }
  @media (min-width: 980px) {
    .story--lead {
      grid-template-columns: 1.1fr 1fr;
      grid-template-rows: auto;
    }
    .story--lead .story__photo { aspect-ratio: auto; height: 100%; min-height: 360px; }
    .story--lead .story__body { padding: var(--space-9) var(--space-8); }
  }
  .story:hover {
    transform: translateY(-4px);
    box-shadow: 0 22px 48px rgba(11, 64, 36, 0.16);
  }
  .story__photo {
    aspect-ratio: 4 / 3;
    background-size: cover;
    background-position: center;
  }
  .story__photo--side {
    aspect-ratio: 1 / 1;
    height: 100%;
  }
  .story__body {
    padding: var(--space-8);
    display: flex; flex-direction: column;
    gap: var(--space-3);
  }
  .story__country {
    color: var(--color-gold);
    font-size: 0.72rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    font-weight: 800;
  }
  .story__title {
    margin: 0;
    color: var(--color-green-deep);
    font-size: 1.35rem;
    line-height: 1.2;
    font-weight: 800;
    letter-spacing: -0.005em;
  }
  .story__title--lead {
    font-size: clamp(1.6rem, 2.4vw, 2rem);
  }
  .story__excerpt {
    margin: 0;
    color: var(--color-ink-soft);
    font-size: 1rem;
    line-height: 1.55;
  }
  .story__excerpt--side { font-size: 0.92rem; line-height: 1.5; }
  .story__cta {
    color: var(--color-green-deep);
    font-weight: 700;
    font-size: 0.9rem;
    border-bottom: 2px solid var(--color-gold);
    align-self: flex-start;
    padding-bottom: 2px;
    margin-top: var(--space-2);
  }
  .stories__sidecol {
    display: grid;
    grid-template-rows: 1fr 1fr;
    gap: var(--space-6);
  }
  .story--side {
    display: grid;
    grid-template-columns: minmax(140px, 38%) 1fr;
    border: 1px solid color-mix(in srgb, var(--color-sage) 18%, transparent);
    box-shadow: 0 4px 14px rgba(11, 64, 36, 0.06);
  }
  .story__body--side {
    padding: var(--space-6);
    gap: var(--space-2);
  }
  .story--side .story__title { font-size: 1.1rem; }
  @media (max-width: 560px) {
    .story--side { grid-template-columns: 1fr; }
    .story__photo--side { aspect-ratio: 16 / 10; height: auto; }
  }

  /* ===== BAND 5: IMPACT (deep green, photo backdrop, huge stats) ===== */
  .impact {
    position: relative;
    background: var(--color-green-deep);
    padding: clamp(var(--space-16), 10vw, var(--space-24)) 0;
    overflow: hidden;
    color: var(--color-white);
  }
  .impact__bg {
    position: absolute; inset: 0;
    background-size: cover;
    background-position: center;
    opacity: 0.18;
    z-index: 0;
    filter: grayscale(40%);
  }
  .impact__scrim {
    position: absolute; inset: 0; z-index: 1;
    background:
      radial-gradient(circle at 30% 30%, rgba(11, 64, 36, 0.55), rgba(11, 64, 36, 0.95) 70%),
      linear-gradient(180deg, rgba(11, 64, 36, 0.78) 0%, rgba(11, 64, 36, 0.92) 100%);
  }
  .impact__inner { position: relative; z-index: 2; }
  .impact__head { text-align: center; margin-bottom: var(--space-12); }
  .impact__eyebrow { color: var(--color-gold); }
  .impact__h2 {
    margin: 0;
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 800;
    color: var(--color-white);
    line-height: 1.05;
    letter-spacing: -0.018em;
  }
  .impact__grid {
    list-style: none; padding: 0; margin: 0;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-8);
    border-top: 1px solid color-mix(in srgb, var(--color-gold) 30%, transparent);
    border-bottom: 1px solid color-mix(in srgb, var(--color-gold) 30%, transparent);
    padding: var(--space-12) 0;
  }
  @media (max-width: 800px) {
    .impact__grid {
      grid-template-columns: 1fr;
      gap: var(--space-6);
      padding: var(--space-8) 0;
    }
  }
  .impact-stat {
    display: flex; flex-direction: column;
    align-items: center; text-align: center;
    gap: var(--space-3);
    position: relative;
  }
  .impact-stat:not(:last-child)::after {
    content: '';
    position: absolute;
    right: calc(var(--space-8) * -0.5);
    top: 12%; bottom: 12%;
    width: 1px;
    background: color-mix(in srgb, var(--color-gold) 30%, transparent);
  }
  @media (max-width: 800px) { .impact-stat::after { display: none; } }
  .impact-stat__value {
    font-size: clamp(4rem, 10vw, 7.5rem);
    font-weight: 800;
    line-height: 0.9;
    color: var(--color-gold);
    letter-spacing: -0.04em;
  }
  .impact-stat__unit {
    font-size: 0.55em;
    font-weight: 700;
    margin-left: 2px;
    color: color-mix(in srgb, var(--color-gold) 90%, var(--color-white));
  }
  .impact-stat__label {
    font-size: 0.92rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    font-weight: 800;
    color: var(--color-white);
  }
  .impact-stat__note {
    font-size: 0.78rem;
    letter-spacing: 0.04em;
    color: color-mix(in srgb, var(--color-white) 65%, transparent);
    max-width: 28ch;
  }
  .impact__sources {
    margin: var(--space-8) 0 0 0;
    text-align: center;
    font-size: 0.82rem;
    letter-spacing: 0.06em;
    color: color-mix(in srgb, var(--color-white) 75%, transparent);
  }
  .impact__sources a {
    color: var(--color-gold);
    text-decoration: none;
    border-bottom: 1px solid color-mix(in srgb, var(--color-gold) 50%, transparent);
    padding-bottom: 1px;
  }
  .impact__sources a:hover { border-bottom-color: var(--color-gold); }

  /* ===== BAND 6: PARTNER (full-bleed gold band, field-leader photo, white tier cards) ===== */
  .partner {
    position: relative;
    padding: clamp(var(--space-16), 11vw, var(--space-24)) 0;
    background: var(--color-gold);
    color: var(--color-green-deep);
    overflow: hidden;
    isolation: isolate;
  }
  .partner__photo {
    position: absolute; inset: 0;
    background-size: cover;
    background-position: right center;
    opacity: 0.28;
    z-index: 0;
    filter: saturate(1.05);
  }
  .partner__scrim {
    position: absolute; inset: 0; z-index: 1;
    background:
      linear-gradient(90deg, var(--color-gold) 0%, var(--color-gold) 35%, color-mix(in srgb, var(--color-gold) 70%, transparent) 70%, color-mix(in srgb, var(--color-gold) 30%, transparent) 100%);
  }
  .partner__inner {
    position: relative; z-index: 2;
    display: grid;
    grid-template-columns: 5fr 6fr;
    gap: clamp(var(--space-8), 4vw, var(--space-12));
    align-items: center;
  }
  @media (max-width: 980px) {
    .partner__inner { grid-template-columns: 1fr; gap: var(--space-10); }
    .partner__scrim {
      background: linear-gradient(180deg, var(--color-gold) 0%, color-mix(in srgb, var(--color-gold) 88%, transparent) 100%);
    }
  }
  .partner__eyebrow {
    margin: 0 0 var(--space-4) 0;
    font-size: 0.78rem;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    font-weight: 800;
    color: var(--color-green-deep);
  }
  .partner__h2 {
    margin: 0 0 var(--space-5) 0;
    font-size: clamp(2rem, 4vw, 3rem);
    line-height: 1.05;
    color: var(--color-green-deep);
    font-weight: 800;
    letter-spacing: -0.02em;
  }
  .partner__body {
    margin: 0 0 var(--space-8) 0;
    color: color-mix(in srgb, var(--color-green-deep) 88%, transparent);
    line-height: 1.6;
    font-size: 1.05rem;
    max-width: 44ch;
  }
  .partner__cta {
    display: inline-flex;
    align-items: center;
    gap: var(--space-3);
    background: var(--color-green-deep);
    color: var(--color-white);
    border-radius: 999px;
    padding: 20px 36px;
    font-size: 1.05rem;
    font-weight: 800;
    text-decoration: none;
    box-shadow: 0 18px 40px rgba(11, 64, 36, 0.28);
    transition: transform 200ms, box-shadow 200ms, background 200ms;
  }
  .partner__cta:hover {
    transform: translateY(-2px);
    box-shadow: 0 22px 48px rgba(11, 64, 36, 0.34);
    background: #0d5b32;
  }
  .partner__altgive {
    margin: var(--space-5) 0 0 0;
    font-size: 0.9rem;
    line-height: 1.6;
  }
  .partner__altgive a {
    color: var(--color-green-deep);
    text-decoration: none;
    font-weight: 700;
    border-bottom: 2px solid var(--color-green-deep);
    padding-bottom: 2px;
  }
  .partner__altgive a:hover {
    border-bottom-color: transparent;
  }
  .partner__tiers-label {
    margin: 0 0 var(--space-5) 0;
    font-size: 0.72rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    font-weight: 800;
    color: color-mix(in srgb, var(--color-green-deep) 75%, transparent);
  }
  .partner__tiers-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-3);
  }
  @media (max-width: 680px) { .partner__tiers-grid { grid-template-columns: repeat(2, 1fr); } }
  .tier {
    position: relative;
    display: flex; flex-direction: column; align-items: flex-start;
    padding: var(--space-5);
    background: var(--color-white);
    border: 1px solid color-mix(in srgb, var(--color-green-deep) 12%, transparent);
    border-radius: 12px;
    text-decoration: none;
    color: var(--color-green-deep);
    transition: transform 200ms, box-shadow 200ms, border-color 200ms;
    min-height: 110px;
    box-shadow: 0 4px 14px rgba(11, 64, 36, 0.08);
  }
  .tier:hover {
    transform: translateY(-3px);
    border-color: var(--color-green-deep);
    box-shadow: 0 14px 30px rgba(11, 64, 36, 0.18);
  }
  .tier__amount {
    font-size: clamp(1.35rem, 1.8vw, 1.7rem);
    font-weight: 800;
    line-height: 1;
    color: var(--color-green-deep);
    letter-spacing: -0.02em;
  }
  .tier__period {
    font-size: 0.72rem;
    font-weight: 600;
    color: color-mix(in srgb, var(--color-green-deep) 60%, transparent);
    margin-left: 4px;
    letter-spacing: 0;
  }
  .tier__label {
    margin-top: var(--space-3);
    font-size: 0.7rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    font-weight: 800;
    color: var(--color-green-deep);
  }
  .tier--featured {
    background: var(--color-green-deep);
    border-color: var(--color-green-deep);
    box-shadow: 0 14px 32px rgba(11, 64, 36, 0.32);
  }
  .tier--featured .tier__amount { color: var(--color-gold); }
  .tier--featured .tier__label { color: var(--color-white); }
  .tier--featured .tier__period { color: color-mix(in srgb, var(--color-white) 75%, transparent); }
  .tier--featured:hover {
    background: #0d5b32;
    border-color: var(--color-gold);
  }
  .tier__badge {
    position: absolute;
    top: -10px; left: var(--space-5);
    background: var(--color-gold);
    color: var(--color-green-deep);
    font-size: 0.6rem;
    font-weight: 800;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    padding: 4px 8px;
    border-radius: 4px;
    border: 1px solid var(--color-green-deep);
  }

  /* ===== BAND 7: PRAY + GO (split-band, photo each side) ===== */
  .praygo {
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: 460px;
  }
  @media (max-width: 880px) { .praygo { grid-template-columns: 1fr; } }
  .praygo__panel {
    position: relative;
    display: block;
    text-decoration: none;
    color: var(--color-white);
    overflow: hidden;
    isolation: isolate;
    min-height: 460px;
  }
  .praygo__photo {
    position: absolute; inset: 0;
    background-size: cover;
    background-position: center;
    z-index: 0;
    transition: transform 800ms ease;
  }
  .praygo__panel:hover .praygo__photo { transform: scale(1.05); }
  .praygo__scrim { position: absolute; inset: 0; z-index: 1; }
  .praygo__scrim--green {
    background: linear-gradient(135deg, rgba(11, 64, 36, 0.92) 0%, rgba(11, 64, 36, 0.78) 100%);
  }
  .praygo__scrim--terracotta {
    background: linear-gradient(135deg, rgba(163, 109, 76, 0.90) 0%, rgba(31, 58, 26, 0.82) 100%);
  }
  .praygo__scrim--cream {
    background: linear-gradient(135deg, rgba(248, 244, 228, 0.94) 0%, rgba(243, 234, 216, 0.97) 100%);
  }
  .praygo__photo--light { opacity: 1; }
  .praygo__eyebrow--dark { color: var(--color-green-deep); }
  .praygo__h3--dark { color: var(--color-green-deep); }
  .praygo__lede--dark { color: var(--color-ink); }
  .praygo__cta--dark {
    color: var(--color-green-deep);
    border-bottom-color: var(--color-gold);
  }
  .praygo__trips {
    list-style: none; padding: 0;
    margin: 0 0 var(--space-6) 0;
    display: flex; flex-direction: column;
    gap: var(--space-2);
    font-size: 0.92rem;
    color: var(--color-ink);
  }
  .praygo__trips li {
    display: flex; gap: var(--space-3);
    align-items: baseline;
    padding: var(--space-2) 0;
    border-top: 1px solid color-mix(in srgb, var(--color-green-deep) 12%, transparent);
  }
  .praygo__trips li:last-child {
    border-bottom: 1px solid color-mix(in srgb, var(--color-green-deep) 12%, transparent);
  }
  .praygo__trip-date {
    font-weight: 800;
    color: var(--color-green-deep);
    font-size: 0.78rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    min-width: 76px;
  }
  .praygo__body {
    position: absolute;
    inset: 0;
    z-index: 2;
    padding: clamp(var(--space-10), 6vw, var(--space-16));
    display: flex; flex-direction: column; justify-content: center;
    max-width: 480px;
  }
  .praygo__eyebrow {
    margin: 0 0 var(--space-4) 0;
    font-size: 0.78rem;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    font-weight: 800;
    color: var(--color-gold);
  }
  .praygo__h3 {
    margin: 0 0 var(--space-4) 0;
    font-size: clamp(1.8rem, 3vw, 2.4rem);
    font-weight: 800;
    line-height: 1.1;
    color: var(--color-white);
    letter-spacing: -0.018em;
  }
  .praygo__lede {
    margin: 0 0 var(--space-6) 0;
    font-size: 1rem;
    line-height: 1.55;
    color: color-mix(in srgb, var(--color-white) 88%, transparent);
    max-width: 38ch;
  }
  .praygo__cta {
    align-self: flex-start;
    font-weight: 700;
    font-size: 0.92rem;
    letter-spacing: 0.04em;
    color: var(--color-gold);
    border-bottom: 2px solid var(--color-gold);
    padding-bottom: 3px;
  }

  /* ===== BAND 8: NEWSLETTER (sage-light, centered, single-field) ===== */
  .newsletter {
    background: color-mix(in srgb, var(--color-sage-light) 55%, var(--color-white));
    padding: clamp(var(--space-16), 10vw, var(--space-20)) 0;
  }
  .newsletter__inner {
    text-align: center;
    display: flex; flex-direction: column; align-items: center;
    gap: var(--space-4);
  }
  .newsletter__eyebrow { color: var(--color-green-deep); }
  .newsletter__h2 {
    margin: 0;
    font-size: clamp(1.8rem, 3.6vw, 2.6rem);
    color: var(--color-green-deep);
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: -0.018em;
  }
  .newsletter__body {
    margin: 0 0 var(--space-4) 0;
    color: var(--color-ink-soft);
    font-size: 1rem;
    line-height: 1.55;
    max-width: 52ch;
  }
  .newsletter__form {
    display: flex;
    gap: var(--space-2);
    width: 100%;
    max-width: 520px;
    padding: 6px;
    background: var(--color-white);
    border-radius: 999px;
    box-shadow: 0 8px 28px rgba(11, 64, 36, 0.10);
  }
  @media (max-width: 540px) {
    .newsletter__form {
      flex-direction: column;
      border-radius: 14px;
      padding: var(--space-2);
    }
  }
  .newsletter__input {
    flex: 1;
    border: 0;
    background: transparent;
    padding: 14px 20px;
    font-size: 1rem;
    font-family: inherit;
    color: var(--color-ink);
    outline: none;
    min-width: 0;
  }
  .newsletter__submit {
    border-radius: 999px;
    padding: 14px 26px;
    font-size: 0.95rem;
    gap: var(--space-2);
  }
  @media (max-width: 540px) { .newsletter__submit { border-radius: 10px; } }
  .newsletter__privacy {
    margin: var(--space-2) 0 0 0;
    font-size: 0.8rem;
    color: var(--color-sage);
  }
  .newsletter__privacy a {
    color: var(--color-green-deep);
    border-bottom: 1px solid color-mix(in srgb, var(--color-gold) 70%, transparent);
    text-decoration: none;
    padding-bottom: 1px;
  }

