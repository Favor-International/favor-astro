---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteHeader from '../components/global/SiteHeader.astro';
import SiteFooter from '../components/global/SiteFooter.astro';
import NewsletterForm from '../components/global/NewsletterForm.astro';
import { PILLARS, PARTNER_TIERS, SITE } from '../lib/site';
import { CTA } from '../lib/cta';

// Pillar imagery (each pillar has its own distinct photo).
const pillarImages: Record<string, string> = {
  'evangelism-discipleship': '/images/pillar-evangelism-discipleship.jpg',
  'education': '/images/pillar-education.jpg',
  'community-development': '/images/pillar-community-care.jpg',
  'economic-empowerment': '/images/pillar-economic-empowerment.jpg',
};

// Real published stories from the Webflow CMS (Stories.csv).
const featuredStories = [
  {
    title: '"More Bibles for Ethiopia, please!"',
    country: 'Ethiopia',
    excerpt: 'After two months of Portable Bible Schools in Ethiopia, field teachers graduated 763 students, led 112 to salvation, and baptized 57. Then they ran out of Bibles.',
    image: '/images/stories/more-bibles-for-ethiopia-please.jpg',
    href: '/stories/more-bibles-for-ethiopia-please/',
  },
  {
    title: 'Daniel Kidia',
    country: 'South Sudan',
    excerpt: 'A former Mundari cattle warrior, now a Favor field pastor leading PBS classes among his own people. A PBS testimony.',
    image: '/images/stories/daniel-kidia.jpg',
    href: '/stories/daniel-kidia/',
  },
  {
    title: 'Goats for Women',
    country: 'Uganda',
    excerpt: 'Women of Puranga praised and worshipped God as they waited to receive two goats each, the fruit of a year of Women’s Empowerment training.',
    image: '/images/stories/goats-for-women.jpg',
    href: '/stories/goats-for-women/',
  },
];

const quickAmounts = [25, 50, 100, 200, 500];
---
<BaseLayout
  title={`${SITE.name} — ${SITE.tagline}`}
  description="Favor International equips indigenous African leaders to advance the Gospel through Portable Bible Schools, the GIFT Institute, education, medical care, church planting, and economic empowerment. ECFA-accredited. Carole Ward, Founder."
  image="/images/pillar-evangelism-discipleship.jpg"
>
  <SiteHeader variant="transparent" />
  <main id="main">

    <!-- BAND 1: Hero — full-bleed background, partner-centric H1 (World Vision pattern) -->
    <!--
      DESIGN NOTE: Photo is intentionally low-rendered with a strong gradient
      overlay to mask compression artifacts in the available field photography.
      Replace /images/pbs-karamoja.jpg with a high-resolution editorial hero
      shot when one becomes available. Recommended: wide environmental shot
      (IJM-style "joy from a distance"), 2400x1500 minimum.
    -->
    <section class="hero hero--fullbleed" aria-label="Stand with the missionaries reaching East Africa">
      <div class="hero__bg" style="background-image: url(/images/pbs-karamoja.jpg)" aria-hidden="true"></div>
      <div class="hero__scrim" aria-hidden="true"></div>
      <div class="hero__inner container">
        <div class="hero__copy">
          <p class="hero__eyebrow">Transformed Hearts Transform Nations</p>
          <h1 class="hero__h1">Stand with the missionaries reaching East Africa's hardest places.</h1>
          <p class="hero__sub">Favor International equips indigenous African leaders to plant churches, train pastors, run schools, and care for the persecuted. Your monthly partnership makes their work possible.</p>
          <div class="hero__cta">
            <a class="btn btn--primary btn--large" href="/give/partner-monthly/">{CTA.partnerMonthly}</a>
            <a class="hero__secondary" href="/impact/">See the field &rarr;</a>
          </div>
          <p class="hero__trust">ECFA-accredited &middot; 501(c)(3) &middot; EIN {SITE.ein}</p>
        </div>
      </div>
    </section>

    <!-- BAND 2: Scripture pause-beat (the John 9:4 verse from the existing homepage) -->
    <section class="band band--cream scripture">
      <div class="container container--narrow scripture__inner">
        <blockquote class="scripture__quote">
          &ldquo;{SITE.scripture.text}&rdquo;
        </blockquote>
        <p class="scripture__cite">&mdash; {SITE.scripture.attribution}</p>
      </div>
    </section>

    <!-- BAND 3: What We Do — four ministry pillars with real names from favorintl.org -->
    <section class="band band--white pillars">
      <div class="container">
        <header class="band__header">
          <p class="label">What We Do</p>
          <h2>Four ministries. One Kingdom outcome.</h2>
        </header>
        <div class="pillars__grid">
          {PILLARS.map((p) => (
            <a class="pillar" href={`/impact/${p.slug}/`}>
              <div class="pillar__photo" style={`background-image: url(${pillarImages[p.slug]})`} aria-hidden="true">
                <div class="pillar__photo-scrim" aria-hidden="true"></div>
                <h3 class="pillar__title">{p.label}</h3>
              </div>
              <div class="pillar__body">
                <p>{p.blurb}</p>
                <span class="pillar__cta">Learn more →</span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- BAND 4: Stories of Transformation -->
    <section class="band band--cream stories">
      <div class="container">
        <header class="band__header band__header--with-cta">
          <div>
            <p class="label">Stories of Transformation</p>
            <h2>Real names. Real places. Real outcomes.</h2>
          </div>
          <a class="band__header-cta" href="/stories/">All stories →</a>
        </header>
        <div class="stories__grid">
          {featuredStories.map((s) => (
            <a class="story" href={s.href}>
              <div class="story__photo" style={`background-image: url(${s.image})`} aria-hidden="true"></div>
              <div class="story__body">
                <span class="story__country">{s.country}</span>
                <h3>{s.title}</h3>
                <p>{s.excerpt}</p>
                <span class="story__cta">Read the story →</span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- BAND 5: Partner with us today -->
    <section class="band band--green partner" id="partner">
      <div class="container partner__grid">
        <div class="partner__copy">
          <p class="label label--bright">Become a Favor Partner</p>
          <h2>Partner with us today.</h2>
          <p>Favor Partners give monthly. Your gift goes straight to the field and keeps indigenous pastors, teachers, and counselors in motion. Pick a tier that fits, or choose your own amount.</p>
          <p class="partner__trust">Tax-deductible. <a href="/about/accountability/">ECFA-accredited since 2019.</a></p>
        </div>
        <div class="partner__tiers">
          {PARTNER_TIERS.map((t) => (
            <a class:list={['tier', t.featured && 'tier--featured']} href={`/give/partner-monthly/?amount=${t.amount}`}>
              <span class="tier__amount">${t.amount}<span class="tier__period">/mo</span></span>
              <span class="tier__label">{t.label}</span>
            </a>
          ))}
        </div>
      </div>
      <div class="container partner__footer">
        <a class="btn btn--primary btn--large" href="/give/partner-monthly/">{CTA.partnerMonthly}</a>
        <a class="partner__alt" href="/give/">Or explore other ways to give →</a>
      </div>
    </section>

    <!-- BAND 6: Pray -->
    <section class="band band--tan pray-cta">
      <div class="container pray-cta__grid">
        <div class="pray-cta__photo" style="background-image: url(/images/ministry-house-of-prayer.jpg)" role="img" aria-label="A House of Prayer gathering in Juba, South Sudan"></div>
        <div class="pray-cta__copy">
          <p class="label">Pray with us</p>
          <h2>You can pray where they cannot reach.</h2>
          <p>The 30-Day Prayer Guide walks you through one specific request per day across the regions Favor serves. No email required. Print it, tape it to the fridge, pray it out loud.</p>
          <a class="btn btn--secondary btn--large" href="/pray/30-day-guide/">{CTA.prayerGuide}</a>
        </div>
      </div>
    </section>

    <!-- BAND 7: Trust signals (real badges, audited claims) -->
    <section class="band band--white trust-band">
      <div class="container">
        <header class="band__header">
          <p class="label">Accountability</p>
          <h2>Three ways Favor earns your trust.</h2>
        </header>
        <div class="trust-band__grid">
          <article class="trust-card">
            <img class="trust-card__badge" src="/images/trust/ecfa.png" alt="ECFA Accredited" width="120" height="120" />
            <h3>ECFA-accredited since 2019</h3>
            <p>Favor International has been a member of the Evangelical Council for Financial Accountability since September 30, 2019. ECFA holds members to a public standard of stewardship and disclosure.</p>
            <a href={SITE.trust.ecfa} target="_blank" rel="noopener">View our ECFA profile →</a>
          </article>
          <article class="trust-card">
            <img class="trust-card__badge" src="/images/trust/charity-navigator.svg" alt="Charity Navigator Four-Star" width="120" height="120" />
            <h3>Four-Star Charity Navigator rating</h3>
            <p>Charity Navigator scores nonprofits on financial health, accountability, and transparency. Favor holds the Four-Star rating, the highest tier.</p>
            <a href={SITE.trust.charityNavigator} target="_blank" rel="noopener">View our Charity Navigator profile →</a>
          </article>
          <article class="trust-card">
            <img class="trust-card__badge" src="/images/trust/candid-platinum.svg" alt="Candid Platinum Transparency Seal" width="120" height="120" />
            <h3>Candid Platinum transparency seal</h3>
            <p>Candid (formerly Guidestar) verifies nonprofit transparency at four tiers. Favor holds the Platinum tier, the highest. EIN {SITE.ein}.</p>
            <a href={SITE.trust.candid} target="_blank" rel="noopener">View our Candid profile →</a>
          </article>
        </div>
      </div>
    </section>

    <!-- BAND 8: Inline give widget -->
    <section class="band band--green-deep inline-give">
      <div class="container container--narrow inline-give__inner">
        <p class="label label--bright">Give where most needed</p>
        <h2>One gift. Directly to the field.</h2>
        <p>Unrestricted gifts go where the field is asking the loudest that week. Pick an amount, or set your own.</p>
        <form class="inline-give__form" action="/give/one-time/" method="get">
          <div class="inline-give__amounts">
            {quickAmounts.map((a, i) => (
              <label>
                <input type="radio" name="amount" value={a} checked={i === 1} />
                <span>${a}</span>
              </label>
            ))}
            <label class="inline-give__custom">
              <input type="number" name="amount" placeholder="Custom" min="5" />
            </label>
          </div>
          <button type="submit" class="btn btn--primary btn--large">Give now</button>
        </form>
        <p class="inline-give__note">Tax-deductible. Powered by Blackbaud. <a href="/give/">See all giving options →</a></p>
      </div>
    </section>

    <!-- BAND 9: Newsletter -->
    <section class="band band--sage newsletter-band">
      <div class="container container--narrow">
        <p class="label">Get the field report</p>
        <h2>Be inspired with amazing stories from the field.</h2>
        <p>Sign up for the Favor newsletter. Field updates, prayer requests, and stories of transformation, sent monthly.</p>
        <NewsletterForm />
      </div>
    </section>

  </main>
  <SiteFooter />
</BaseLayout>

<style>
  /* ===== HERO (full-bleed, World Vision pattern) ===== */
  .hero--fullbleed {
    position: relative;
    min-height: clamp(560px, 88vh, 760px);
    display: flex;
    align-items: center;
    color: var(--color-white);
    overflow: hidden;
    padding-top: 96px;
    padding-bottom: var(--space-12);
  }
  .hero__bg {
    position: absolute; inset: 0;
    background-size: cover;
    background-position: center;
    z-index: 0;
    /* Slight zoom + saturation tweak helps low-res field photos read better */
    transform: scale(1.05);
    filter: saturate(1.05) contrast(1.02);
  }
  .hero__scrim {
    position: absolute; inset: 0;
    z-index: 1;
    /* Strong deep-green gradient on the left where the text lives, fading to
       lighter green on the right. Masks compression artifacts in the photo. */
    background:
      linear-gradient(90deg,
        rgba(11, 64, 36, 0.92) 0%,
        rgba(11, 64, 36, 0.78) 32%,
        rgba(11, 64, 36, 0.45) 58%,
        rgba(11, 64, 36, 0.18) 85%,
        rgba(11, 64, 36, 0.08) 100%),
      linear-gradient(180deg,
        rgba(11, 64, 36, 0.15) 0%,
        transparent 30%,
        transparent 70%,
        rgba(11, 64, 36, 0.35) 100%);
  }
  .hero__inner {
    position: relative;
    z-index: 2;
    width: 100%;
  }
  .hero__copy {
    max-width: 640px;
  }
  .hero__eyebrow {
    margin: 0 0 var(--space-4) 0;
    font-size: 0.78rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    font-weight: 700;
    color: var(--color-gold);
  }
  .hero__h1 {
    margin: 0 0 var(--space-5) 0;
    font-size: clamp(2.1rem, 4.6vw, 3.6rem);
    font-weight: 800;
    line-height: 1.08;
    letter-spacing: -0.015em;
    color: var(--color-white);
    text-wrap: balance;
  }
  .hero__sub {
    margin: 0 0 var(--space-8) 0;
    font-size: clamp(1.0rem, 1.3vw, 1.15rem);
    line-height: 1.6;
    color: color-mix(in srgb, var(--color-white) 92%, transparent);
    max-width: 56ch;
  }
  .hero__cta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-5);
    margin-bottom: var(--space-8);
  }
  .hero__secondary {
    color: var(--color-white);
    text-decoration: none;
    font-weight: 700;
    font-size: 0.95rem;
    letter-spacing: 0.02em;
    border-bottom: 2px solid var(--color-gold);
    padding-bottom: 2px;
  }
  .hero__secondary:hover { color: var(--color-gold); }
  .hero__trust {
    margin: 0;
    font-size: 0.78rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    font-weight: 600;
    color: color-mix(in srgb, var(--color-white) 72%, transparent);
  }
  @media (max-width: 720px) {
    .hero--fullbleed { min-height: 540px; padding-top: 88px; }
    .hero__scrim {
      /* On mobile, scrim from the bottom up so text-over-photo still reads */
      background: linear-gradient(180deg,
        rgba(11, 64, 36, 0.6) 0%,
        rgba(11, 64, 36, 0.78) 38%,
        rgba(11, 64, 36, 0.92) 100%);
    }
  }
  /* ===== SCRIPTURE BAND ===== */
  .scripture { padding-top: var(--space-12); padding-bottom: var(--space-12); }
  .scripture__inner { text-align: center; }
  .scripture__quote {
    margin: 0 auto var(--space-3) auto;
    max-width: 50ch;
    font-family: var(--font-serif, Georgia, 'Source Serif Pro', serif);
    font-style: italic;
    font-size: clamp(1.25rem, 2.2vw, 1.6rem);
    line-height: 1.5;
    color: var(--color-green-deep);
    quotes: none;
    border: none;
  }
  .scripture__cite {
    margin: 0;
    color: var(--color-sage);
    font-size: 0.92rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-weight: 600;
  }

  /* ===== BAND HELPERS ===== */
  .label { text-transform: uppercase; letter-spacing: 0.16em; font-size: 0.78rem; font-weight: 700; color: var(--color-sage); margin: 0 0 var(--space-3); }
  .label--bright { color: var(--color-gold); }
  .band__header { text-align: center; margin-bottom: var(--space-10); }
  .band__header--with-cta { display: flex; justify-content: space-between; align-items: flex-end; flex-wrap: wrap; gap: var(--space-4); text-align: left; }
  .band__header h2 { margin: 0; font-size: clamp(1.8rem, 3.2vw, 2.4rem); color: var(--color-green-deep); }
  .band__header-cta { color: var(--color-green); text-decoration: none; font-weight: 700; font-size: 0.95rem; }

  /* ===== PILLARS ===== */
  .pillars__grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: var(--space-5); }
  @media (max-width: 1100px) { .pillars__grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 540px) { .pillars__grid { grid-template-columns: 1fr; } }
  .pillar {
    display: flex; flex-direction: column;
    background: var(--color-white);
    border-radius: var(--radius-card);
    overflow: hidden;
    text-decoration: none;
    color: var(--color-ink);
    border: 1px solid var(--color-border);
    transition: transform 200ms, box-shadow 200ms;
  }
  .pillar:hover { transform: translateY(-4px); box-shadow: 0 14px 32px rgba(11, 64, 36, 0.12); }
  .pillar__photo {
    position: relative;
    aspect-ratio: 4 / 3;
    background-size: cover;
    background-position: center;
  }
  .pillar__photo-scrim {
    position: absolute; inset: 0;
    background: linear-gradient(180deg, rgba(0,0,0,0) 35%, rgba(11, 64, 36, 0.85) 100%);
  }
  .pillar__title {
    position: absolute;
    left: var(--space-4); right: var(--space-4); bottom: var(--space-4);
    color: var(--color-white);
    font-size: 1.15rem;
    font-weight: 700;
    margin: 0;
    line-height: 1.2;
  }
  .pillar__body { padding: var(--space-5); display: flex; flex-direction: column; gap: var(--space-3); flex: 1; }
  .pillar__body p { margin: 0; color: var(--color-ink-soft); font-size: 0.92rem; line-height: 1.5; }
  .pillar__cta { color: var(--color-green); font-weight: 700; font-size: 0.9rem; margin-top: auto; }

  /* ===== STORIES ===== */
  .stories__grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--space-6); }
  @media (max-width: 900px) { .stories__grid { grid-template-columns: 1fr; } }
  .story {
    display: flex; flex-direction: column;
    background: var(--color-white);
    border-radius: var(--radius-card);
    overflow: hidden;
    text-decoration: none;
    color: var(--color-ink);
    box-shadow: 0 4px 14px rgba(11, 64, 36, 0.06);
    transition: transform 200ms, box-shadow 200ms;
  }
  .story:hover { transform: translateY(-4px); box-shadow: 0 14px 32px rgba(11, 64, 36, 0.12); }
  .story__photo {
    aspect-ratio: 16 / 10;
    background-size: cover;
    background-position: center;
  }
  .story__body { padding: var(--space-5) var(--space-5) var(--space-6); display: flex; flex-direction: column; gap: var(--space-2); flex: 1; }
  .story__country {
    color: var(--color-sage);
    font-size: 0.75rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    font-weight: 700;
  }
  .story h3 { margin: 0; color: var(--color-green-deep); font-size: 1.2rem; line-height: 1.25; }
  .story p { margin: 0; color: var(--color-ink-soft); font-size: 0.92rem; line-height: 1.55; flex: 1; }
  .story__cta { color: var(--color-green); font-weight: 700; font-size: 0.9rem; }

  /* ===== PARTNER ===== */
  .partner {
    background: linear-gradient(160deg, var(--color-green) 0%, var(--color-green-deep) 100%);
    color: var(--color-white);
    padding-top: var(--space-14);
    padding-bottom: var(--space-14);
  }
  .partner__grid { display: grid; grid-template-columns: 1fr 1.2fr; gap: var(--space-10); align-items: center; }
  @media (max-width: 900px) { .partner__grid { grid-template-columns: 1fr; } }
  .partner__copy h2 { color: var(--color-white); margin: 0 0 var(--space-4); font-size: clamp(1.8rem, 3.2vw, 2.4rem); }
  .partner__copy p { color: color-mix(in srgb, var(--color-white) 86%, transparent); margin: 0 0 var(--space-3); line-height: 1.55; }
  .partner__trust a { color: var(--color-gold); text-decoration: underline; }
  .partner__tiers {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-3);
  }
  @media (max-width: 600px) { .partner__tiers { grid-template-columns: repeat(2, 1fr); } }
  .tier {
    display: flex; flex-direction: column; align-items: flex-start;
    padding: var(--space-4) var(--space-5);
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.16);
    border-radius: var(--radius-card);
    text-decoration: none;
    color: var(--color-white);
    transition: background 200ms, border-color 200ms, transform 200ms;
  }
  .tier:hover { background: rgba(255, 255, 255, 0.14); border-color: var(--color-gold); transform: translateY(-3px); }
  .tier__amount { font-size: 1.6rem; font-weight: 800; color: var(--color-gold); line-height: 1; }
  .tier__period { font-size: 0.85rem; font-weight: 500; color: color-mix(in srgb, var(--color-white) 70%, transparent); margin-left: 4px; }
  .tier__label { margin-top: var(--space-1); font-size: 0.8rem; letter-spacing: 0.1em; text-transform: uppercase; font-weight: 700; color: var(--color-white); }
  .tier--featured { background: var(--color-gold); color: var(--color-green-deep); border-color: var(--color-gold); }
  .tier--featured .tier__amount { color: var(--color-green-deep); }
  .tier--featured .tier__period { color: color-mix(in srgb, var(--color-green-deep) 70%, transparent); }
  .tier--featured .tier__label { color: var(--color-green-deep); }

  .partner__footer { margin-top: var(--space-10); display: flex; flex-wrap: wrap; align-items: center; gap: var(--space-5); justify-content: center; }
  .partner__alt { color: var(--color-gold); text-decoration: none; font-weight: 700; font-size: 0.95rem; }

  /* ===== PRAY BAND ===== */
  .pray-cta__grid { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-10); align-items: center; }
  @media (max-width: 900px) { .pray-cta__grid { grid-template-columns: 1fr; } }
  .pray-cta__photo {
    aspect-ratio: 4 / 3;
    background-size: cover;
    background-position: center;
    border-radius: var(--radius-card);
    box-shadow: 0 12px 30px rgba(11, 64, 36, 0.15);
  }
  .pray-cta__copy h2 { margin: 0 0 var(--space-4); color: var(--color-green-deep); }
  .pray-cta__copy p { color: var(--color-ink-soft); margin: 0 0 var(--space-6); line-height: 1.6; }

  /* ===== TRUST BAND ===== */
  .trust-band__grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--space-6); }
  @media (max-width: 900px) { .trust-band__grid { grid-template-columns: 1fr; } }
  .trust-card {
    background: var(--color-cream);
    padding: var(--space-7);
    border-radius: var(--radius-card);
    text-align: center;
    display: flex; flex-direction: column; align-items: center;
    gap: var(--space-3);
    border-top: 4px solid var(--color-gold);
  }
  .trust-card__badge { height: 120px; width: auto; }
  .trust-card h3 { margin: 0; color: var(--color-green-deep); font-size: 1.1rem; }
  .trust-card p { margin: 0; color: var(--color-ink-soft); font-size: 0.92rem; line-height: 1.5; }
  .trust-card a { color: var(--color-green); font-weight: 700; font-size: 0.88rem; text-decoration: underline; }

  /* ===== INLINE GIVE ===== */
  .inline-give { color: var(--color-white); padding-top: var(--space-12); padding-bottom: var(--space-12); }
