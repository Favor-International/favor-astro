---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteHeader from '../components/global/SiteHeader.astro';
import SiteFooter from '../components/global/SiteFooter.astro';
import { PILLARS, PARTNER_TIERS, SITE } from '../lib/site';
import { CTA } from '../lib/cta';

// Pillar imagery (each pillar has its own distinct photo).
const pillarImages: Record<string, string> = {
  'evangelism-discipleship': '/images/pillar-evangelism-discipleship.jpg',
  'education': '/images/pillar-education.jpg',
  'community-development': '/images/pillar-community-care.jpg',
  'economic-empowerment': '/images/pillar-economic-empowerment.jpg',
};

// Real published stories from the Webflow CMS (Stories.csv).
const featuredStories = [
  {
    title: '"More Bibles for Ethiopia, please!"',
    country: 'Ethiopia',
    excerpt: 'After two months of Portable Bible Schools in Ethiopia, field teachers graduated 763 students, led 112 to salvation, and baptized 57. Then they ran out of Bibles.',
    image: '/images/stories/more-bibles-for-ethiopia-please.jpg',
    href: '/stories/more-bibles-for-ethiopia-please/',
  },
  {
    title: 'Daniel Kidia',
    country: 'South Sudan',
    excerpt: 'A former Mundari cattle warrior, now a Favor field pastor leading PBS classes among his own people. A PBS testimony.',
    image: '/images/stories/daniel-kidia.jpg',
    href: '/stories/daniel-kidia/',
  },
  {
    title: 'Goats for Women',
    country: 'Uganda',
    excerpt: 'Women of Puranga praised and worshipped God as they waited to receive two goats each, the fruit of a year of Women’s Empowerment training.',
    image: '/images/stories/goats-for-women.jpg',
    href: '/stories/goats-for-women/',
  },
];

---
<BaseLayout
  title={`${SITE.name} — ${SITE.tagline}`}
  description="Favor International equips indigenous African leaders to advance the Gospel through Portable Bible Schools, the GIFT Institute, education, medical care, church planting, and economic empowerment. ECFA-accredited. Carole Ward, Founder."
  image="/images/pillar-evangelism-discipleship.jpg"
>
  <SiteHeader variant="transparent" />
  <main id="main">

    <!-- BAND 1: Hero — full-bleed photo + dark-green-on-left gradient (inspiration spec) -->
    <section class="hero hero--fullbleed" aria-label="Send a pastor where the gospel has not reached">
      <div class="hero__bg" style="background-image: url(/images/hero-pastor-preaching.jpg)" aria-hidden="true"></div>
      <div class="hero__scrim" aria-hidden="true"></div>
      <div class="hero__inner container">
        <div class="hero__copy">
          <p class="hero__eyebrow">Where others will not go</p>
          <h1 class="hero__h1">Send a pastor where the gospel has not reached.</h1>
          <p class="hero__sub">Indigenous missionaries equipped and sent into 14 nations across East and Central Africa.</p>
          <div class="hero__cta">
            <a class="btn btn--primary btn--large hero__primary" href="/give/partner-monthly/">{CTA.partnerMonthly} <span aria-hidden="true">&rarr;</span></a>
          </div>
          <ul class="hero__trust">
            <li class="hero__trust-item hero__trust-item--badge">
              <span class="hero__trust-ecfa">ECFA</span>
            </li>
            <li class="hero__trust-divider" aria-hidden="true"></li>
            <li class="hero__trust-item">501(c)(3)</li>
            <li class="hero__trust-divider" aria-hidden="true"></li>
            <li class="hero__trust-item">On the field since 2002</li>
          </ul>
        </div>
      </div>
    </section>

    <!-- BAND 2: Scripture pause-beat — white, centered, gold rule above, no em-dashes -->
    <section class="scripture-band">
      <div class="container container--narrow scripture-band__inner">
        <span class="scripture-band__rule scripture-band__rule--gold" aria-hidden="true"></span>
        <blockquote class="scripture-band__quote">
          &ldquo;{SITE.scripture.text}&rdquo;
        </blockquote>
        <p class="scripture-band__cite">JOHN 9:4 &middot; AMPC</p>
        <span class="scripture-band__rule scripture-band__rule--sage" aria-hidden="true"></span>
      </div>
    </section>

    <!-- BAND 3: What you make possible — white, photo-on-top pillar cards -->
    <section class="pillars-band">
      <div class="container">
        <header class="pillars-band__header">
          <p class="eyebrow">Where your partnership goes</p>
          <h2>Four fronts. One Gospel.</h2>
          <span class="gold-underline" aria-hidden="true"></span>
          <p class="pillars-band__lede">You fund four kinds of work at once. A pastor in a village no missions agency will enter. A child learning to read at a Favor school. A widow with a goat. A clinic with antibiotics on the shelf.</p>
        </header>
        <div class="pillars-band__grid">
          {PILLARS.map((p) => (
            <a class="pillar-card" href={`/impact/${p.slug}/`}>
              <div class="pillar-card__photo" style={`background-image: url(${pillarImages[p.slug]})`} role="img" aria-label={p.label}></div>
              <div class="pillar-card__body">
                <h3 class="pillar-card__title">{p.label}</h3>
                <p class="pillar-card__blurb">{p.blurb}</p>
                <span class="pillar-card__cta">See this work &rarr;</span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- BAND 4: Proof strip — sage-light, 3 ECFA-audited numbers, icon + card -->
    <section class="proof-band">
      <div class="container">
        <header class="proof-band__header">
          <p class="eyebrow eyebrow--green">The receipts</p>
          <h2>Your dollar reaches the field.</h2>
          <p class="proof-band__lede">You can trust where the money goes. Favor International has been ECFA-accredited since 2019 and rated four stars by Charity Navigator.</p>
        </header>
        <ul class="proof-band__grid">
          <li class="proof-stat">
            <span class="proof-stat__icon" aria-hidden="true">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 2v20M5 9l7-7 7 7"/>
                <path d="M5 21h14"/>
              </svg>
            </span>
            <span class="proof-stat__value">89%</span>
            <span class="proof-stat__label">to the field</span>
            <span class="proof-stat__note">FY2024 program ratio, audited</span>
          </li>
          <li class="proof-stat">
            <span class="proof-stat__icon" aria-hidden="true">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"/>
                <path d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
              </svg>
            </span>
            <span class="proof-stat__value">14</span>
            <span class="proof-stat__label">nations reached</span>
            <span class="proof-stat__note">East and Central Africa</span>
          </li>
          <li class="proof-stat">
            <span class="proof-stat__icon" aria-hidden="true">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                <rect x="2" y="6" width="20" height="12" rx="2"/>
                <circle cx="12" cy="12" r="2"/>
                <path d="M6 12h.01M18 12h.01"/>
              </svg>
            </span>
            <span class="proof-stat__value">$8.36M</span>
            <span class="proof-stat__label">FY2024 revenue</span>
            <span class="proof-stat__note">Filed Form 990, ECFA, Candid</span>
          </li>
        </ul>
        <p class="proof-band__sources">
          Sources: <a href={SITE.trust.ecfa} target="_blank" rel="noopener">ECFA</a> ·
          <a href={SITE.trust.charityNavigator} target="_blank" rel="noopener">Charity Navigator</a> ·
          <a href={SITE.trust.candid} target="_blank" rel="noopener">Candid</a>
        </p>
      </div>
    </section>

    <!-- BAND 5: Stories from the field — white, real story photos breathing -->
    <section class="stories-band">
      <div class="container">
        <header class="stories-band__header">
          <div>
            <p class="eyebrow">Stories from the field</p>
            <h2>Real names. Real places.</h2>
            <p class="stories-band__lede">You can read the names of the pastors, women, and children your partnership is sending us to.</p>
          </div>
          <a class="stories-band__all" href="/stories/">All stories &rarr;</a>
        </header>
        <div class="stories-band__grid">
          {featuredStories.map((s) => (
            <a class="story-card" href={s.href}>
              <div class="story-card__photo" style={`background-image: url(${s.image})`} role="img" aria-label={s.title}></div>
              <div class="story-card__body">
                <span class="story-card__country">{s.country}</span>
                <h3 class="story-card__title">{s.title}</h3>
                <p class="story-card__excerpt">{s.excerpt}</p>
                <span class="story-card__cta">Read the story &rarr;</span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- BAND 6: Partner — white outer, contained green inset card -->
    <section class="partner-band" id="partner">
      <div class="container">
        <div class="partner-card">
          <div class="partner-card__copy">
            <p class="eyebrow eyebrow--gold">Become a Favor Partner</p>
            <h2 class="partner-card__h2">$40 a month sends a pastor.</h2>
            <span class="gold-underline gold-underline--bright" aria-hidden="true"></span>
            <p class="partner-card__body">You can keep a Favor pastor on the trail in a place no other ministry will go. Pick a monthly tier, or set your own amount. Every gift is tax-deductible. ECFA-accredited since 2019.</p>
            <a class="btn btn--primary btn--large partner-card__cta" href="/give/partner-monthly/">{CTA.partnerMonthly}</a>
            <p class="partner-card__pray">Or pray with us: <a href="/pray/30-day-guide/">get the 30-day guide &rarr;</a></p>
          </div>
          <div class="partner-card__tiers">
            <p class="partner-card__tiers-label">Suggested monthly tiers</p>
            {PARTNER_TIERS.map((t) => (
              <a class:list={['partner-tier', t.featured && 'partner-tier--featured']} href={`/give/partner-monthly/?amount=${t.amount}`}>
                {t.featured && <span class="partner-tier__badge">Most chosen</span>}
                <span class="partner-tier__amount">${t.amount}<span class="partner-tier__period">/mo</span></span>
                <span class="partner-tier__label">{t.label}</span>
              </a>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- BAND 7: Trust signals — cream, ECFA + Charity Navigator + Candid -->
    <section class="trust-band">
      <div class="container">
        <header class="trust-band__header">
          <p class="eyebrow eyebrow--green">Accountability</p>
          <h2>You can verify every dollar.</h2>
          <p class="trust-band__lede">You don't have to take our word for it. Three independent watchdogs audit Favor's books and stewardship every year.</p>
        </header>
        <div class="trust-band__grid">
          <article class="trust-card">
            <img class="trust-card__badge" src="/images/trust/ecfa.png" alt="ECFA Accredited" width="96" height="96" />
            <h3>ECFA-accredited since 2019</h3>
            <p>Favor International has been a member of the Evangelical Council for Financial Accountability since September 30, 2019. ECFA holds members to a public standard of stewardship and disclosure.</p>
            <a href={SITE.trust.ecfa} target="_blank" rel="noopener">View our ECFA profile &rarr;</a>
          </article>
          <article class="trust-card">
            <img class="trust-card__badge" src="/images/trust/charity-navigator.svg" alt="Charity Navigator Four-Star" width="96" height="96" />
            <h3>Four-Star Charity Navigator rating</h3>
            <p>Charity Navigator scores nonprofits on financial health, accountability, and transparency. Favor holds the Four-Star rating, the highest tier.</p>
            <a href={SITE.trust.charityNavigator} target="_blank" rel="noopener">View our Charity Navigator profile &rarr;</a>
          </article>
          <article class="trust-card">
            <img class="trust-card__badge" src="/images/trust/candid-platinum.svg" alt="Candid Platinum Transparency Seal" width="96" height="96" />
            <h3>Candid Platinum transparency seal</h3>
            <p>Candid (formerly Guidestar) verifies nonprofit transparency at four tiers. Favor holds the Platinum tier, the highest.</p>
            <p class="trust-card__ein">EIN 47-5225697 &middot; FY2024 Form 990</p>
            <a href={SITE.trust.candid} target="_blank" rel="noopener">View our Candid profile &rarr;</a>
          </article>
        </div>
      </div>
    </section>

  </main>
  <SiteFooter />
</BaseLayout>

<style>
  /* ===== HERO (full-bleed, copies inspiration mockup) ===== */
  .hero--fullbleed {
    position: relative;
    min-height: clamp(680px, 96vh, 920px);
    display: flex;
    align-items: center;
    color: var(--color-white);
    overflow: hidden;
    padding-top: 0;
    padding-bottom: 0;
  }
  .hero__bg {
    position: absolute; inset: 0;
    background-size: cover;
    /* Bias the crop so the pastor sits centered in his half rather than
       jammed against the top-right corner. */
    background-position: 70% 65%;
    z-index: 0;
  }
  .hero__scrim {
    position: absolute; inset: 0;
    z-index: 1;
    /* Deep-green gradient: opaque on the left where text lives, fully clear
       on the right so the pastor's face and the warm sunset breathe. */
    background:
      linear-gradient(90deg,
        rgba(11, 64, 36, 0.96) 0%,
        rgba(11, 64, 36, 0.92) 28%,
        rgba(11, 64, 36, 0.55) 52%,
        rgba(11, 64, 36, 0.10) 72%,
        rgba(11, 64, 36, 0) 100%);
  }
  .hero__inner {
    position: relative;
    z-index: 2;
    width: 100%;
    padding-top: 120px;
    padding-bottom: var(--space-12);
  }
  .hero__copy {
    max-width: 720px;
  }
  .hero__eyebrow {
    margin: 0 0 var(--space-5) 0;
    font-size: 0.85rem;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    font-weight: 700;
    color: var(--color-gold);
  }
  .hero__h1 {
    margin: 0 0 var(--space-6) 0;
    font-size: clamp(2.5rem, 5.6vw, 4.6rem);
    font-weight: 800;
    line-height: 1.04;
    letter-spacing: -0.02em;
    color: var(--color-white);
    /* Force 3-line break to match mockup: "Send a pastor / where the gospel
       / has not reached." Narrower than the copy column so subhead can still
       breathe. */
    max-width: 14ch;
  }
  .hero__sub {
    margin: 0 0 var(--space-8) 0;
    font-size: clamp(1.05rem, 1.4vw, 1.2rem);
    line-height: 1.5;
    color: color-mix(in srgb, var(--color-white) 92%, transparent);
    max-width: 48ch;
  }
  .hero__cta {
    margin-bottom: var(--space-10);
  }
  .hero__primary {
    border-radius: 999px;
    padding: 20px 36px;
    font-size: 1.05rem;
    box-shadow: 0 18px 40px rgba(0, 0, 0, 0.25);
    gap: var(--space-3);
  }
  .hero__primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 22px 48px rgba(0, 0, 0, 0.32);
  }
  .hero__trust {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    align-items: center;
    gap: var(--space-4);
    flex-wrap: wrap;
  }
  .hero__trust-item {
    font-size: 0.82rem;
    letter-spacing: 0.06em;
    font-weight: 600;
    color: color-mix(in srgb, var(--color-white) 86%, transparent);
  }
  .hero__trust-item--badge {
    width: 44px; height: 44px;
    border: 2px solid color-mix(in srgb, var(--color-white) 70%, transparent);
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
  }
  .hero__trust-ecfa {
    font-size: 0.7rem;
    font-weight: 800;
    letter-spacing: 0.04em;
    color: var(--color-white);
  }
  .hero__trust-divider {
    width: 1px; height: 20px;
    background: color-mix(in srgb, var(--color-white) 35%, transparent);
  }
  @media (max-width: 900px) {
    .hero__inner { padding-top: 110px; }
    .hero__scrim {
      background: linear-gradient(180deg,
        rgba(11, 64, 36, 0.65) 0%,
        rgba(11, 64, 36, 0.82) 40%,
        rgba(11, 64, 36, 0.94) 100%);
    }
  }
  @media (max-width: 720px) {
    .hero--fullbleed { min-height: 600px; }
    .hero__h1 { font-size: clamp(2rem, 8vw, 2.8rem); }
  }
  /* ===== SHARED HELPERS ===== */
  .eyebrow {
    margin: 0 0 var(--space-3) 0;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-sage);
  }
  .eyebrow--gold { color: var(--color-gold); }
  .eyebrow--green { color: var(--color-green-deep); }
  .gold-underline {
    display: inline-block;
    width: 56px;
    height: 3px;
    background: var(--color-gold);
    margin: var(--space-4) auto;
    border-radius: 2px;
  }
  .gold-underline--bright { background: var(--color-gold); margin: var(--space-3) 0; }

  /* ===== BAND 2: SCRIPTURE PAUSE-BEAT (white) ===== */
  .scripture-band {
    background: var(--color-white);
    padding: var(--space-14) 0;
  }
  .scripture-band__inner {
    text-align: center;
    display: flex; flex-direction: column; align-items: center;
    gap: var(--space-6);
  }
  .scripture-band__rule {
    width: 64px; height: 2px; display: block;
  }
  .scripture-band__rule--gold { background: var(--color-gold); }
  .scripture-band__rule--sage { background: color-mix(in srgb, var(--color-sage) 50%, transparent); }
  .scripture-band__quote {
    margin: 0;
    max-width: 56ch;
    font-size: clamp(1.35rem, 2.4vw, 1.75rem);
    line-height: 1.45;
    color: var(--color-green-deep);
    font-weight: 500;
    quotes: none;
    border: none;
    padding: 0;
  }
  .scripture-band__cite {
    margin: 0;
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.22em;
    color: var(--color-sage);
  }

  /* ===== BAND 3: PILLARS (white, photo-on-top card) ===== */
  .pillars-band {
    background: var(--color-white);
    padding: var(--space-14) 0;
  }
  .pillars-band__header {
    text-align: center;
    max-width: 720px;
    margin: 0 auto var(--space-12) auto;
  }
  .pillars-band__header h2 {
    margin: 0;
    font-size: clamp(2rem, 3.6vw, 2.75rem);
    color: var(--color-green-deep);
    line-height: 1.1;
    font-weight: 800;
    letter-spacing: -0.01em;
  }
  .pillars-band__lede {
    margin: var(--space-5) auto 0 auto;
    color: var(--color-ink-soft);
    font-size: 1.05rem;
    line-height: 1.6;
    max-width: 60ch;
  }
  .pillars-band__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-6);
  }
  @media (max-width: 1100px) { .pillars-band__grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 540px) { .pillars-band__grid { grid-template-columns: 1fr; } }
  .pillar-card {
    display: flex; flex-direction: column;
    background: var(--color-white);
    border-radius: 12px;
    overflow: hidden;
    text-decoration: none;
    color: var(--color-ink);
    border: 1px solid color-mix(in srgb, var(--color-sage) 30%, transparent);
    transition: transform 200ms, box-shadow 200ms, border-color 200ms;
  }
  .pillar-card:hover {
    transform: translateY(-4px);
    border-color: var(--color-gold);
    box-shadow: 0 18px 36px rgba(11, 64, 36, 0.12);
  }
  .pillar-card__photo {
    aspect-ratio: 4 / 3;
    background-size: cover;
    background-position: center;
  }
  .pillar-card__body {
    padding: var(--space-6);
    display: flex; flex-direction: column;
    gap: var(--space-3);
    flex: 1;
  }
  .pillar-card__title {
    margin: 0;
    color: var(--color-green-deep);
    font-size: 1.15rem;
    font-weight: 700;
    line-height: 1.25;
  }
  .pillar-card__blurb {
    margin: 0;
    color: var(--color-ink-soft);
    font-size: 0.92rem;
    line-height: 1.55;
    flex: 1;
  }
  .pillar-card__cta {
    color: var(--color-green-deep);
    font-weight: 700;
    font-size: 0.9rem;
    margin-top: auto;
  }

  /* ===== BAND 4: PROOF STRIP (sage-light, icon+stat cards) ===== */
  .proof-band {
    background: #d8dfd2;
    padding: var(--space-14) 0;
  }
  .proof-band__header {
    text-align: center;
    margin-bottom: var(--space-10);
    max-width: 720px;
    margin-left: auto; margin-right: auto;
  }
  .proof-band__header h2 {
    margin: 0;
    font-size: clamp(1.8rem, 3.4vw, 2.4rem);
    color: var(--color-green-deep);
    line-height: 1.1;
    font-weight: 800;
  }
  .proof-band__lede {
    margin: var(--space-4) auto 0 auto;
    color: var(--color-ink);
    font-size: 1.0rem;
    line-height: 1.55;
    max-width: 56ch;
  }
  .proof-band__grid {
    list-style: none; padding: 0; margin: 0;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-5);
  }
  @media (max-width: 800px) {
    .proof-band__grid { grid-template-columns: 1fr; gap: var(--space-4); }
  }
  .proof-stat {
    display: flex; flex-direction: column;
    align-items: flex-start;
    gap: var(--space-2);
    padding: var(--space-7) var(--space-6);
    background: var(--color-white);
    border-radius: 12px;
    border-left: 4px solid var(--color-gold);
    box-shadow: 0 2px 12px rgba(11, 64, 36, 0.06);
  }
  .proof-stat__icon {
    display: inline-flex;
    width: 48px; height: 48px;
    align-items: center; justify-content: center;
    border-radius: 10px;
    background: color-mix(in srgb, var(--color-gold) 18%, var(--color-white));
    color: var(--color-green-deep);
    margin-bottom: var(--space-2);
  }
  .proof-stat__value {
    font-size: clamp(2.6rem, 5vw, 3.6rem);
    font-weight: 800;
    color: var(--color-green-deep);
    line-height: 1;
    letter-spacing: -0.02em;
  }
  .proof-stat__label {
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-green-deep);
  }
  .proof-stat__note {
    font-size: 0.78rem;
    letter-spacing: 0.06em;
    color: var(--color-sage);
    font-weight: 600;
    margin-top: var(--space-1);
  }
