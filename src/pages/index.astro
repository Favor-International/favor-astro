---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteHeader from '../components/global/SiteHeader.astro';
import SiteFooter from '../components/global/SiteFooter.astro';
import { SITE } from '../lib/site';
import { CTA } from '../lib/cta';

// =====================================================================
// HOMEPAGE v13 — implements the nonprofit-best-practices review.
// Partner-as-hero voice ("you" before "we"). Tight partner journey:
// attract -> inform -> engage -> give. 9 bands. Trust signals + impact
// proof inline with the asks, not buried in the footer.
// =====================================================================

// The featured impact story sits next to the 2025 numbers band so a
// real name + place + outcome anchors the statistics (research shows
// one story + statistics outperforms either alone).
const featuredStory = {
  title: '"More Bibles for Ethiopia, please!"',
  excerpt: 'After two months of Portable Bible Schools, field teachers graduated 763 students, led 112 to salvation, and baptized 57. Then they ran out of Bibles. A partner answered.',
  href: '/stories/more-bibles-for-ethiopia-please/',
  image: '/images/stories/more-bibles-for-ethiopia-please.jpg',
  attribution: 'Field report · Ethiopia',
};

// Two more lead stories used in the trimmed featured grid (replaces
// the 25-card masonry that overwhelmed the page per review).
const leadStories = [
  {
    title: 'Daniel Kidia',
    country: 'South Sudan',
    excerpt: 'A former Mundari cattle warrior, now a Favor field pastor leading PBS classes among his own people.',
    href: '/stories/daniel-kidia/',
    image: '/images/stories/daniel-kidia.jpg',
  },
  {
    title: 'Goats for Women',
    country: 'Uganda',
    excerpt: 'Women of Puranga praised and worshiped God as they waited to receive two goats each, the fruit of a year of empowerment training.',
    href: '/stories/goats-for-women/',
    image: '/images/stories/goats-for-women.jpg',
  },
];

const ministries = [
  { name: 'Evangelism & Discipleship', href: '/impact/evangelism-discipleship/', image: '/images/pillar-evangelism-discipleship.jpg', alt: 'Two field pastors standing in a flooded field after a Portable Bible School.', blurb: 'You send Portable Bible Schools, the GIFT Institute, House of Prayer, and Favor FM into villages where no other ministry will go.' },
  { name: 'Education',                  href: '/impact/education/',                  image: '/images/pillar-education.jpg',                  alt: 'Children seated in blue plastic chairs at a Village Learning Center in South Sudan.',   blurb: 'You fund Village Learning Centers, Favor Primary, Favor Secondary, and the Leadership Training Institute across East Africa.' },
  { name: 'Community Development',      href: '/impact/community-development/',      image: '/images/pillar-community-care.jpg',             alt: 'A Favor field worker shares a meal with two men in a community-care setting.',          blurb: 'You fund trauma counseling, medical care, church planting, and church construction in places no other ministry will go.' },
  { name: 'Economic Empowerment',       href: '/impact/economic-empowerment/',       image: '/images/pillar-economic-empowerment.jpg',       alt: 'A Favor empowerment program participant weighing red onions for sale.',                 blurb: 'You start sustainability projects, women\'s empowerment cohorts, and vocational training that move a whole village off relief.' },
];
---
<BaseLayout
  title={SITE.name}
  description="You can send an indigenous pastor where the gospel has not reached. Favor International trains and deploys local church planters across 14 nations of East and Central Africa. ECFA-accredited. Carole Ward, Founder."
  image="/images/hero-pastor-preaching.jpg"
>
  <SiteHeader variant="transparent" />
  <main id="main">

    <!-- ====================================================
         BAND 1 — HERO (partner-centric H1, subheadline, single CTA)
         ==================================================== -->
    <section class="hero hero--fullbleed" aria-label="You can send a pastor where the gospel has not reached">
      <div class="hero__bg" style="background-image: url(/images/hero-pastor-preaching.jpg)" role="img" aria-label="An indigenous African pastor in a white tunic preaching to a seated congregation under a tree at golden hour."></div>
      <div class="hero__scrim" aria-hidden="true"></div>
      <div class="hero__inner container">
        <div class="hero__copy">
          <p class="hero__eyebrow">Where others will not go</p>
          <h1 class="hero__h1">You can send an indigenous pastor where the gospel has not reached.</h1>
          <p class="hero__sub">Train and equip local church planters to plant churches and transform communities across 14 nations of East and Central Africa.</p>
          <div class="hero__cta">
            <a class="btn btn--primary btn--large hero__primary" href="/give/partner-monthly/">{CTA.partnerMonthly} <span aria-hidden="true">&rarr;</span></a>
          </div>
          <ul class="hero__trust">
            <li class="hero__trust-item hero__trust-item--badge"><span class="hero__trust-ecfa">ECFA</span></li>
            <li class="hero__trust-divider" aria-hidden="true"></li>
            <li class="hero__trust-item">501(c)(3)</li>
            <li class="hero__trust-divider" aria-hidden="true"></li>
            <li class="hero__trust-item">On the field since 2002</li>
          </ul>
        </div>
      </div>
    </section>

    <!-- ====================================================
         BAND 2 — IMPACT NUMBERS + ONE FEATURED STORY
         (review: stats alone don't connect — pair with one real
         name, place, outcome to anchor the numbers)
         ==================================================== -->
    <section class="impact-story">
      <div class="container impact-story__grid">
        <div class="impact-story__stats">
          <p class="eyebrow">2025 highlights</p>
          <h2 class="impact-story__h2">Your support is raising the next generation of missionary leaders.</h2>
          <ul class="impact-story__numbers">
            <li>
              <span class="impact-story__value">195,773</span>
              <span class="impact-story__label">Came to Christ</span>
            </li>
            <li>
              <span class="impact-story__value">119,182</span>
              <span class="impact-story__label">Discipled</span>
            </li>
          </ul>
          <p class="impact-story__source">Per Favor's 2025 field-team reports.</p>
        </div>
        <figure class="impact-story__feature">
          <a class="impact-story__link" href={featuredStory.href}>
            <div class="impact-story__photo" style={`background-image: url(${featuredStory.image})`} aria-hidden="true"></div>
            <figcaption class="impact-story__caption">
              <span class="impact-story__chip">{featuredStory.attribution}</span>
              <h3 class="impact-story__title">{featuredStory.title}</h3>
              <p class="impact-story__excerpt">{featuredStory.excerpt}</p>
              <span class="impact-story__cta">Read the story &rarr;</span>
            </figcaption>
          </a>
        </figure>
      </div>
    </section>

    <!-- ====================================================
         BAND 3 — VISION & MISSION (verbatim Favor copy)
         ==================================================== -->
    <section class="vm">
      <div class="container vm__grid">
        <div class="vm__block">
          <p class="eyebrow">Our Vision</p>
          <h2 class="vm__vision">Transformed Hearts Transform Nations.</h2>
        </div>
        <div class="vm__block">
          <p class="eyebrow">Our Mission</p>
          <p class="vm__mission">
            Transforming nations with the power of the Gospel through prayer movements and indigenous missionary movements which are accelerating the fulfillment of the Great Commission to unreached people groups, and into every area of society from grassroots to governments.
          </p>
          <a class="vm__link" href="/about/mission-vision/">Read the full mission &amp; vision &rarr;</a>
        </div>
      </div>
    </section>

    <!-- ====================================================
         BAND 4 — WHAT WE DO (4 ministry pillars, partner voice)
         ==================================================== -->
    <section class="whatwedo">
      <div class="container">
        <header class="whatwedo__header">
          <p class="eyebrow">What your partnership does</p>
          <h2 class="whatwedo__h2">Four ministries. One Kingdom outcome.</h2>
        </header>
        <div class="whatwedo__grid">
          {ministries.map((m) => (
            <a class="ministry" href={m.href}>
              <figure class="ministry__photo">
                <img src={m.image} alt={m.alt} loading="lazy" />
              </figure>
              <div class="ministry__body">
                <h3 class="ministry__name">{m.name}</h3>
                <p class="ministry__blurb">{m.blurb}</p>
                <span class="ministry__cta">See this work &rarr;</span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- ====================================================
         BAND 5 — BECOME A FAVOR PARTNER (monthly giving)
         Per review: "Insert a full-width band inviting visitors
         to join the monthly giving community." Mid-page lead path.
         ==================================================== -->
    <section class="partner" id="partner">
      <div class="container partner__grid">
        <div class="partner__copy">
          <p class="eyebrow eyebrow--gold">Become a Favor Partner</p>
          <h2 class="partner__h2">Your monthly partnership keeps an indigenous pastor on the trail.</h2>
          <p class="partner__lede">You don't have to fly to East Africa to send the Gospel there. A Favor Partner gift, given monthly, equips and feeds the field worker who already lives in the village no other ministry will go to.</p>
          <a class="btn btn--primary btn--large partner__cta" href="/give/partner-monthly/">{CTA.partnerMonthly} <span aria-hidden="true">&rarr;</span></a>
          <p class="partner__line">Tax-deductible. <a href="/about/accountability/">ECFA-accredited since 2019.</a></p>
        </div>
        <figure class="partner__photo">
          <img src="/images/partner-with-us.jpg" alt="A Favor field worker shares a meal with two men in a community gathering." loading="lazy" />
        </figure>
      </div>
    </section>

    <!-- ====================================================
         BAND 6 — JOHN 9:4 SCRIPTURE PAUSE
         ==================================================== -->
    <section class="scripture">
      <div class="container container--narrow scripture__inner">
        <span class="scripture__rule" aria-hidden="true"></span>
        <blockquote class="scripture__quote">
          "We must work the works of Him Who sent Me and be busy with His business while it is daylight; night is coming on, when no man can work."
        </blockquote>
        <p class="scripture__cite">JOHN 9:4 &middot; AMPC</p>
      </div>
    </section>

    <!-- ====================================================
         BAND 7 — PRAY + GO (split panel; the two non-give CTAs)
         Per review: many visitors aren't ready to give. Offer
         prayer + vision-trip options to keep them engaged.
         ==================================================== -->
    <section class="praygo">
      <div class="container praygo__grid">
        <a class="praygo__panel praygo__panel--pray" href="/pray/30-day-guide/">
          <div class="praygo__bg" style="background-image: url(/images/ministry-house-of-prayer.jpg)" aria-hidden="true"></div>
          <div class="praygo__scrim praygo__scrim--green" aria-hidden="true"></div>
          <div class="praygo__copy">
            <p class="praygo__eyebrow">Pray with us</p>
            <h3 class="praygo__h3">You can pray where they cannot reach.</h3>
            <p class="praygo__sub">One specific request per day across the 14 nations Favor serves. Free PDF. No signup.</p>
            <span class="praygo__cta">Get the 30-Day Prayer Guide <span aria-hidden="true">&rarr;</span></span>
          </div>
        </a>
        <a class="praygo__panel praygo__panel--go" href="/go/vision-trips/">
          <div class="praygo__bg" style="background-image: url(/images/story-vision-trip-team.jpg)" aria-hidden="true"></div>
          <div class="praygo__scrim praygo__scrim--terracotta" aria-hidden="true"></div>
          <div class="praygo__copy">
            <p class="praygo__eyebrow">Walk with us</p>
            <h3 class="praygo__h3">You can see the work for yourself.</h3>
            <p class="praygo__sub">Small-team vision trips to Uganda, South Sudan, and Ethiopia. Spring and Fall 2026.</p>
            <span class="praygo__cta">See open vision trips <span aria-hidden="true">&rarr;</span></span>
          </div>
        </a>
      </div>
    </section>

    <!-- ====================================================
         BAND 8 — TWO MORE FEATURED STORIES + LINK TO ALL
         Per review: replace 25-card grid with 1-2 highlighted
         stories with name + place + outcome. Then a "see all".
         ==================================================== -->
    <section class="stories">
      <div class="container">
        <header class="stories__header">
          <div>
            <p class="eyebrow">Stories of transformation</p>
            <h2 class="stories__h2">Real names. Real places. Real outcomes.</h2>
          </div>
          <a class="stories__all" href="/stories/">See all 265 stories &rarr;</a>
        </header>
        <div class="stories__grid">
          {leadStories.map((s) => (
            <a class="story-card" href={s.href}>
              <figure class="story-card__photo">
                <img src={s.image} alt={s.title} loading="lazy" />
              </figure>
              <div class="story-card__body">
                <span class="story-card__country">{s.country}</span>
                <h3 class="story-card__title">{s.title}</h3>
                <p class="story-card__excerpt">{s.excerpt}</p>
                <span class="story-card__cta">Read the story &rarr;</span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- ====================================================
         BAND 9 — ACCOUNTABILITY (real trust badges + Florida)
         Per review: surface trust signals + leadership near the
         conversion moment, not buried in the footer alone.
         ==================================================== -->
    <section class="trust">
      <div class="container">
        <header class="trust__head">
          <p class="eyebrow eyebrow--green">Accountability you can verify</p>
          <h2 class="trust__h2">You can see exactly where your dollar goes.</h2>
          <p class="trust__lede">Favor International is audited every year by three independent watchdogs and registered with the State of Florida. Click any badge to see our public profile.</p>
        </header>
        <div class="trust__grid">
          <a class="trust-tile" href={SITE.trust.ecfa} target="_blank" rel="noopener">
            <img src="/images/trust/ecfa.png" alt="ECFA Accredited" loading="lazy" />
            <div class="trust-tile__copy">
              <h3>ECFA-accredited since 2019</h3>
              <p>Evangelical Council for Financial Accountability member since September 30, 2019.</p>
              <span class="trust-tile__link">View ECFA profile &rarr;</span>
            </div>
          </a>
          <a class="trust-tile" href={SITE.trust.charityNavigator} target="_blank" rel="noopener">
            <img src="/images/trust/charity-navigator.svg" alt="Charity Navigator Four-Star rating" loading="lazy" />
            <div class="trust-tile__copy">
              <h3>Four-Star Charity Navigator</h3>
              <p>Highest rating tier for financial health, accountability, and transparency.</p>
              <span class="trust-tile__link">View Charity Navigator profile &rarr;</span>
            </div>
          </a>
          <a class="trust-tile" href={SITE.trust.candid} target="_blank" rel="noopener">
            <img src="/images/trust/candid-platinum.svg" alt="Candid Platinum Transparency Seal" loading="lazy" />
            <div class="trust-tile__copy">
              <h3>Candid Platinum seal</h3>
              <p>Highest transparency tier on Candid (formerly GuideStar).</p>
              <span class="trust-tile__link">View Candid profile &rarr;</span>
            </div>
          </a>
        </div>
        <p class="trust__fdacs">
          A copy of the official registration and financial information for Favor International, Inc. (CH57842) may be obtained from the Florida Division of Consumer Services by visiting <a href="https://www.fdacs.gov/" target="_blank" rel="noopener">fdacs.gov</a> or calling toll-free 1-800-HELP-FLA (1-800-435-7352) within the state. Registration does not imply endorsement, approval, or recommendation by the State. Favor International, Inc. is a registered 501(c)(3) nonprofit organization. EIN {SITE.ein}.
        </p>
      </div>
    </section>

    <!-- ====================================================
         BAND 10 — FINAL CTA (single ask: become a Favor Partner)
         Per review: every page ends with one clear next step.
         ==================================================== -->
    <section class="final-cta">
      <div class="container final-cta__inner">
        <h2 class="final-cta__h2">Send a pastor today.</h2>
        <p class="final-cta__sub">Your monthly partnership equips a field pastor, feeds a Village Learning Center child, or stocks a field clinic. Pick the work. Set the amount. Cancel anytime.</p>
        <a class="btn btn--primary btn--large final-cta__btn" href="/give/partner-monthly/">{CTA.partnerMonthly} <span aria-hidden="true">&rarr;</span></a>
      </div>
    </section>

  </main>
  <SiteFooter />
</BaseLayout>

<style>
  /* ========== SHARED ========== */
  .eyebrow {
    margin: 0 0 var(--space-3) 0;
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-sage);
  }
  .eyebrow--gold  { color: var(--color-gold); }
  .eyebrow--green { color: var(--color-green-deep); }

  /* ========== HERO ========== */
  .hero--fullbleed {
    position: relative;
    min-height: clamp(680px, 96vh, 920px);
    display: flex; align-items: center;
    color: var(--color-white);
    overflow: hidden;
  }
  .hero__bg {
    position: absolute; inset: 0;
    background-size: cover;
    background-position: 50% 50%;
    z-index: 0;
  }
  .hero__scrim {
    position: absolute; inset: 0; z-index: 1;
    background: linear-gradient(90deg,
      rgba(11, 64, 36, 0.96) 0%,
      rgba(11, 64, 36, 0.90) 28%,
      rgba(11, 64, 36, 0.55) 52%,
      rgba(11, 64, 36, 0.10) 72%,
      rgba(11, 64, 36, 0) 100%);
  }
  .hero__inner { position: relative; z-index: 2; width: 100%; padding-top: 120px; padding-bottom: var(--space-12); }
  .hero__copy  { max-width: 740px; }
  .hero__eyebrow {
    margin: 0 0 var(--space-5) 0;
    font-size: 0.85rem; letter-spacing: 0.24em;
    text-transform: uppercase; font-weight: 700;
    color: var(--color-gold);
  }
  .hero__h1 {
    margin: 0 0 var(--space-5) 0;
    font-size: clamp(2.3rem, 5.2vw, 4.2rem);
    font-weight: 800; line-height: 1.04;
    letter-spacing: -0.02em;
    color: var(--color-white);
    text-wrap: balance;
  }
  .hero__sub {
    margin: 0 0 var(--space-8) 0;
    font-size: clamp(1.05rem, 1.4vw, 1.2rem);
    line-height: 1.55;
    color: color-mix(in srgb, var(--color-white) 92%, transparent);
    max-width: 56ch;
  }
  .hero__cta { margin-bottom: var(--space-10); }
  .hero__primary {
    border-radius: 999px; padding: 20px 36px;
    font-size: 1.05rem; gap: var(--space-3);
    box-shadow: 0 18px 40px rgba(0, 0, 0, 0.25);
  }
  .hero__primary:hover { transform: translateY(-2px); box-shadow: 0 22px 48px rgba(0, 0, 0, 0.32); }
  .hero__trust { list-style: none; padding: 0; margin: 0; display: flex; align-items: center; gap: var(--space-4); flex-wrap: wrap; }
  .hero__trust-item { font-size: 0.82rem; letter-spacing: 0.06em; font-weight: 600; color: color-mix(in srgb, var(--color-white) 86%, transparent); }
  .hero__trust-item--badge {
    width: 44px; height: 44px;
    border: 2px solid color-mix(in srgb, var(--color-white) 70%, transparent);
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
  }
  .hero__trust-ecfa { font-size: 0.7rem; font-weight: 800; color: var(--color-white); letter-spacing: 0.04em; }
  .hero__trust-divider { width: 1px; height: 20px; background: color-mix(in srgb, var(--color-white) 35%, transparent); }
  @media (max-width: 900px) {
    .hero__inner { padding-top: 110px; }
    .hero__scrim { background: linear-gradient(180deg, rgba(11,64,36,0.65) 0%, rgba(11,64,36,0.82) 40%, rgba(11,64,36,0.94) 100%); }
  }

  /* ========== BAND 2 — IMPACT + STORY ========== */
  .impact-story { background: var(--color-white); padding: clamp(var(--space-12), 8vw, var(--space-16)) 0; }
  .impact-story__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(var(--space-8), 6vw, var(--space-12));
    align-items: center;
  }
  @media (max-width: 900px) { .impact-story__grid { grid-template-columns: 1fr; } }
  .impact-story__h2 {
    margin: 0 0 var(--space-6) 0;
    font-size: clamp(1.8rem, 3.6vw, 2.6rem);
    line-height: 1.15;
    color: var(--color-green-deep);
    font-weight: 800;
    letter-spacing: -0.015em;
  }
  .impact-story__numbers {
    list-style: none; padding: 0; margin: 0 0 var(--space-3) 0;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-6);
  }
  .impact-story__numbers li { display: flex; flex-direction: column; gap: 4px; }
  .impact-story__value {
    font-size: clamp(2.4rem, 5vw, 3.6rem);
    font-weight: 800;
    color: var(--color-green-deep);
    line-height: 1;
    letter-spacing: -0.03em;
  }
  .impact-story__label {
    font-size: 0.78rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    font-weight: 700;
    color: var(--color-gold);
  }
  .impact-story__source { margin: 0; color: var(--color-sage); font-size: 0.82rem; font-style: italic; }

  .impact-story__feature { margin: 0; }
  .impact-story__link {
    display: block;
    border-radius: 14px;
    overflow: hidden;
    background: var(--color-white);
    box-shadow: 0 6px 24px rgba(11, 64, 36, 0.10);
    text-decoration: none;
    color: var(--color-ink);
    transition: transform 220ms, box-shadow 220ms;
  }
  .impact-story__link:hover { transform: translateY(-3px); box-shadow: 0 18px 40px rgba(11, 64, 36, 0.16); }
  .impact-story__photo { aspect-ratio: 16 / 10; background-size: cover; background-position: center; }
  .impact-story__caption { padding: var(--space-6); display: flex; flex-direction: column; gap: var(--space-2); }
  .impact-story__chip {
    align-self: flex-start;
    background: color-mix(in srgb, var(--color-gold) 18%, var(--color-white));
    color: var(--color-green-deep);
    padding: 4px 10px;
    border-radius: 999px;
    font-size: 0.7rem;
    font-weight: 800;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }
  .impact-story__title { margin: 0; color: var(--color-green-deep); font-size: 1.35rem; font-weight: 800; line-height: 1.2; }
  .impact-story__excerpt { margin: 0; color: var(--color-ink-soft); font-size: 0.95rem; line-height: 1.55; }
  .impact-story__cta { color: var(--color-green-deep); font-weight: 700; font-size: 0.9rem; border-bottom: 2px solid var(--color-gold); padding-bottom: 2px; align-self: flex-start; }

  /* ========== BAND 3 — VISION & MISSION ========== */
  .vm { background: var(--color-cream); padding: clamp(var(--space-12), 8vw, var(--space-16)) 0; }
  .vm__grid { display: grid; grid-template-columns: 1fr 1.5fr; gap: clamp(var(--space-8), 6vw, var(--space-14)); align-items: start; }
  @media (max-width: 900px) { .vm__grid { grid-template-columns: 1fr; } }
  .vm__vision {
    margin: 0;
    font-size: clamp(2rem, 4.4vw, 3.4rem);
    line-height: 1.04;
    font-weight: 800;
    color: var(--color-green-deep);
    letter-spacing: -0.018em;
  }
  .vm__mission { margin: 0 0 var(--space-6) 0; font-size: clamp(1.1rem, 1.5vw, 1.3rem); line-height: 1.65; color: var(--color-ink); font-weight: 500; }
  .vm__link { color: var(--color-green-deep); text-decoration: none; font-weight: 700; border-bottom: 2px solid var(--color-gold); padding-bottom: 2px; }
  .vm__link:hover { color: var(--color-gold); }

  /* ========== BAND 4 — WHAT WE DO ========== */
  .whatwedo { background: var(--color-white); padding: clamp(var(--space-12), 8vw, var(--space-16)) 0; }
  .whatwedo__header { text-align: center; max-width: 720px; margin: 0 auto var(--space-12) auto; }
  .whatwedo__h2 {
    margin: 0;
    font-size: clamp(1.8rem, 3.8vw, 2.6rem);
    line-height: 1.1;
    color: var(--color-green-deep);
    font-weight: 800;
    letter-spacing: -0.01em;
  }
  .whatwedo__grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: var(--space-6); }
  @media (max-width: 1100px) { .whatwedo__grid { grid-template-columns: repeat(2, 1fr); } }
