---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteHeader from '../components/global/SiteHeader.astro';
import SiteFooter from '../components/global/SiteFooter.astro';
import { PILLARS, PARTNER_TIERS, SITE } from '../lib/site';
import { CTA } from '../lib/cta';

// Pillar imagery — each pillar gets its own field photo.
const pillarImages: Record<string, string> = {
  'evangelism-discipleship': '/images/pillar-evangelism-discipleship.jpg',
  'education': '/images/pillar-education.jpg',
  'community-development': '/images/pillar-community-care.jpg',
  'economic-empowerment': '/images/pillar-economic-empowerment.jpg',
};

// 2025 highlights — verbatim from the existing favorintl.org homepage.
// Source: Favor International FY2025 field highlights.
const highlights = [
  { value: '195,773', label: 'Came to Christ' },
  { value: '119,182', label: 'Discipled' },
];
const highlightPhotos = [
  { src: '/images/highlight-saved.jpg', alt: 'New believers sitting and listening to a Favor pastor share the Gospel.' },
  { src: '/images/highlight-crowd.jpg', alt: 'A crowd of thousands gathered at a Favor revival meeting in East Africa.' },
  { src: '/images/highlight-baptism.jpg', alt: 'A woman being baptized in a Favor field outreach.' },
  { src: '/images/highlight-prayer.jpg', alt: 'A man lifting his hands in prayer at a Favor gathering.' },
];

// Featured film + 8 field videos — pulled from the Favor YouTube channel.
// Source: favor landing-pages repo, Videos.astro component.
const featuredVideo = {
  id: 'LHarkRULU7Q',
  title: 'Favor International — An Indigenous Missionary Movement',
  subtitle: '1,400 native missionaries across 14+ nations of Africa.',
  tag: 'Featured Film',
};
const videos = [
  { id: '4YpOvDoc6k4', title: 'Where Medicine Meets Miracles', subtitle: "Inside Favor's medical center in Africa.", tag: 'Medical Care' },
  { id: 'DEydcLqBQW0', title: "Favor's Primary Schools",         subtitle: 'Educated for the Kingdom.',                tag: 'Education' },
  { id: 'C5VBPhA50Mg', title: 'Evangelism in Africa',             subtitle: "Building lasting disciples through God's Word.", tag: 'Evangelism' },
  { id: 'TZmNp40_lbI', title: 'Church Planting',                  subtitle: 'The church is the body of Christ.',         tag: 'Church Planting' },
  { id: '25f290un21o', title: 'Once Under the Trees, Now a Church', subtitle: 'A village receives its sanctuary.',       tag: 'Church Building' },
  { id: 'xwSVEViFikA', title: "GIFT — God's Institute for Transformation", subtitle: 'Discipleship that transforms.',   tag: 'Discipleship' },
  { id: 'nSFl3Y7TLYI', title: 'The Power of Trauma Counseling',   subtitle: 'Healing the heart of a continent.',         tag: 'Trauma Healing' },
  { id: 'JCjHdG0NnLQ', title: 'To Reach a Village, Reach a Woman', subtitle: 'Empowering women to transform communities.', tag: "Women's Ministry" },
];
const ytThumb = (id: string, hi = true) => `https://img.youtube.com/vi/${id}/${hi ? 'maxresdefault' : 'hqdefault'}.jpg`;
const ytFallback = (id: string) => `this.onerror=null;this.src='https://img.youtube.com/vi/${id}/hqdefault.jpg'`;

// Real published stories from the CMS — homepage features 6 (was 3).
const featuredStories = [
  { title: 'More Bibles for Ethiopia, please.', country: 'Ethiopia',     excerpt: 'After two months of Portable Bible Schools, field teachers graduated 763 students, led 112 to salvation, and baptized 57. Then they ran out of Bibles.', image: '/images/stories/more-bibles-for-ethiopia-please.jpg', href: '/stories/more-bibles-for-ethiopia-please/' },
  { title: 'Daniel Kidia.',                     country: 'South Sudan',  excerpt: 'A former Mundari cattle warrior, now a Favor field pastor leading PBS classes among his own people.',                                                              image: '/images/stories/daniel-kidia.jpg',                     href: '/stories/daniel-kidia/' },
  { title: 'Goats for Women.',                  country: 'Uganda',       excerpt: 'Women of Puranga praised and worshiped God as they waited to receive two goats each, the fruit of a year of empowerment training.',                              image: '/images/stories/goats-for-women.jpg',                  href: '/stories/goats-for-women/' },
  { title: 'A Generational Shift.',              country: 'Uganda',       excerpt: 'When parents commit to Christ, the next generation is the first to see a different family.',                                                                     image: '/images/pillar-evangelism-discipleship.jpg',           href: '/stories/a-generational-shift/' },
  { title: 'Breaking Through to Chad.',         country: 'Chad',         excerpt: 'A new field pioneered. Indigenous Chadian leaders trained. The Gospel moves north.',                                                                              image: '/images/pillar-education.jpg',                         href: '/stories/breaking-through-to-chad/' },
  { title: 'Celebrating Recent Graduates.',     country: 'Kenya',        excerpt: 'Two cohorts of GIFT students graduate and head home equipped to plant, train, and disciple.',                                                                     image: '/images/ministry-gift-staff.jpg',                      href: '/stories/celebrating-recent-graduates/' },
];
---
<BaseLayout
  title={SITE.name}
  description="Favor International equips indigenous African leaders to advance the Gospel through Portable Bible Schools, the GIFT Institute, schools, medical care, church planting, and economic empowerment. ECFA-accredited. Carole Ward, Founder."
  image="/images/hero-pastor-preaching.jpg"
>
  <SiteHeader variant="transparent" />
  <main id="main">

    <!-- ====================================================
         BAND 1 — HERO (full-bleed, real Favor field photo)
         ==================================================== -->
    <section class="hero hero--fullbleed" aria-label="Send a pastor where the gospel has not reached">
      <div class="hero__bg" style="background-image: url(/images/hero-pastor-preaching.jpg)" aria-hidden="true"></div>
      <div class="hero__scrim" aria-hidden="true"></div>
      <div class="hero__inner container">
        <div class="hero__copy">
          <p class="hero__eyebrow">Where others will not go</p>
          <h1 class="hero__h1">Send a pastor where the gospel has not reached.</h1>
          <p class="hero__sub">Indigenous missionaries equipped and sent into 14 nations across East and Central Africa.</p>
          <div class="hero__cta">
            <a class="btn btn--primary btn--large hero__primary" href="/give/partner-monthly/">{CTA.partnerMonthly} <span aria-hidden="true">&rarr;</span></a>
          </div>
          <ul class="hero__trust">
            <li class="hero__trust-item hero__trust-item--badge"><span class="hero__trust-ecfa">ECFA</span></li>
            <li class="hero__trust-divider" aria-hidden="true"></li>
            <li class="hero__trust-item">501(c)(3)</li>
            <li class="hero__trust-divider" aria-hidden="true"></li>
            <li class="hero__trust-item">On the field since 2002</li>
          </ul>
        </div>
      </div>
    </section>

    <!-- ====================================================
         BAND 2 — VISION & MISSION (white, verbatim Favor)
         ==================================================== -->
    <section class="vm">
      <div class="container vm__grid">
        <div class="vm__block vm__block--vision">
          <p class="eyebrow">Our Vision</p>
          <h2 class="vm__vision">Transformed Hearts Transform Nations.</h2>
        </div>
        <div class="vm__block vm__block--mission">
          <p class="eyebrow">Our Mission</p>
          <p class="vm__mission">
            Transforming nations with the power of the Gospel through prayer movements and indigenous missionary movements which are accelerating the fulfillment of the Great Commission to unreached people groups, and into every area of society from grassroots to governments.
          </p>
          <a class="vm__link" href="/about/mission-vision/">Read the full mission &amp; vision &rarr;</a>
        </div>
      </div>
    </section>

    <!-- ====================================================
         BAND 3 — 2025 HIGHLIGHTS (white, big stats + photos)
         ==================================================== -->
    <section class="highlights">
      <div class="container">
        <header class="highlights__header">
          <p class="eyebrow">2025 Highlights</p>
          <h2>You raised up the next generation of missionary leaders.</h2>
          <p class="highlights__source">Per Favor's 2025 field-team reports.</p>
        </header>
        <div class="highlights__grid">
          {highlights.map((h) => (
            <div class="hl-stat">
              <span class="hl-stat__value">{h.value}</span>
              <span class="hl-stat__label">{h.label}</span>
            </div>
          ))}
        </div>
        <div class="highlights__photos">
          {highlightPhotos.map((p) => (
            <figure class="hl-photo">
              <img src={p.src} alt={p.alt} loading="lazy" />
            </figure>
          ))}
        </div>
      </div>
    </section>

    <!-- ====================================================
         BAND 4 — WHAT WE DO (white, 4 pillars properly spaced)
         ==================================================== -->
    <section class="pillars-band">
      <div class="container">
        <header class="pillars-band__header">
          <p class="eyebrow">What We Do</p>
          <h2>Four ministries. One Kingdom outcome.</h2>
          <p class="pillars-band__lede">You fund four kinds of work at once. A pastor in a village no missions agency will enter. A child learning to read at a Favor school. A widow with a goat. A clinic with antibiotics on the shelf.</p>
        </header>
        <div class="pillars-band__grid">
          {PILLARS.map((p) => (
            <a class="pillar-card" href={`/impact/${p.slug}/`}>
              <div class="pillar-card__photo" style={`background-image: url(${pillarImages[p.slug]})`} role="img" aria-label={p.label}></div>
              <div class="pillar-card__body">
                <h3 class="pillar-card__title">{p.label}</h3>
                <p class="pillar-card__blurb">{p.blurb}</p>
                <span class="pillar-card__cta">See this work &rarr;</span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- ====================================================
         BAND 5 — SEE THE FIELD (cream, video gallery)
         ==================================================== -->
    <section class="videos" id="videos">
      <div class="container">
        <header class="videos__head">
          <p class="eyebrow">See the Field</p>
          <h2>From the field, <em>in their own voices</em>.</h2>
          <p class="videos__lede">The Gospel meeting real lives. Medicine, education, evangelism, women's empowerment, trauma healing, church planting.</p>
        </header>

        <article
          class="video-feature"
          id="video-stage"
          data-video-id={featuredVideo.id}
          data-title={featuredVideo.title}
          data-subtitle={featuredVideo.subtitle}
          data-tag={featuredVideo.tag}
        >
          <div class="video-feature__player" id="stage-player">
            <button class="video-feature__btn" type="button" aria-label={`Play: ${featuredVideo.title}`}>
              <img class="video-feature__thumb" src={ytThumb(featuredVideo.id)} onerror={ytFallback(featuredVideo.id)} alt="" loading="eager" />
              <span class="video-feature__overlay" aria-hidden="true"></span>
              <span class="video-feature__play" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="currentColor"><polygon points="6 4 20 12 6 20 6 4"/></svg>
              </span>
            </button>
          </div>
          <div class="video-feature__caption">
            <span class="video-feature__chip" id="stage-chip">{featuredVideo.tag}</span>
            <h3 id="stage-title">{featuredVideo.title}</h3>
            <p id="stage-subtitle">{featuredVideo.subtitle}</p>
          </div>
        </article>

        <div class="video-grid">
          {videos.map((v) => (
            <article class="video-card" data-video-id={v.id} data-title={v.title} data-subtitle={v.subtitle} data-tag={v.tag}>
              <button class="video-card__btn" type="button" aria-label={`Play: ${v.title}`}>
                <img class="video-card__thumb" src={ytThumb(v.id)} onerror={ytFallback(v.id)} alt="" loading="lazy" />
                <span class="video-card__overlay" aria-hidden="true"></span>
                <span class="video-card__play" aria-hidden="true">
                  <svg viewBox="0 0 24 24" fill="currentColor"><polygon points="6 4 20 12 6 20 6 4"/></svg>
                </span>
              </button>
              <div class="video-card__meta">
                <span class="video-card__tag">{v.tag}</span>
                <h4>{v.title}</h4>
                <p>{v.subtitle}</p>
              </div>
            </article>
          ))}
        </div>

        <p class="videos__channel">
          <a href="https://www.youtube.com/@FavorIntlOrg" target="_blank" rel="noopener">See more on the Favor YouTube channel &rarr;</a>
        </p>
      </div>
    </section>

    <!-- ====================================================
         BAND 6 — STORIES (white, 6 real CMS stories)
         ==================================================== -->
    <section class="stories-band">
      <div class="container">
        <header class="stories-band__header">
          <div>
            <p class="eyebrow">Stories of Transformation</p>
            <h2>Real names. Real places.</h2>
            <p class="stories-band__lede">You can read the names of the pastors, women, and children your partnership is sending us to.</p>
          </div>
          <a class="stories-band__all" href="/stories/">All stories &rarr;</a>
        </header>
        <div class="pillars__grid">
          {PILLARS.map((p, i) => (
            <a class="pillar" href={`/impact/${p.slug}/`}>
              <div class="pillar__photo" style={`background-image: url(${pillarImages[p.slug]})`} role="img" aria-label={p.label}></div>
              <div class="pillar__scrim" aria-hidden="true"></div>
              <div class="pillar__body">
                <span class="pillar__num">0{i + 1}</span>
                <h3 class="pillar__title">{p.label}</h3>
                <p class="pillar__blurb">{p.blurb}</p>
                <span class="pillar__cta">Explore this pillar <span aria-hidden="true">&rarr;</span></span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- ====================================================
         BAND 7 — PARTNER (cream, side-by-side, NOT dark green)
         ==================================================== -->
    <section class="partner" id="partner">
      <div class="container partner__grid">
        <div class="partner__copy">
          <p class="eyebrow eyebrow--green">Become a Favor Partner</p>
          <h2>Partner with us today.</h2>
          <p class="partner__lede">You can keep a Favor pastor on the trail in a place no other ministry will go. Monthly partnership is how the field stays equipped, fed, and discipled.</p>
          <p class="partner__line">Tax-deductible. <a href="/about/accountability/">ECFA-accredited since 2019.</a></p>
          <a class="btn btn--primary btn--large partner__cta" href="/give/partner-monthly/">{CTA.partnerMonthly} <span aria-hidden="true">&rarr;</span></a>
          <p class="partner__alt">
            <a href="/give/">Other ways to give &rarr;</a>
            <span aria-hidden="true">&middot;</span>
            <a href="/pray/30-day-guide/">Get the 30-day prayer guide &rarr;</a>
          </p>
        </div>
        <div class="partner__tiers">
          <p class="partner__tiers-label">Suggested monthly tiers</p>
          <div class="partner__tiers-grid">
            {PARTNER_TIERS.map((t) => (
              <a class:list={['partner-tier', t.featured && 'partner-tier--featured']} href={`/give/partner-monthly/?amount=${t.amount}`}>
                {t.featured && <span class="partner-tier__badge">Most chosen</span>}
                <span class="partner-tier__amount">${t.amount}<span class="partner-tier__period">/mo</span></span>
                <span class="partner-tier__label">{t.label}</span>
              </a>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- ====================================================
         BAND 8 — SCRIPTURE (sage-light pause)
         ==================================================== -->
    <section class="scripture-band">
      <div class="container container--narrow scripture-band__inner">
        <span class="scripture-band__rule" aria-hidden="true"></span>
        <blockquote class="scripture-band__quote">&ldquo;{SITE.scripture.text}&rdquo;</blockquote>
        <p class="scripture-band__cite">JOHN 9:4 &middot; AMPC</p>
      </div>
    </section>

    <!-- ====================================================
         BAND 9 — TRUST (white, real badges with linked profiles)
         ==================================================== -->
    <section class="trust">
      <div class="container">
        <header class="trust__head">
          <p class="eyebrow">Accountability</p>
          <h2>You can verify every dollar.</h2>
          <p class="trust__lede">You don't have to take our word for it. Favor International is audited by three independent watchdogs and registered with the State of Florida.</p>
        </header>

        <div class="trust__grid">
          <a class="trust-tile" href={SITE.trust.ecfa} target="_blank" rel="noopener">
            <img src="/images/trust/ecfa.png" alt="ECFA Accredited" loading="lazy" />
            <div class="trust-tile__copy">
              <h3>ECFA-accredited since 2019</h3>
              <p>Evangelical Council for Financial Accountability member since September 30, 2019.</p>
              <span class="trust-tile__link">View ECFA profile &rarr;</span>
            </div>
          </a>
          <a class="trust-tile" href={SITE.trust.charityNavigator} target="_blank" rel="noopener">
            <img src="/images/trust/charity-navigator.svg" alt="Charity Navigator Four-Star" loading="lazy" />
            <div class="trust-tile__copy">
              <h3>Four-Star Charity Navigator</h3>
              <p>Highest rating tier for financial health, accountability, and transparency.</p>
              <span class="trust-tile__link">View Charity Navigator profile &rarr;</span>
            </div>
          </a>
          <a class="trust-tile" href={SITE.trust.candid} target="_blank" rel="noopener">
            <img src="/images/trust/candid-platinum.svg" alt="Candid Platinum Transparency Seal" loading="lazy" />
            <div class="trust-tile__copy">
              <h3>Candid Platinum seal</h3>
              <p>Highest transparency tier on Candid (formerly GuideStar).</p>
              <span class="trust-tile__link">View Candid profile &rarr;</span>
            </div>
          </a>
        </div>

        <p class="trust__fdacs">
          A copy of the official registration and financial information for Favor International, Inc. (CH57842) may be obtained from the Florida Division of Consumer Services by visiting <a href="https://www.fdacs.gov/" target="_blank" rel="noopener">fdacs.gov</a> or calling toll-free 1-800-HELP-FLA (1-800-435-7352) within the state. Registration does not imply endorsement, approval, or recommendation by the State. Favor International, Inc. is a registered 501(c)(3) nonprofit organization. EIN {SITE.ein}.
        </p>
      </div>
    </section>

    <!-- BAND 7: Pray + Go (split-band) -->
    <section class="praygo">
      <a class="praygo__panel praygo__panel--pray" href="/pray/30-day-guide/">
        <div class="praygo__photo" style="background-image: url(/images/hero-prayer-team.jpg)" aria-hidden="true"></div>
        <div class="praygo__scrim praygo__scrim--green" aria-hidden="true"></div>
        <div class="praygo__body">
          <p class="praygo__eyebrow">Pray with us</p>
          <h3 class="praygo__h3">You can pray where they cannot reach.</h3>
          <p class="praygo__lede">One specific request a day, across 14 nations Favor serves. Free PDF, no signup.</p>
          <span class="praygo__cta">Get the 30-Day Prayer Guide <span aria-hidden="true">&rarr;</span></span>
        </div>
      </a>
      <a class="praygo__panel praygo__panel--go" href="/go/vision-trips/">
        <div class="praygo__photo" style="background-image: url(/images/pbs-karamoja.jpg)" aria-hidden="true"></div>
        <div class="praygo__scrim praygo__scrim--terracotta" aria-hidden="true"></div>
        <div class="praygo__body">
          <p class="praygo__eyebrow">Walk with us</p>
          <h3 class="praygo__h3">See it for yourself.</h3>
          <p class="praygo__lede">Small-team vision trips to Uganda, South Sudan, and Ethiopia. Spring and Fall 2026.</p>
          <span class="praygo__cta">See open vision trips <span aria-hidden="true">&rarr;</span></span>
        </div>
      </a>
    </section>

    <!-- BAND 8: Newsletter (sage-light, single-field) -->
    <section class="newsletter">
      <div class="container container--narrow newsletter__inner">
        <p class="band-head__eyebrow newsletter__eyebrow">Field report</p>
        <h2 class="newsletter__h2">One short email. Every other week.</h2>
        <p class="newsletter__body">Real names, real numbers, real prayer requests from the field. Unsubscribe in one click.</p>
        <form class="newsletter__form" action="/newsletter/" method="get">
          <label class="visually-hidden" for="newsletter-email">Email address</label>
          <input class="newsletter__input" id="newsletter-email" type="email" name="email" required placeholder="you@example.com" autocomplete="email" />
          <button class="btn btn--primary newsletter__submit" type="submit">Subscribe <span aria-hidden="true">&rarr;</span></button>
        </form>
        <p class="newsletter__privacy">We never sell or share your email. Read our <a href="/about/accountability/">accountability practice</a>.</p>
      </div>
    </section>

    <!-- BAND 9: Trust strip (compact, horizontal, near footer) -->
    <section class="trust">
      <div class="container trust__inner">
        <p class="trust__lede">You can verify every dollar.</p>
        <ul class="trust__row">
          <li class="trust__item">
            <a href={SITE.trust.ecfa} target="_blank" rel="noopener" class="trust__link">
              <span class="trust__badge" aria-hidden="true">
                <svg viewBox="0 0 64 64" width="56" height="56" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M32 4 8 14v18c0 13 11 25 24 28 13-3 24-15 24-28V14L32 4z"/><path d="M22 33l7 7 13-15"/></svg>
                <span class="trust__badge-text">ECFA</span>
              </span>
              <span class="trust__label">ECFA-accredited <em>since 2019</em></span>
            </a>
          </li>
          <li class="trust__item">
            <a href={SITE.trust.charityNavigator} target="_blank" rel="noopener" class="trust__link">
              <span class="trust__badge" aria-hidden="true">
                <svg viewBox="0 0 64 64" width="56" height="56" fill="currentColor"><path d="M32 6l7.4 14.9L56 23.3l-12 11.7 2.8 16.6L32 43.8l-14.8 7.8L20 35 8 23.3l16.6-2.4L32 6z"/></svg>
                <span class="trust__badge-text">4★</span>
              </span>
              <span class="trust__label">Charity Navigator <em>Four-Star rating</em></span>
            </a>
          </li>
          <li class="trust__item">
            <a href={SITE.trust.candid} target="_blank" rel="noopener" class="trust__link">
              <span class="trust__badge" aria-hidden="true">
                <svg viewBox="0 0 64 64" width="56" height="56" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="32" cy="32" r="26"/><path d="M44 24c-2-4-6-6-12-6-6 0-12 4-12 14s6 14 12 14c6 0 10-2 12-6"/></svg>
                <span class="trust__badge-text">Platinum</span>
              </span>
              <span class="trust__label">Candid Platinum <em>transparency seal</em></span>
            </a>
          </li>
        </ul>
        <p class="trust__ein">EIN {SITE.ein} · FY2024 Form 990 on file · Tax-deductible · 501(c)(3)</p>
      </div>
    </section>

  </main>
  <SiteFooter />
</BaseLayout>

<!-- ====================================================
     VIDEO STAGE CLICK HANDLER
     ==================================================== -->
<script>
  (function () {
    const stage = document.getElementById('video-stage') as HTMLElement | null;
    const player = document.getElementById('stage-player') as HTMLElement | null;
    const chip = document.getElementById('stage-chip') as HTMLElement | null;
    const titleEl = document.getElementById('stage-title') as HTMLElement | null;
    const subtitleEl = document.getElementById('stage-subtitle') as HTMLElement | null;
    if (!stage || !player || !chip || !titleEl || !subtitleEl) return;

    function loadInStage(videoId: string, title: string, subtitle: string, tag: string, shouldScroll: boolean) {
      const wrap = document.createElement('div');
      wrap.className = 'video-embed';
      const iframe = document.createElement('iframe');
      iframe.src = `https://www.youtube-nocookie.com/embed/${videoId}?autoplay=1&rel=0&modestbranding=1`;
      iframe.title = title;
      iframe.allow = 'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share';
      iframe.referrerPolicy = 'strict-origin-when-cross-origin';
      iframe.allowFullscreen = true;
      iframe.loading = 'lazy';
      wrap.appendChild(iframe);
      player!.replaceChildren(wrap);
      titleEl!.textContent = title;
      subtitleEl!.textContent = subtitle;
      chip!.textContent = tag;
      document.querySelectorAll('.video-card').forEach((c) => c.classList.remove('is-active'));
      const active = document.querySelector(`.video-card[data-video-id="${videoId}"]`);
      if (active) active.classList.add('is-active');
      if (shouldScroll) stage!.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }

    const featuredBtn = player.querySelector('button');
    if (featuredBtn) {
      featuredBtn.addEventListener('click', (e) => {
        e.preventDefault();
        loadInStage(stage.dataset.videoId || '', stage.dataset.title || '', stage.dataset.subtitle || '', stage.dataset.tag || 'Featured', false);
      });
    }

    document.querySelectorAll<HTMLElement>('.video-card').forEach((card) => {
      const btn = card.querySelector('button');
      if (!btn) return;
      btn.addEventListener('click', (e) => {
        e.preventDefault();
        loadInStage(card.dataset.videoId || '', card.dataset.title || '', card.dataset.subtitle || '', card.dataset.tag || '', true);
      });
    });
  })();
</script>

