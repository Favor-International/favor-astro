---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteHeader from '../components/global/SiteHeader.astro';
import SiteFooter from '../components/global/SiteFooter.astro';
import NewsletterForm from '../components/global/NewsletterForm.astro';
import { PILLARS, PARTNER_TIERS, SITE } from '../lib/site';
import { CTA, SIGNATURE } from '../lib/cta';

const pillarImages: Record<string, string> = {
  'evangelism-discipleship': '/images/evangelism-discipleship.jpg',
  'education': '/images/education-vlc-jondoru.jpg',
  'community-development': '/images/pillar-community.jpg',
  'economic-empowerment': '/images/pillar-economic.jpg',
};

// Hero grid: 1 large feature + 3 supporting tiles (Samaritan's Purse pattern)
const heroGrid = [
  { image: '/images/pbs-karamoja.jpg', size: 'large', label: 'Portable Bible School', country: 'Karamoja, Uganda' },
  { image: '/images/hero-congo-grads.jpg', size: 'small', label: 'PBS Graduation', country: 'DR Congo' },
  { image: '/images/gift-bishoftu-tot.jpg', size: 'small', label: 'GIFT Institute', country: 'Bishoftu, Ethiopia' },
  { image: '/images/education-vlc-jondoru.jpg', size: 'small', label: 'Village Learning Center', country: 'South Sudan' },
];

// Real stories from the Webflow CMS Stories collection. Source: Stories.csv.
const featuredStories = [
  {
    title: 'More Bibles for Ethiopia, please.',
    country: 'Ethiopia',
    date: 'Field report',
    excerpt: 'After two months of Portable Bible Schools in Ethiopia, field teachers graduated 763 students, led 112 to salvation, baptized 57 — and ran out of Bibles. A partner answered.',
    image: '/images/stories/more-bibles-for-ethiopia-please.jpg',
    href: '/stories/more-bibles-for-ethiopia-please/',
  },
  {
    title: 'Daniel Kidia, a Mundari warrior who came home.',
    country: 'South Sudan',
    date: 'PBS testimony',
    excerpt: 'A former cattle warrior in South Sudan, now a Favor field pastor leading PBS classes among his own people. The Mundari are hearing the gospel in their language for the first time.',
    image: '/images/stories/daniel-kidia.jpg',
    href: '/stories/daniel-kidia/',
  },
  {
    title: 'Goats for women in Puranga.',
    country: 'Uganda',
    date: 'Women’s empowerment',
    excerpt: '50 women in Puranga, Uganda, finished a year of Women’s Empowerment training and received two goats each. The herds will pay for school fees, food, and medical care across the village.',
    image: '/images/stories/goats-for-women.jpg',
    href: '/stories/goats-for-women/',
  },
];

const quickAmounts = [25, 50, 100, 200, 500];
---
<BaseLayout
  title={SITE.name}
  description="Favor International partners with indigenous African pastors and field leaders. ECFA-accredited. Carole Ward has been on the field since 2002. Favor International was founded in 2015."
  image="/images/pbs-karamoja.jpg"
>
  <SiteHeader variant="transparent" />
  <main id="main">

    <!-- BAND 1: Hero grid -->
    <section class="hero">
      <div class="hero__grid">
        {heroGrid.map((tile, i) => (
          <figure class={`hero__tile hero__tile--${tile.size}`} data-i={i}>
            <div class="hero__tile-photo" style={`background-image: url(${tile.image})`} role="img" aria-label={`${tile.label}, ${tile.country}`}></div>
            <figcaption class="hero__tile-caption">
              <span class="hero__tile-label">{tile.label}</span>
              <span class="hero__tile-country">{tile.country}</span>
            </figcaption>
          </figure>
        ))}
      </div>
      <div class="hero__fade" aria-hidden="true"></div>
      <div class="hero__inner container">
        <p class="hero__eyebrow"><span class="hero__eyebrow-dot" aria-hidden="true"></span>{SIGNATURE}</p>
        <h1>Stand with indigenous pastors reaching the hardest places on earth.</h1>
        <p class="hero__sub">Favor International equips African leaders to plant churches, train pastors, and care for the persecuted. You can be part of it.</p>
        <div class="hero__cta">
          <a class="btn btn--primary btn--large" href="/give/partner-monthly/">{CTA.partnerMonthly}</a>
          <a class="hero__secondary" href="/impact/">See the work →</a>
        </div>
      </div>
    </section>

    <!-- BAND 2: Signature -->
    <section class="band band--cream signature">
      <div class="container container--narrow">
        <p class="label">Our calling</p>
        <h2 class="signature__phrase">{SIGNATURE}</h2>
        <p class="signature__body">Favor International supports indigenous African leaders in places most ministries cannot or will not reach. We pray. We send. We stand with the field. We do whatever it takes to put the Gospel in the hands of every village.</p>
      </div>
    </section>

    <!-- BAND 3: Four pillars -->
    <section class="band band--white pillars">
      <div class="container">
        <header class="band__header">
          <p class="label">The work</p>
          <h2>Four ministries. One Kingdom outcome.</h2>
        </header>
        <div class="pillars__grid">
          {PILLARS.map((p) => (
            <a class="pillar" href={`/impact/${p.slug}/`}>
              <div class="pillar__photo" style={`background-image: url(${pillarImages[p.slug]})`} aria-hidden="true">
                <div class="pillar__photo-scrim" aria-hidden="true"></div>
                <h3 class="pillar__title-overlay">{p.label}</h3>
              </div>
              <div class="pillar__body">
                <p>{p.blurb}</p>
                <span class="pillar__cta">Explore →</span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- BAND 4: Stories from the field -->
    <section class="band band--cream stories">
      <div class="container">
        <header class="band__header band__header--left">
          <p class="label">Stories from the field</p>
          <h2>What partners made possible.</h2>
          <a class="band__header-cta" href="/stories/">All stories →</a>
        </header>
        <div class="stories__grid">
          {featuredStories.map((s) => (
            <a class="story" href={s.href}>
              <div class="story__photo" style={`background-image: url(${s.image})`} aria-hidden="true"></div>
              <div class="story__body">
                <span class="story__meta">{s.country} · {s.date}</span>
                <h3>{s.title}</h3>
                <p>{s.excerpt}</p>
                <span class="story__cta">Read the story →</span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- BAND 5: Become a Favor Partner -->
    <section class="band partner" id="partner">
      <div class="container partner__grid">
        <div class="partner__copy">
          <p class="label">Monthly partnership</p>
          <h2>Become a Favor Partner.</h2>
          <p>Favor Partners give monthly. Your gift goes to the field every month and keeps indigenous pastors, teachers, and counselors in motion. Pick the tier that fits. Custom amounts welcome.</p>
          <p class="partner__trust">Tax-deductible. <a href="/about/accountability/">ECFA-accredited.</a></p>
        </div>
        <div class="partner__tiers">
          {PARTNER_TIERS.map((t) => (
            <a class:list={['tier', t.featured && 'tier--featured']} href={`/give/partner-monthly/?amount=${t.amount}`}>
              <span class="tier__amount">${t.amount}<span class="tier__period">/mo</span></span>
              <span class="tier__label">{t.label}</span>
            </a>
          ))}
        </div>
      </div>
      <div class="container partner__footer">
        <a class="btn btn--primary btn--large" href="/give/partner-monthly/">{CTA.partnerMonthly}</a>
        <a class="partner__alt" href="/give/">Or explore other ways to give →</a>
      </div>
    </section>

    <!-- BAND 6: Pray -->
    <section class="band band--tan pray-cta">
      <div class="container pray-cta__grid">
        <div class="pray-cta__photo" style="background-image: url(/images/evangelism-discipleship.jpg)" role="img" aria-label="A pastor prays with children in a village"></div>
        <div class="pray-cta__copy">
          <p class="label">Pray with us</p>
          <h2>You can pray where they cannot reach.</h2>
          <p>The 30-Day Prayer Guide walks you through one specific request per day across the regions Favor serves. No email required. Print it, tape it to the fridge, pray it out loud.</p>
          <a class="btn btn--secondary btn--large" href="/pray/30-day-guide/">{CTA.prayerGuide}</a>
        </div>
      </div>
    </section>

    <!-- BAND 7: How we earn your trust (World Vision pattern) -->
    <section class="band band--white trust-band">
      <div class="container">
        <header class="band__header">
          <p class="label">How we earn your trust</p>
          <h2>Three ways Favor stays accountable.</h2>
        </header>
        <div class="trust-band__grid">
          <article class="trust-card">
            <img class="trust-card__badge" src="/images/trust/ecfa.png" alt="ECFA Accredited" width="120" height="120" />
            <h3>ECFA-accredited since 2019</h3>
            <p>Favor International has been a member of the Evangelical Council for Financial Accountability since September 30, 2019. ECFA holds members to a public standard of stewardship and disclosure.</p>
            <a href={SITE.trust.ecfa} target="_blank" rel="noopener">View our ECFA profile →</a>
          </article>
          <article class="trust-card">
            <img class="trust-card__badge" src="/images/trust/charity-navigator.svg" alt="Charity Navigator Four-Star" width="120" height="120" />
            <h3>Four-Star Charity Navigator rating</h3>
            <p>Charity Navigator scores nonprofits on financial health, accountability, and transparency. Favor International currently holds a Four-Star rating, the highest tier.</p>
            <a href={SITE.trust.charityNavigator} target="_blank" rel="noopener">View our Charity Navigator profile →</a>
          </article>
          <article class="trust-card">
            <img class="trust-card__badge" src="/images/trust/candid-platinum.svg" alt="Candid Platinum Transparency Seal" width="120" height="120" />
            <h3>Candid Platinum transparency seal</h3>
            <p>Candid (formerly Guidestar) verifies nonprofit transparency at four tiers. Favor International holds the Platinum tier, the highest. EIN {SITE.ein}.</p>
            <a href={SITE.trust.candid} target="_blank" rel="noopener">View our Candid profile →</a>
          </article>
        </div>
      </div>
    </section>

    <!-- BAND 8: Inline give widget (Samaritan's Purse pattern) -->
    <section class="band band--green-deep inline-give">
      <div class="container container--narrow inline-give__inner">
        <p class="label label--bright">Give where most needed</p>
        <h2>One gift. Directly to the field.</h2>
        <p>Unrestricted gifts go where the field is asking the loudest that week. Pick an amount, or set your own.</p>
        <form class="inline-give__form" action="/give/one-time/" method="get">
          <div class="inline-give__amounts">
            {quickAmounts.map((a, i) => (
              <label>
                <input type="radio" name="amount" value={a} checked={i === 1} />
                <span>${a}</span>
              </label>
            ))}
            <label class="inline-give__custom">
              <input type="number" name="amount" placeholder="Custom" min="5" />
            </label>
          </div>
          <button type="submit" class="btn btn--primary btn--large">Give now</button>
        </form>
        <p class="inline-give__note">Tax-deductible. Powered by Blackbaud. <a href="/give/">See all giving options →</a></p>
      </div>
    </section>

    <!-- BAND 9: Newsletter -->
    <section class="band band--sage newsletter-band">
      <div class="container container--narrow">
        <p class="label">Get the field report</p>
        <h2>One email a month. Real news from the field.</h2>
        <p>Honest reporting from each country team. What worked. What didn’t. What the field is asking for next.</p>
        <NewsletterForm />
      </div>
    </section>

  </main>
  <SiteFooter />
</BaseLayout>

<style>
  /* ===== HERO GRID ===== */
  .hero {
    position: relative;
    min-height: 92vh;
    display: flex;
    align-items: flex-end;
    color: var(--color-white);
    overflow: hidden;
    padding-top: 96px;
    padding-bottom: var(--space-16);
  }
  .hero__grid {
    position: absolute; inset: 0;
    display: grid;
    grid-template-columns: 2.4fr 1fr;
    grid-template-rows: 1fr 1fr 1fr;
    gap: 4px;
    z-index: 0;
  }
  .hero__tile { margin: 0; position: relative; overflow: hidden; }
  .hero__tile--large {
    grid-column: 1;
    grid-row: 1 / span 3;
  }
  .hero__tile--small {
    grid-column: 2;
    grid-row: span 1;
  }
  .hero__tile-photo {
    position: absolute; inset: 0;
    background-size: cover;
    background-position: center;
    background-color: var(--color-sage-light);
    transition: transform 4s ease;
  }
  .hero__tile--large .hero__tile-photo { background-position: center 35%; }
  .hero__tile-caption {
    position: absolute;
    left: var(--space-3); bottom: var(--space-3);
    color: var(--color-white);
    display: flex; flex-direction: column;
    z-index: 2;
    pointer-events: none;
  }
  .hero__tile-label {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-gold);
  }
  .hero__tile-country {
    font-size: 0.85rem;
    font-weight: 600;
    color: color-mix(in srgb, var(--color-white) 90%, transparent);
  }
  .hero__tile::after {
    content: '';
    position: absolute; inset: 0;
    background: linear-gradient(180deg, rgba(0,0,0,0) 60%, rgba(0,0,0,0.55) 100%);
    z-index: 1;
    pointer-events: none;
  }

  /* Directional fade — dark on left where text sits, clear on right where photos breathe */
  .hero__fade {
    position: absolute; inset: 0;
    z-index: 1;
    background:
      linear-gradient(95deg, rgba(20, 35, 16, 0.92) 0%, rgba(20, 35, 16, 0.78) 28%, rgba(20, 35, 16, 0.30) 50%, rgba(20, 35, 16, 0.0) 70%),
      linear-gradient(180deg, rgba(20, 35, 16, 0.55) 0%, rgba(20, 35, 16, 0) 25%, rgba(20, 35, 16, 0) 70%, rgba(20, 35, 16, 0.50) 100%);
    pointer-events: none;
  }

  .hero__inner {
    position: relative;
    z-index: 3;
    max-width: 720px;
    padding-top: var(--space-12);
    padding-bottom: var(--space-12);
  }
  .hero__eyebrow {
    display: inline-flex;
    align-items: center;
    gap: var(--space-3);
    color: var(--color-gold-light);
    font-size: 0.82rem;
    font-weight: 600;
    letter-spacing: 0.20em;
    text-transform: uppercase;
    margin: 0 0 var(--space-5);
  }
  .hero__eyebrow-dot {
    width: 8px; height: 8px; border-radius: 50%;
    background: var(--color-green-bright);
    box-shadow: 0 0 0 4px color-mix(in srgb, var(--color-green-bright) 25%, transparent);
  }
  .hero h1 {
    color: var(--color-white);
    margin: 0 0 var(--space-6);
    font-size: clamp(2.5rem, 5.4vw, 4.4rem);
    line-height: 1.04;
    letter-spacing: -0.01em;
    font-weight: 800;
    text-wrap: balance;
    text-shadow: 0 2px 16px rgba(0,0,0,0.35);
  }
  .hero__sub {
    font-size: clamp(1.05rem, 1.4vw, 1.2rem);
    color: color-mix(in srgb, var(--color-white) 94%, transparent);
    max-width: 580px;
    margin: 0 0 var(--space-8);
    line-height: 1.55;
    text-shadow: 0 1px 8px rgba(0,0,0,0.35);
  }
  .hero__cta { display: flex; gap: var(--space-6); align-items: center; flex-wrap: wrap; }
  .hero__secondary {
    color: var(--color-white);
    text-decoration: none;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-size: 0.85rem;
    border-bottom: 2px solid var(--color-gold);
    padding-bottom: 4px;
  }
  .hero__secondary:hover { color: var(--color-gold); }

  @media (max-width: 900px) {
    .hero__grid {
      grid-template-columns: 1fr 1fr;
      grid-template-rows: 1fr 1fr;
    }
    .hero__tile--large { grid-column: 1 / span 2; grid-row: 1; }
    .hero__tile--small:nth-of-type(2) { grid-column: 1; grid-row: 2; }
    .hero__tile--small:nth-of-type(3) { grid-column: 2; grid-row: 2; }
    .hero__tile--small:nth-of-type(4) { display: none; }
    .hero__fade {
      background:
        linear-gradient(180deg, rgba(20, 35, 16, 0.80) 0%, rgba(20, 35, 16, 0.55) 30%, rgba(20, 35, 16, 0.78) 60%, rgba(20, 35, 16, 0.92) 100%);
    }
    .hero { min-height: 110vh; padding-top: 72px; }
  }

  /* ===== BAND HELPERS ===== */
  .band__header { text-align: center; max-width: 760px; margin: 0 auto var(--space-16); }
  .band__header--left { text-align: left; max-width: none; display: grid; grid-template-columns: 1fr auto; gap: var(--space-4); align-items: end; }
  .band__header--left h2 { grid-row: 2; grid-column: 1; margin: 0; }
  .band__header--left .label { grid-row: 1; grid-column: 1; margin: 0; }
  .band__header--left .band__header-cta { grid-row: 2; grid-column: 2; font-weight: 700; color: var(--color-gold-deep); text-decoration: none; font-size: 0.95rem; letter-spacing: 0.04em; }
  .band__header h2 { text-wrap: balance; }
  .band__lede { font-size: 1.05rem; color: var(--color-ink-soft); }
  .label--bright { color: var(--color-green-bright) !important; }

  /* ===== SIGNATURE ===== */
  .signature { text-align: center; }
  .signature__phrase {
    font-family: var(--font-sans);
    font-weight: 800;
    font-style: italic;
    font-size: clamp(2rem, 4.5vw, 3.4rem);
    color: var(--color-green);
    line-height: 1.1;
    margin: var(--space-4) 0 var(--space-6);
  }
  .signature__body { font-size: 1.1rem; color: var(--color-ink-soft); max-width: 640px; margin: 0 auto; }

  /* ===== PILLARS — title on photo ===== */
  .pillars__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-4);
  }
  @media (max-width: 1100px) { .pillars__grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 540px) { .pillars__grid { grid-template-columns: 1fr; } }
  .pillar {
    display: flex; flex-direction: column;
    background: var(--color-white);
    border-radius: var(--radius-card);
    overflow: hidden;
    text-decoration: none; color: inherit;
    box-shadow: var(--shadow-soft);
    transition: transform 200ms, box-shadow 200ms;
    height: 100%;
  }
  .pillar:hover { transform: translateY(-4px); box-shadow: var(--shadow-card); }
  .pillar__photo {
    aspect-ratio: 4 / 5;
    background-size: cover;
    background-position: center;
    background-color: var(--color-sage-light);
    position: relative;
  }
  .pillar__photo-scrim {
    position: absolute; inset: 0;
    background: linear-gradient(180deg, rgba(31,58,26,0) 40%, rgba(31,58,26,0.85) 100%);
  }
  .pillar__title-overlay {
    position: absolute;
    left: var(--space-5); right: var(--space-5); bottom: var(--space-5);
    color: var(--color-white);
    font-size: 1.15rem;
    font-weight: 800;
    line-height: 1.2;
    margin: 0;
    text-shadow: 0 1px 8px rgba(0,0,0,0.5);
  }
  .pillar__body { padding: var(--space-5) var(--space-5) var(--space-6); display: flex; flex-direction: column; gap: var(--space-3); flex: 1; }
  .pillar__body p { margin: 0; color: var(--color-ink-soft); font-size: 0.92rem; flex: 1; }
  .pillar__cta { font-weight: 700; color: var(--color-gold-deep); font-size: 0.85rem; }

  /* ===== STORIES ===== */
  .stories__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-8);
  }
  @media (max-width: 900px) { .stories__grid { grid-template-columns: 1fr; } }
  .story {
    display: flex; flex-direction: column;
    background: var(--color-white);
    border-radius: var(--radius-card);
    overflow: hidden;
    text-decoration: none; color: inherit;
    box-shadow: var(--shadow-soft);
    transition: transform 200ms, box-shadow 200ms;
  }
  .story:hover { transform: translateY(-4px); box-shadow: var(--shadow-card); }
  .story__photo {
    aspect-ratio: 3 / 2;
    background-size: cover;
    background-position: center;
    background-color: var(--color-sage-light);
  }
  .story__body { padding: var(--space-6); display: flex; flex-direction: column; gap: var(--space-3); }
  .story__meta {
    font-size: var(--font-size-label);
    font-weight: 700;
    letter-spacing: var(--letter-spacing-label);
    text-transform: uppercase;
    color: var(--color-terracotta);
  }
  .story h3 { margin: 0; color: var(--color-green); font-size: 1.2rem; line-height: 1.25; }
  .story p { margin: 0; color: var(--color-ink-soft); font-size: 0.95rem; }
  .story__cta { margin-top: auto; font-weight: 700; color: var(--color-gold-deep); font-size: 0.9rem; }

  /* ===== PARTNER BAND ===== */
  .partner {
    background: linear-gradient(135deg, var(--color-gold) 0%, color-mix(in srgb, var(--color-gold) 76%, var(--color-terracotta)) 100%);
    color: var(--color-ink);
  }
  .partner__grid {
    display: grid;
    grid-template-columns: 1fr 1.5fr;
    gap: var(--space-16);
    align-items: center;
  }
  @media (max-width: 1024px) { .partner__grid { grid-template-columns: 1fr; gap: var(--space-12); } }
  .partner__copy h2 { color: var(--color-ink); font-size: clamp(2rem, 3.5vw, 2.75rem); }
  .partner__copy .label { color: var(--color-green-deep); }
  .partner__copy a { color: var(--color-green-deep); }
  .partner__trust { font-size: 0.92rem; color: color-mix(in srgb, var(--color-ink) 78%, transparent); }
  .partner__tiers {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-3);
  }
  @media (max-width: 540px) { .partner__tiers { grid-template-columns: repeat(2, 1fr); } }
  .tier {
    display: flex; flex-direction: column; gap: var(--space-2);
    background: var(--color-white);
    color: var(--color-ink);
    border-radius: var(--radius-card);
    padding: var(--space-6);
    text-decoration: none;
    border: 2px solid transparent;
    transition: transform 160ms, border-color 160ms, box-shadow 160ms;
    text-align: center;
  }
  .tier:hover { transform: translateY(-3px); border-color: var(--color-green); box-shadow: var(--shadow-card); }
  .tier__amount { font-weight: 800; font-size: 1.8rem; color: var(--color-green); line-height: 1; display: inline-flex; align-items: baseline; justify-content: center; gap: 2px; }
  .tier__period { font-size: 0.78rem; font-weight: 600; color: var(--color-sage); margin-left: 4px; }
  .tier__label { font-weight: 700; letter-spacing: 0.06em; color: var(--color-green-deep); text-transform: uppercase; font-size: 0.78rem; }
  .tier--featured { background: var(--color-green); color: var(--color-white); border-color: var(--color-green-deep); }
  .tier--featured .tier__amount, .tier--featured .tier__label { color: var(--color-gold); }
  .tier--featured .tier__period { color: color-mix(in srgb, var(--color-white) 82%, transparent); }

  .partner__footer {
