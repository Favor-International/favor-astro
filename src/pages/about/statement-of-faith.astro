---
import PageLayout from '../../layouts/PageLayout.astro';
import PageHero from '../../components/band/PageHero.astro';
import CtaBand from '../../components/band/CtaBand.astro';

const articles = [
  { title: 'The Bible', body: 'We believe the Bible (Old and New Testaments) is the inspired, infallible, and authoritative Word of God.' },
  { title: 'God', body: 'We believe in one God, eternally existent in three persons: Father, Son, and Holy Spirit.' },
  { title: 'Jesus Christ', body: 'We believe in the deity of our Lord Jesus Christ, His virgin birth, sinless life, atoning death, bodily resurrection, ascension, and personal return in power and glory.' },
  { title: 'Salvation', body: 'We believe salvation is by grace through faith in Jesus Christ alone, not by works.' },
  { title: 'The Holy Spirit', body: 'We believe in the present ministry of the Holy Spirit, by whose indwelling the Christian is enabled to live a godly life.' },
  { title: 'The Church', body: 'We believe in the spiritual unity of believers in our Lord Jesus Christ, expressed locally in the gathered church.' },
  { title: 'Baptism', body: 'We believe in the baptism of all believers by immersion as a physical sign of the inward faith in Jesus Christ. Baptism symbolizes our death and resurrection with Him.' },
  { title: 'The Resurrection', body: 'We believe in the resurrection of the dead and that the dead in Christ will rise never to die again, and those who are still living will be caught up with them to meet the Lord in the air, and to live with Christ throughout eternity.' },
  { title: 'Holy Matrimony', body: 'We believe in holy matrimony, that is marriage between one man and one woman, as having been sanctioned in the Christian life according to the Word of God. We believe that in marriage, a man leaves his father and mother and joins his wife and the two become one flesh (Genesis 2:24).' },
  { title: 'Tithing and Giving', body: 'We believe in tithing and giving offerings in the Kingdom of God so that there may be enough supply for the work of God and His servants. We apply the power of prayer, fasting, and giving within our lives, as has been taught us by our Lord Jesus Christ through His Word (Matthew 6:3-18).' },
  { title: 'The Great Commission', body: 'We believe in preaching the Gospel of Jesus Christ and being witnesses of His Word and works to the entire world, in fulfillment of the Great Commission. This was commanded to us, by the Lord Jesus Christ, and is His commission for the whole body of Christ worldwide.' },
  { title: 'Spiritual Authority', body: 'We believe that the devil is the prince of demons and darkness, and as the adversary of God is therefore an enemy of the children of God. When Jesus died on the cross, He guaranteed the ultimate triumph of God and His church, over all darkness. He has given believers power and authority for prayer, doing His Word and will, fulfilling His commission, and setting people free from the works of the enemy, in His Name. (Mark 16:16-17, Ephesians 2:2, Colossians 2:13-15, 1 Peter 5:8, and Revelation 20:10.)' },
  { title: 'The Return of Christ', body: 'We believe in and eagerly await the second return of this same Jesus Christ, to take the Church to Himself, a Church without spot or wrinkle. This is our driving force in preparing ourselves and the rest of the world, as we &lsquo;occupy&rsquo; until His return.' },
];
---
<PageLayout
  title="Statement of Faith"
  description="The doctrinal statement of Favor International. Where we stand."
>
  <PageHero
    label="Statement of Faith"
    title="Where we stand."
    promise="The doctrinal core that every Favor staff member, board member, and field leader affirms."
    image="/images/story-historic-prayer.jpg"
    imageAlt="Gulu Stadium prayer gathering, 2005"
    variant="split"
  />

  <section class="band band--white">
    <div class="container container--narrow">
      <ol class="faith-list">
        {articles.map((a) => (
          <li>
            <h3>{a.title}</h3>
            <p>{a.body}</p>
          </li>
        ))}
      </ol>
      <p>This statement is intentionally short and intentionally classic. Favor stands in the historic Christian faith summarized in the Nicene Creed and the Lausanne Covenant.</p>
    </div>
  </section>

  <CtaBand
    heading="Questions on doctrine?"
    body="Email the team. We are happy to discuss what we believe and why."
    ctaLabel="Email the team"
    ctaHref="mailto:info@favorintl.org"
    variant="sage"
  />
</PageLayout>

<style>
  .faith-list { list-style: none; padding: 0; margin: 0 0 var(--space-8); display: grid; gap: var(--space-4); counter-reset: faith; }
  .faith-list li {
    padding: var(--space-6);
    background: var(--color-cream);
    border-radius: var(--radius-card);
    position: relative;
    padding-left: 72px;
  }
  .faith-list li::before {
    counter-increment: faith;
    content: counter(faith);
    position: absolute;
    left: var(--space-6);
    top: var(--space-6);
    width: 36px; height: 36px;
    border-radius: 50%;
    background: var(--color-gold);
    color: var(--color-ink);
    display: flex; align-items: center; justify-content: center;
    font-weight: 800;
  }
  .faith-list h3 { margin: 0 0 var(--space-2); color: var(--color-green); font-size: 1.15rem; }
  .faith-list p { margin: 0; color: var(--color-ink-soft); }
</style>
