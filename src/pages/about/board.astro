---
import PageLayout from '../../layouts/PageLayout.astro';
import PageHero from '../../components/band/PageHero.astro';
import OverlayFeature from '../../components/band/OverlayFeature.astro';
import CtaBand from '../../components/band/CtaBand.astro';
import directorsData from '../../data/directors.json';

// Board of Directors: 9 volunteer board members. Source: Webflow CMS Directors collection.
const board = directorsData
  .filter(d => /board/i.test(d.type))
  .sort((a, b) => (a.order || 999) - (b.order || 999));
const personHref = (slug) => slug === 'carole-ward' ? '/about/our-story/founder/' : `/about/people/${slug}/`;

const governance = [
  { title: 'Term limits', body: 'Board members serve renewable three-year terms, with a maximum tenure that keeps fresh perspective and continuity in balance.', icon: '<circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/>' },
  { title: 'Volunteer service', body: 'Board service is fully volunteer. No board member receives any compensation for their role.', icon: '<path d="M19 14c1.5-1.6 3-3.3 3-5.5A3.5 3.5 0 0 0 12 6 3.5 3.5 0 0 0 2 8.5c0 2.2 1.5 3.9 3 5.5l7 7z"/>' },
  { title: 'Independence', body: 'A majority of the board is independent of paid staff, and the board reviews the executive team’s compensation every year.', icon: '<path d="M12 3v18"/><path d="M6 7h12"/><path d="M6 7 3 13h6zM18 7l-3 6h6z"/><path d="M5 21h14"/>' },
  { title: 'Annual audit', body: 'Favor is audited every year by an independent firm. The audited financials are filed with the IRS as Form 990 and reviewed by ECFA.', icon: '<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><path d="M14 2v6h6"/><path d="m9 15 2 2 4-4"/>' },
  { title: 'Conflict-of-interest policy', body: 'A written conflict-of-interest policy is signed by every board member each year and reviewed by counsel.', icon: '<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>' },
];
---
<PageLayout
  title="Board of Directors"
  description="The volunteer Board of Directors providing governance and financial oversight for Favor International."
>
  <PageHero
    label="Governance"
    title="Board of Directors."
    promise="Volunteer governance. Term-limited. Independent of paid staff per ECFA best practice."
    image="/images/hero-tot-bishoftu.jpg"
    imageAlt="A Training of Trainers session in Bishoftu, Ethiopia"
    variant="split"
  />

  <section class="band band--white">
    <div class="container">
      <p class="band__lede" style="text-align:center; max-width: 760px; margin: 0 auto var(--space-12) auto;">
        Favor International's Board of Directors meets quarterly and is responsible for
        governance, financial oversight, executive review, and strategic direction. Each member
        serves without compensation. The board is independent of paid staff and operates under
        the conflict-of-interest and best-practice standards required for ECFA accreditation.
      </p>
      <div class="board-grid">
        {board.map((m) => (
          <a class="board-card" href={personHref(m.slug)}>
            <div class="board-card__photo">
              <img src={m.imagePath} alt={`${m.fullName}, ${m.position}`} loading="lazy" />
            </div>
            <div class="board-card__body">
              <h3>{m.fullName}</h3>
              <p class="board-card__role">{m.position}</p>
              <p class="board-card__location">{m.location}</p>
              <span class="board-card__more">View profile &rarr;</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="band band--cream">
    <div class="container">
      <header class="band__header">
        <p class="label">Governance</p>
        <h2>How the board works.</h2>
      </header>
      <div class="gov-grid">
        {governance.map((g) => (
          <article class="gov-card">
            <span class="gov-card__icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" set:html={g.icon}></svg></span>
            <h3>{g.title}</h3>
            <p>{g.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <OverlayFeature
    image="/images/hero-prayer-team.jpg"
    imageAlt="Favor leaders gathered in prayer"
    eyebrow="Built to be trusted"
    heading="Oversight that protects every gift."
    side="right"
  >
    <p>Favor International is accredited by the <strong>Evangelical Council for Financial Accountability (ECFA)</strong> and audited every year by an independent firm.</p>
    <p>Our audited financials are filed with the IRS as a public Form 990, rated by Charity Navigator, and listed on Candid. The board reviews them, along with executive compensation, every year.</p>
  </OverlayFeature>

  <CtaBand
    heading="Read the financial accountability page."
    body="ECFA, Charity Navigator, Candid Platinum: the third-party signals that show where the money goes."
    ctaLabel="Financial accountability"
    ctaHref="/about/accountability/"
    variant="sage"
  />
</PageLayout>

<style>
  .board-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-8);
  }
  @media (max-width: 900px) { .board-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 540px) { .board-grid { grid-template-columns: 1fr; } }

  .board-card {
    background: var(--color-cream);
    border-radius: var(--radius-card);
    overflow: hidden;
    border: 2px solid var(--color-green);
    box-shadow: var(--shadow-card);
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
    transition: transform 180ms, box-shadow 180ms;
  }
  .board-card:hover { transform: translateY(-4px); box-shadow: 0 20px 44px rgba(31, 58, 26, 0.16); }
  .board-card__more {
    margin-top: var(--space-3);
    color: var(--color-gold-deep);
    font-weight: 700;
    font-size: 0.85rem;
  }
  .board-card:hover .board-card__more { color: var(--color-green); }
  .board-card__photo {
    width: 100%;
    aspect-ratio: 1 / 1;
    background: var(--color-sage-light);
    overflow: hidden;
  }
  .board-card__photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    display: block;
  }
  .board-card__body {
    padding: var(--space-5) var(--space-5) var(--space-6);
    text-align: left;
  }
  .board-card__body h3 {
    margin: 0 0 var(--space-1) 0;
    color: var(--color-green);
    font-size: 1.15rem;
    line-height: 1.2;
  }
  .board-card__role {
    margin: 0;
    color: var(--color-ink);
    font-weight: 600;
    font-size: 0.92rem;
  }
  .board-card__location {
    margin: var(--space-2) 0 0 0;
    color: var(--color-sage);
    font-size: 0.82rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .gov-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: var(--space-6); }
  .gov-card { background: var(--color-white); border: 2px solid var(--accent, var(--color-gold)); border-radius: var(--radius-card); padding: var(--space-6); box-shadow: var(--shadow-soft); }
  .gov-card:nth-child(4n+1) { --accent: var(--color-gold-deep); }
  .gov-card:nth-child(4n+2) { --accent: var(--color-green-bright); }
  .gov-card:nth-child(4n+3) { --accent: var(--color-terracotta); }
  .gov-card:nth-child(4n+4) { --accent: var(--color-sage); }
  .gov-card__icon { display: inline-flex; align-items: center; justify-content: center; width: 48px; height: 48px; border-radius: 12px; background: color-mix(in srgb, var(--accent, var(--color-gold)) 14%, var(--color-white)); color: var(--accent, var(--color-green)); margin-bottom: var(--space-4); }
  .gov-card__icon svg { width: 26px; height: 26px; }
  .gov-card h3 { margin: 0 0 var(--space-2); color: var(--color-green); font-size: 1.15rem; }
  .gov-card p { margin: 0; color: var(--color-ink-soft); line-height: 1.6; font-size: 0.95rem; }
</style>
