---
import PageLayout from '../../layouts/PageLayout.astro';
import PageHero from '../../components/band/PageHero.astro';
import CtaBand from '../../components/band/CtaBand.astro';
import directorsData from '../../data/directors.json';

// Board of Directors: 9 volunteer board members. Source: Webflow CMS Directors collection.
const board = directorsData
  .filter(d => /board/i.test(d.type))
  .sort((a, b) => (a.order || 999) - (b.order || 999));
const personHref = (slug) => slug === 'carole-ward' ? '/about/our-story/founder/' : `/about/people/${slug}/`;
---
<PageLayout
  title="Board of Directors"
  description="The volunteer Board of Directors providing governance and financial oversight for Favor International."
>
  <PageHero
    label="Governance"
    title="Board of Directors."
    promise="Volunteer governance. Term-limited. Independent of paid staff per ECFA best practice."
    image="/images/hero-tot-bishoftu.jpg"
    imageAlt="A Training of Trainers session in Bishoftu, Ethiopia"
    variant="split"
  />

  <section class="band band--white">
    <div class="container">
      <p class="band__lede" style="text-align:center; max-width: 760px; margin: 0 auto var(--space-12) auto;">
        Favor International's Board of Directors meets quarterly and is responsible for
        governance, financial oversight, executive review, and strategic direction. Each member
        serves without compensation. The board is independent of paid staff and operates under
        the conflict-of-interest and best-practice standards required for ECFA accreditation.
      </p>
      <div class="board-grid">
        {board.map((m) => (
          <a class="board-card" href={personHref(m.slug)}>
            <div class="board-card__photo">
              <img src={m.imagePath} alt={`${m.fullName}, ${m.position}`} loading="lazy" />
            </div>
            <div class="board-card__body">
              <h3>{m.fullName}</h3>
              <p class="board-card__role">{m.position}</p>
              <p class="board-card__location">{m.location}</p>
              <span class="board-card__more">View profile &rarr;</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="band band--cream">
    <div class="container container--narrow">
      <h2 class="band__title">How the board works.</h2>
      <ul class="board-facts">
        <li><strong>Term limits.</strong> Board members serve renewable three-year terms with a maximum tenure that ensures fresh perspective and continuity.</li>
        <li><strong>Compensation.</strong> Board service is fully volunteer. No board member receives compensation for their role.</li>
        <li><strong>Independence.</strong> A majority of the board is independent of paid staff, and the board reviews the executive team's compensation annually.</li>
        <li><strong>Audit.</strong> Favor is audited annually by an independent firm. The audited financials are filed with the IRS as Form 990 and reviewed by ECFA.</li>
        <li><strong>Conflicts of interest.</strong> A written conflict-of-interest policy is signed by every board member each year and reviewed by counsel.</li>
      </ul>
    </div>
  </section>

  <CtaBand
    heading="Read the financial accountability page."
    body="ECFA, Charity Navigator, Candid Platinum: the third-party signals that show where the money goes."
    ctaLabel="Financial accountability"
    ctaHref="/about/accountability/"
    variant="sage"
  />
</PageLayout>

<style>
  .board-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-8);
  }
  @media (max-width: 900px) { .board-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 540px) { .board-grid { grid-template-columns: 1fr; } }

  .board-card {
    background: var(--color-cream);
    border-radius: var(--radius-card);
    overflow: hidden;
    border-top: 4px solid var(--color-green);
    border-left: 1px solid var(--color-border);
    border-right: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
    box-shadow: var(--shadow-card);
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
    transition: transform 180ms, box-shadow 180ms;
  }
  .board-card:hover { transform: translateY(-4px); box-shadow: 0 20px 44px rgba(31, 58, 26, 0.16); }
  .board-card__more {
    margin-top: var(--space-3);
    color: var(--color-gold-deep);
    font-weight: 700;
    font-size: 0.85rem;
  }
  .board-card:hover .board-card__more { color: var(--color-green); }
  .board-card__photo {
    width: 100%;
    aspect-ratio: 1 / 1;
    background: var(--color-sage-light);
    overflow: hidden;
  }
  .board-card__photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    display: block;
  }
  .board-card__body {
    padding: var(--space-5) var(--space-5) var(--space-6);
    text-align: left;
  }
  .board-card__body h3 {
    margin: 0 0 var(--space-1) 0;
    color: var(--color-green);
    font-size: 1.15rem;
    line-height: 1.2;
  }
  .board-card__role {
    margin: 0;
    color: var(--color-ink);
    font-weight: 600;
    font-size: 0.92rem;
  }
  .board-card__location {
    margin: var(--space-2) 0 0 0;
    color: var(--color-sage);
    font-size: 0.82rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .board-facts {
    list-style: none;
    padding: 0;
    margin: var(--space-6) 0 0 0;
    display: grid;
    gap: var(--space-4);
  }
  .board-facts li {
    padding: var(--space-4) var(--space-5);
    background: var(--color-white);
    border-left: 4px solid var(--color-gold);
    border-radius: var(--radius-card);
    font-size: 0.95rem;
    line-height: 1.55;
    color: var(--color-ink-soft);
  }
  .board-facts strong {
    color: var(--color-green);
    font-weight: 700;
  }
</style>
