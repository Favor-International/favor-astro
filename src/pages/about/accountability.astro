---
import PageLayout from '../../layouts/PageLayout.astro';
import PageHero from '../../components/band/PageHero.astro';
import OverlayFeature from '../../components/band/OverlayFeature.astro';
import CtaBand from '../../components/band/CtaBand.astro';
import { SITE, IMPACT_STATS } from '../../lib/site';

const impactReports = [
  { label: '2025 Q1 Report', url: 'https://cdn.prod.website-files.com/62cda51656823c14ac1caf02/67f8fb06a27063a36a26d893_Impact%20Report%202025.pdf' },
  { label: '2024 Annual Report', url: 'https://cdn.prod.website-files.com/62cda51656823c14ac1caf02/679e8757459b553c8139cd68_Annual%20Report%202024%20.pdf' },
  { label: '2024 Q3 Report', url: 'https://cdn.prod.website-files.com/62cda51656823c14ac1caf02/6712aa5698186f3c16b908b7_Favor%20Q3%20Impact%20Report%202024.pdf' },
  { label: '2024 Q2 Report', url: 'https://cdn.prod.website-files.com/62cda51656823c14ac1caf02/669678d504deb0d992ef5a58_Q2%202024%20Impact%20Report.pdf' },
  { label: '2024 Q1 Report', url: 'https://cdn.prod.website-files.com/62cda51656823c14ac1caf02/679e86c02439d38e1e5915f6_FAVOR%20Q1%20IMPACT%20REPORT%202024.pdf' },
  { label: '2023 Annual Report', url: 'https://cdn.prod.website-files.com/62cda51656823c14ac1caf02/679e8468daf348cccd1ebff7_Annual%20Impact%20Report%202023.pdf' },
  { label: '2023 Q3 Report', url: 'https://cdn.prod.website-files.com/62cda51656823c14ac1caf02/65397e8ad81200f382d3b2d1_Q3%20Impact%20Report%202023%20-%20V2.pdf' },
  { label: '2023 Q2 Report', url: 'https://cdn.prod.website-files.com/62cda51656823c14ac1caf02/65397e65c8de24acbce19141_8th%20Draft%20-%20Q2%20Impact%20Report%202023.pdf' },
  { label: '2023 Q1 Report', url: 'https://cdn.prod.website-files.com/62cda51656823c14ac1caf02/646fb51c44f4f022ea4f8359_Q1%20Impact%20Report%202023%20FINAL.pdf' },
  { label: '2022 Annual Report', url: 'https://cdn.prod.website-files.com/62cda51656823c14ac1caf02/647e51a33462782bd45eda60_Annual%20Report%20Final%20-%202022.pdf' },
  { label: '2022 Q3 Report', url: 'https://cdn.prod.website-files.com/62cda51656823c14ac1caf02/64542c2a1a2f50cc3f9886ca_Q3%20REPORT%20Draft%20Five.pdf' },
  { label: '2022 Q2 Report', url: 'https://cdn.prod.website-files.com/62cda51656823c14ac1caf02/64542bd0101e245f20073754_MAILOUT%20-%20Q2%20Impact%20Report%20Summary%20FINAL%20wCROP%20(1).pdf' },
  { label: '2022 Q1 Report', url: 'https://cdn.prod.website-files.com/62cda51656823c14ac1caf02/6454299e694e0e1eb22af91b_Impact%20Report%20Quarter%20One.pdf' },
  { label: '2021 Annual Report', url: 'https://cdn.prod.website-files.com/62cda51656823c14ac1caf02/647e4e462c127232051125fa_2021%20annual%20report.pdf' },
  { label: '2020 Annual Report', url: 'https://cdn.prod.website-files.com/62cda51656823c14ac1caf02/647e52962c1272320515fd25_2020%20Annual%20Report.pdf' },
];
const form990s = [
  { label: '2024 Form 990', url: 'https://cdn.prod.website-files.com/62cda51656823c41dd1caeeb/6825484c388346ab982d5f46_Favor%202024%20Form%20990.pdf' },
  { label: '2023 Form 990', url: 'https://cdn.prod.website-files.com/62cda51656823c41dd1caeeb/672a9c1581eff2daa4f208d1_Favor%20International%202023%20Form%20990%20Final.pdf' },
  { label: '2022 Form 990', url: 'https://cdn.prod.website-files.com/62cda51656823c41dd1caeeb/64c509c8ef257386b3c251ab_Favor%202022%20Form%20990.pdf' },
  { label: '2021 Form 990', url: 'https://cdn.prod.website-files.com/62cda51656823c41dd1caeeb/642b4c63d932d73e6fc3f5c5_990%202021%20Final.pdf' },
  { label: '2020 Form 990', url: 'https://cdn.prod.website-files.com/62cda51656823c41dd1caeeb/64aed0169ebfb17d7c02bc73_Copy%20of%20Favor%20PUBLIC%20Federal%20Tax%20Form%20990%202020%20final%20(1).pdf' },
];
const audits = [
  { label: '2024 Audited Financials', url: 'https://cdn.prod.website-files.com/62cda51656823c41dd1caeeb/6825484c23dbe25d0e658940_Favor%202024%20Audited%20Fiancial%20Statements.pdf' },
  { label: '2023 Audited Financials', url: 'https://cdn.prod.website-files.com/62cda51656823c41dd1caeeb/672bdc8c698a012b9e25527c_FINAL%20audit%20-%20Favor%202023.pdf' },
  { label: '2022 Audited Financials', url: 'https://cdn.prod.website-files.com/62cda51656823c41dd1caeeb/64a2f854c1475cfd3aa52438_Favor%20Intl%20-%202022%20audit%20-%20FINAL.pdf' },
  { label: '2021 Audited Financials', url: 'https://cdn.prod.website-files.com/62cda51656823c41dd1caeeb/642b4c63b08ad1197cb8bbc6_2021%20US%20Favor%20Intl%20Audit.pdf' },
  { label: '2020 Audited Financials', url: 'https://cdn.prod.website-files.com/62cda51656823c41dd1caeeb/64aed008527fc7445992037b_Favor%20-%202020%20audit.pdf' },
];
const irsLetter = 'https://cdn.prod.website-files.com/62cda51656823c41dd1caeeb/65562b9562e1a1a1d733b585_IRS%20determination%20letter%20updated%20address.pdf';

const allFinancials = [{ label: 'IRS 2023 Determination Letter', url: irsLetter }, ...form990s, ...audits];
---
<PageLayout
  title="Accountability and Financials"
  description="ECFA accreditation, 990s, audited financials, and the public profiles of Favor International."
>
  <PageHero
    label="Accountability"
    title="Audited every year. Publicly profiled."
    promise="The receipts. We publish them so you don't have to ask."
    image="/images/hero-bibles-stacks.jpg"
    imageAlt="Stacks of Bibles ready for field distribution"
  />

  <section class="band band--white">
    <div class="container acct-head">
      <p class="label">Audited financials</p>
      <h2>The receipts behind the work.</h2>
      <p class="acct-lede">Every number below is sourced from Favor's FY2024 audited financials, filed with ECFA and IRS Form 990. No estimates. No projections.</p>
    </div>
    <div class="container acct-stats">
      {IMPACT_STATS.map((s) => (
        <div class="acct-stat">
          <span class="acct-stat__num">{s.value}</span>
          <span class="acct-stat__label">{s.label}</span>
          <span class="acct-stat__src">{s.source}</span>
        </div>
      ))}
    </div>
    <div class="container acct-badges">
      <a href={SITE.trust.ecfa} target="_blank" rel="noopener" aria-label="ECFA Accredited"><img src="/images/trust/ecfa.png" alt="ECFA Accredited" width="92" height="92" /></a>
      <a href={SITE.trust.charityNavigator} target="_blank" rel="noopener" aria-label="Charity Navigator Four-Star"><img src="/images/trust/charity-navigator.svg" alt="Charity Navigator Four-Star" width="92" height="92" /></a>
      <a href={SITE.trust.candid} target="_blank" rel="noopener" aria-label="Candid Platinum"><img src="/images/trust/candid-platinum.svg" alt="Candid Platinum Transparency" width="92" height="92" /></a>
    </div>
  </section>

  <OverlayFeature
    image="/images/hero-congo-grads.jpg"
    imageAlt="Graduates celebrating in DR Congo"
    eyebrow="Stewardship"
    heading="What we promise."
    side="right"
  >
    <p><strong>89 cents of every dollar went to program in FY2024.</strong> The remainder covers U.S. operations, audit, and donor care. (Source: ECFA-filed audited financials.)</p>
    <p>Restricted gifts honor the restriction. We will refund a restricted gift before we redirect one.</p>
    <p>Field-level reporting on every project. We tell you what worked and what didn't.</p>
    <p>No anonymous outcomes. Every story we publish has a real name, a real place, and a real outcome.</p>
  </OverlayFeature>

  <section class="band band--white">
    <div class="container">
      <p class="label">Reports</p>
      <h2>Impact reports.</h2>
      <p class="acct-sub">Quarterly and annual reports from the field, published since 2020.</p>
      <div class="doc-grid">
        {impactReports.map((r) => (
          <a class="doc-card" href={r.url} target="_blank" rel="noopener">
            <svg class="doc-card__icon" viewBox="0 0 24 24" width="20" height="20" aria-hidden="true"><path fill="currentColor" d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8l-6-6Zm0 2 4 4h-4V4ZM8 13h8v2H8v-2Zm0 4h6v2H8v-2Z"/></svg>
            <span>{r.label}</span>
          </a>
        ))}
      </div>

      <h2 class="acct-financials-title">Form 990s and audited financials.</h2>
      <p class="acct-sub">Five years of each, plus our IRS determination letter.</p>
      <div class="doc-grid">
        {allFinancials.map((r) => (
          <a class="doc-card" href={r.url} target="_blank" rel="noopener">
            <svg class="doc-card__icon" viewBox="0 0 24 24" width="20" height="20" aria-hidden="true"><path fill="currentColor" d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8l-6-6Zm0 2 4 4h-4V4ZM8 13h8v2H8v-2Zm0 4h6v2H8v-2Z"/></svg>
            <span>{r.label}</span>
          </a>
        ))}
      </div>
      <p class="acct-ein">EIN {SITE.ein} &middot; 501(c)(3) public charity &middot; ECFA-accredited since September 30, 2019.</p>
    </div>
  </section>

  <CtaBand
    heading="Need anything else for due diligence?"
    body={`Email ${SITE.emailGeneral} and we will send the financial packet within one business day.`}
    ctaLabel="Request the financial packet"
    ctaHref={`mailto:${SITE.emailGeneral}?subject=Financial packet request`}
  />
</PageLayout>

<style>
  .acct-head { text-align: center; max-width: 760px; }
  .acct-head { margin-left: auto; margin-right: auto; }
  .acct-lede { margin: var(--space-3) auto 0; color: var(--color-ink-soft); max-width: 60ch; }
  .acct-stats { display: grid; grid-template-columns: repeat(4, 1fr); gap: var(--space-8); margin-top: var(--space-16); text-align: center; }
  @media (max-width: 760px) { .acct-stats { grid-template-columns: repeat(2, 1fr); gap: var(--space-10) var(--space-6); } }
  .acct-stat__num { display: block; font-family: var(--font-sans); font-weight: 800; font-size: clamp(2.6rem, 6vw, 4rem); color: var(--color-green-deep); line-height: 1; letter-spacing: -0.02em; }
  .acct-stat__label { display: block; margin-top: var(--space-4); font-weight: 800; font-size: 0.8rem; letter-spacing: 0.1em; text-transform: uppercase; color: var(--color-gold-deep); }
  .acct-stat__src { display: block; margin-top: var(--space-3); font-size: 0.78rem; color: var(--color-sage); }
  .acct-badges { display: flex; justify-content: center; align-items: center; gap: clamp(var(--space-8), 8vw, var(--space-20)); margin-top: var(--space-16); flex-wrap: wrap; }
  .acct-badges img { height: 92px; width: auto; transition: transform 160ms; }
  .acct-badges a:hover img { transform: translateY(-3px); }

  .acct-sub { color: var(--color-ink-soft); margin: 0; }
  .acct-financials-title { margin-top: var(--space-16); }
  .doc-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--space-3); margin-top: var(--space-6); }
  @media (max-width: 720px) { .doc-grid { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 460px) { .doc-grid { grid-template-columns: 1fr; } }
  .doc-card { display: flex; align-items: center; gap: var(--space-3); padding: var(--space-4) var(--space-5); background: var(--color-cream); border: 1px solid var(--color-border); border-radius: var(--radius-card); text-decoration: none; color: var(--color-green); font-weight: 600; font-size: 0.92rem; transition: border-color 140ms, transform 140ms, background 140ms; }
  .doc-card:hover { border-color: var(--color-gold); transform: translateY(-2px); background: var(--color-white); }
  .doc-card__icon { flex: 0 0 auto; color: var(--color-gold-deep); }
  .acct-ein { margin-top: var(--space-8); font-size: 0.85rem; color: var(--color-sage); }
</style>
