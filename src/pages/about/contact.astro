---
import PageLayout from '../../layouts/PageLayout.astro';
import PageHero from '../../components/band/PageHero.astro';
import { SITE } from '../../lib/site';
---
<PageLayout
  title="Contact"
  description="Reach a real human on the Favor International US team. Mailing address, phone, and email."
>
  <PageHero
    label="Contact"
    title="Reach a real human."
    promise={`Email or call us during ${SITE.hours}. We answer within one business day.`}
    image="/images/hero-radio-broadcast.jpg"
    imageAlt="A field worker recording radio content for Favor FM"
    variant="split"
  />

  <section class="band band--white">
    <div class="container">
      <div class="contact-grid">
        <div>
          <p class="label">Direct contact</p>
          <h2>Talk to us.</h2>
          <ul class="contact-meta">
            <li><strong>General:</strong> <a href={`mailto:${SITE.emailGeneral}`}>{SITE.emailGeneral}</a></li>
            <li><strong>Prayer:</strong> <a href={`mailto:${SITE.emailPrayer}`}>{SITE.emailPrayer}</a></li>
            <li><strong>Phone:</strong> <a href={`tel:${SITE.phoneTel}`}>{SITE.phone}</a></li>
            <li><strong>Hours:</strong> {SITE.hours}</li>
            <li><strong>Mailing:</strong> {SITE.mailing}</li>
          </ul>
          <p class="label" style="margin-top: var(--space-8);">Follow Favor</p>
          <ul class="contact-social">
            <li><a href={SITE.social.facebook} target="_blank" rel="noopener" aria-label="Facebook"><svg viewBox="0 0 24 24" width="20" height="20" aria-hidden="true"><path fill="currentColor" d="M22 12a10 10 0 1 0-11.56 9.88v-6.99H7.9V12h2.54V9.8c0-2.5 1.49-3.89 3.77-3.89 1.09 0 2.24.2 2.24.2v2.46h-1.26c-1.24 0-1.63.77-1.63 1.56V12h2.77l-.44 2.89h-2.33v6.99A10 10 0 0 0 22 12Z"/></svg></a></li>
            <li><a href={SITE.social.instagram} target="_blank" rel="noopener" aria-label="Instagram"><svg viewBox="0 0 24 24" width="20" height="20" aria-hidden="true"><path fill="currentColor" d="M12 2.16c3.2 0 3.58.01 4.85.07 1.17.05 1.8.25 2.23.41.56.22.96.48 1.38.9.42.42.68.82.9 1.38.16.43.36 1.06.41 2.23.06 1.27.07 1.65.07 4.85s-.01 3.58-.07 4.85c-.05 1.17-.25 1.8-.41 2.23-.22.56-.48.96-.9 1.38-.42.42-.82.68-1.38.9-.43.16-1.06.36-2.23.41-1.27.06-1.65.07-4.85.07s-3.58-.01-4.85-.07c-1.17-.05-1.8-.25-2.23-.41a3.72 3.72 0 0 1-1.38-.9 3.72 3.72 0 0 1-.9-1.38c-.16-.43-.36-1.06-.41-2.23C2.17 15.58 2.16 15.2 2.16 12s.01-3.58.07-4.85c.05-1.17.25-1.8.41-2.23.22-.56.48-.96.9-1.38.42-.42.82-.68 1.38-.9.43-.16 1.06-.36 2.23-.41C8.42 2.17 8.8 2.16 12 2.16Zm0 1.62c-3.15 0-3.52.01-4.76.07-.9.04-1.39.19-1.71.32-.43.17-.74.37-1.06.69-.32.32-.52.63-.69 1.06-.13.32-.28.81-.32 1.71-.06 1.24-.07 1.61-.07 4.76s.01 3.52.07 4.76c.04.9.19 1.39.32 1.71.17.43.37.74.69 1.06.32.32.63.52 1.06.69.32.13.81.28 1.71.32 1.24.06 1.61.07 4.76.07s3.52-.01 4.76-.07c.9-.04 1.39-.19 1.71-.32.43-.17.74-.37 1.06-.69.32-.32.52-.63.69-1.06.13-.32.28-.81.32-1.71.06-1.24.07-1.61.07-4.76s-.01-3.52-.07-4.76c-.04-.9-.19-1.39-.32-1.71a2.85 2.85 0 0 0-.69-1.06 2.85 2.85 0 0 0-1.06-.69c-.32-.13-.81-.28-1.71-.32-1.24-.06-1.61-.07-4.76-.07Zm0 2.76a5.46 5.46 0 1 1 0 10.92 5.46 5.46 0 0 1 0-10.92Zm0 9a3.54 3.54 0 1 0 0-7.08 3.54 3.54 0 0 0 0 7.08Zm5.68-9.21a1.28 1.28 0 1 1-2.56 0 1.28 1.28 0 0 1 2.56 0Z"/></svg></a></li>
            <li><a href={SITE.social.youtube} target="_blank" rel="noopener" aria-label="YouTube"><svg viewBox="0 0 24 24" width="20" height="20" aria-hidden="true"><path fill="currentColor" d="M23.5 6.2a3.02 3.02 0 0 0-2.12-2.14C19.5 3.55 12 3.55 12 3.55s-7.5 0-9.38.51A3.02 3.02 0 0 0 .5 6.2C0 8.07 0 12 0 12s0 3.93.5 5.8a3.02 3.02 0 0 0 2.12 2.14c1.88.51 9.38.51 9.38.51s7.5 0 9.38-.51a3.02 3.02 0 0 0 2.12-2.14c.5-1.87.5-5.8.5-5.8s0-3.93-.5-5.8ZM9.6 15.6V8.4l6.2 3.6-6.2 3.6Z"/></svg></a></li>
            <li><a href={SITE.social.linkedin} target="_blank" rel="noopener" aria-label="LinkedIn"><svg viewBox="0 0 24 24" width="20" height="20" aria-hidden="true"><path fill="currentColor" d="M20.45 20.45h-3.56v-5.57c0-1.33-.02-3.04-1.85-3.04-1.85 0-2.13 1.45-2.13 2.94v5.67H9.35V9h3.42v1.56h.05c.48-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.46v6.28ZM5.34 7.43a2.07 2.07 0 1 1 0-4.14 2.07 2.07 0 0 1 0 4.14ZM7.12 20.45H3.55V9h3.57v11.45ZM22.22 0H1.77C.79 0 0 .77 0 1.73v20.54C0 23.23.79 24 1.77 24h20.45c.98 0 1.78-.77 1.78-1.73V1.73C24 .77 23.2 0 22.22 0Z"/></svg></a></li>
            <li><a href={SITE.social.twitter} target="_blank" rel="noopener" aria-label="X"><svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true"><path fill="currentColor" d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231 5.45-6.231Zm-1.161 17.52h1.833L7.084 4.126H5.117L17.083 19.77Z"/></svg></a></li>
          </ul>
        </div>
        <form class="contact-form" action="/contact/submit" method="post">
          <label>
            <span>Your name</span>
            <input type="text" name="name" required autocomplete="name" />
          </label>
          <label>
            <span>Email</span>
            <input type="email" name="email" required autocomplete="email" />
          </label>
          <label>
            <span>What is this about?</span>
            <select name="topic">
              <option value="general">General question</option>
              <option value="prayer">Prayer request</option>
              <option value="church">Church partnership</option>
              <option value="foundation">Foundation / DAF inquiry</option>
              <option value="vision-trip">Vision trip</option>
              <option value="volunteer">Volunteering</option>
              <option value="media">Media or press</option>
            </select>
          </label>
          <label>
            <span>Your message</span>
            <textarea name="message" rows="6" required></textarea>
          </label>
          <button type="submit" class="btn btn--primary btn--large">Send the message</button>
          <p class="contact-form__privacy">We never sell or share your information. We will reply within one business day.</p>
        </form>
      </div>
    </div>
  </section>
</PageLayout>

<style>
  .contact-grid { display: grid; grid-template-columns: 1fr 1.4fr; gap: var(--space-16); }
  @media (max-width: 900px) { .contact-grid { grid-template-columns: 1fr; } }
  .contact-meta { list-style: none; padding: 0; margin: var(--space-6) 0 0; display: grid; gap: var(--space-3); }
  .contact-meta li { padding: var(--space-3) var(--space-4); background: var(--color-cream); border-radius: var(--radius-input); }
  .contact-meta strong { color: var(--color-green); margin-right: var(--space-2); }
  .contact-form { display: grid; gap: var(--space-4); padding: var(--space-8); background: var(--color-cream); border-radius: var(--radius-card); }
  .contact-form label { display: grid; gap: var(--space-2); }
  .contact-form span { font-weight: 700; font-size: 0.85rem; color: var(--color-green); letter-spacing: 0.04em; text-transform: uppercase; }
  .contact-form input, .contact-form select, .contact-form textarea { font: inherit; padding: 12px 14px; border: 2px solid var(--color-border); border-radius: var(--radius-input); background: var(--color-white); }
  .contact-form input:focus, .contact-form select:focus, .contact-form textarea:focus { outline: 2px solid var(--color-gold); outline-offset: 1px; }
  .contact-form__privacy { margin: 0; font-size: 0.8rem; color: var(--color-sage); }
  .contact-social { list-style: none; padding: 0; margin: var(--space-3) 0 0; display: flex; flex-wrap: wrap; gap: var(--space-3); }
  .contact-social a { display: inline-flex; align-items: center; justify-content: center; width: 44px; height: 44px; background: var(--color-cream); border: 1px solid var(--color-border); border-radius: 50%; color: var(--color-green); text-decoration: none; transition: background 140ms, color 140ms, transform 140ms; }
  .contact-social a:hover { background: var(--color-green); color: var(--color-white); transform: translateY(-2px); }
</style>
