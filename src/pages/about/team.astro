---
import PageLayout from '../../layouts/PageLayout.astro';
import PageHero from '../../components/band/PageHero.astro';
import FeatureRow from '../../components/band/FeatureRow.astro';
import OverlayFeature from '../../components/band/OverlayFeature.astro';
import CtaBand from '../../components/band/CtaBand.astro';
import directorsData from '../../data/directors.json';

// Leadership shown on the Team page: founder + U.S. Executive Directors + Africa Country Director.
// Full board lives on /about/board/. Source: Webflow CMS Directors collection.
const leadershipSlugs = ['carole-ward', 'joy-daniels', 'stephanie-maier', 'terry-lynne-goodman'];
const leadership = leadershipSlugs
  .map(slug => directorsData.find(d => d.slug === slug))
  .filter(Boolean);
const personHref = (slug) => slug === 'carole-ward' ? '/about/our-story/founder/' : `/about/people/${slug}/`;
---
<PageLayout
  title="Our Team"
  description="The U.S. executive team and Africa country leadership of Favor International."
>
  <PageHero
    label="Our Team"
    title="The people who carry the vision."
    promise="A small U.S. team raises support and stewards funds. Indigenous leaders run every program on the field."
    image="/images/about-leadership-training.jpg"
    imageAlt="Favor leadership at a training session"
    variant="split"
  />

  <section class="band band--white">
    <div class="container">
      <p class="band__lede" style="text-align:center; max-width: 760px; margin: 0 auto var(--space-12) auto;">
        Favor's U.S. office is intentionally small. The role of the U.S. team is to raise prayer
        and financial support, steward funds with ECFA-grade accountability, and stay out of the
        field's way. Programs are designed and run by the indigenous leaders who live in each
        country we serve.
      </p>
      <div class="team-grid">
        {leadership.map((m) => (
          <a class="leader-card" href={personHref(m.slug)}>
            <div class="leader-card__photo">
              <img src={m.imagePath} alt={`${m.fullName}, ${m.position}`} loading="lazy" />
            </div>
            <div class="leader-card__body">
              <h3>{m.fullName}</h3>
              <p class="leader-card__role">{m.position}</p>
              <p class="leader-card__location">{m.location}</p>
              {m.bioIntro && <p class="leader-card__bio">{m.bioIntro}</p>}
              <span class="leader-card__more">View profile &rarr;</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <FeatureRow
    image="/images/hero-tot-bishoftu.jpg"
    imageAlt="A Favor training of trainers session"
    eyebrow="Why the team looks like this"
    heading="A small U.S. office, a large field."
    layout="image-left"
    background="cream"
  >
    <p>
      Most international ministries grow a large U.S. headquarters and a smaller field
      presence. We do the opposite. Favor employs more than 100 indigenous workers across
      Uganda, South Sudan, Ethiopia, DR Congo, Chad, and the broader region: pastors,
      teachers, evangelists, midwives, accountants, security staff, and program directors.
      The U.S. team is a handful of people whose job is to support them well.
    </p>
  </FeatureRow>

  <OverlayFeature
    image="/images/pbs-karamoja.jpg"
    imageAlt="A Portable Bible School class in Karamoja"
    eyebrow="Partner as hero"
    heading="The pastor in Karamoja is not a beneficiary. He is the work."
    side="right"
  >
    <p>
      Our role is to make sure he has Bibles, a motorcycle, a salary, and the prayer cover to
      keep going. The indigenous leaders who live in each country we serve design and run every
      program; the U.S. team exists to support them well.
    </p>
  </OverlayFeature>

  <CtaBand
    heading="See the board."
    body="A volunteer Board of Directors provides governance, financial oversight, and accountability."
    ctaLabel="Meet the Board"
    ctaHref="/about/board/"
    variant="sage"
  />
</PageLayout>

<style>
  .team-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-8);
  }
  @media (max-width: 720px) { .team-grid { grid-template-columns: 1fr; } }

  .leader-card {
    background: var(--color-white);
    border-radius: var(--radius-card);
    overflow: hidden;
    border: 1px solid var(--color-border);
    border-top: 4px solid var(--color-green);
    display: grid;
    grid-template-columns: 200px 1fr;
    box-shadow: var(--shadow-card);
    text-decoration: none;
    color: inherit;
    transition: transform 180ms, box-shadow 180ms;
  }
  .leader-card:hover { transform: translateY(-4px); box-shadow: 0 20px 44px rgba(31, 58, 26, 0.16); }
  .leader-card__more {
    margin-top: var(--space-3);
    color: var(--color-gold-deep);
    font-weight: 700;
    font-size: 0.9rem;
  }
  .leader-card:hover .leader-card__more { color: var(--color-green); }
  @media (max-width: 600px) {
    .leader-card { grid-template-columns: 1fr; }
    .leader-card__photo { aspect-ratio: 4 / 3; }
  }

  .leader-card__photo {
    background: var(--color-sage-light);
    aspect-ratio: 1 / 1;
  }
  .leader-card__photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    display: block;
  }
  .leader-card__body {
    padding: var(--space-6);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }
  .leader-card__body h3 {
    margin: 0;
    font-size: 1.4rem;
    color: var(--color-green);
    line-height: 1.15;
  }
  .leader-card__role {
    align-self: start;
    margin: var(--space-1) 0;
    font-weight: 700;
    color: var(--color-green-deep);
    background: color-mix(in srgb, var(--color-green) 12%, var(--color-white));
    padding: 4px 12px;
    border-radius: var(--radius-pill);
    font-size: 0.8rem;
  }
  .leader-card__location {
    margin: 0;
    color: var(--color-sage);
    font-size: 0.8rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    font-weight: 700;
  }
  .leader-card__bio {
    margin: var(--space-2) 0 0 0;
    color: var(--color-ink-soft);
    font-size: 0.92rem;
    line-height: 1.55;
  }
</style>
