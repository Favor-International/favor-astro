---
import PageLayout from '../../layouts/PageLayout.astro';
import PageHero from '../../components/band/PageHero.astro';
import CtaBand from '../../components/band/CtaBand.astro';
import { SITE } from '../../lib/site';

const links = [
  { href: '/about/mission-vision/', label: 'Mission and Vision', desc: 'What we believe Favor is for, and why we still exist.' },
  { href: '/about/our-story/', label: 'Our Story', desc: 'How Favor started and where the founding conviction came from.' },
  { href: '/about/where-we-work/', label: 'Where We Work', desc: 'The fourteen nations and how we got to each one.' },
  { href: '/about/team/', label: 'Team', desc: 'US staff and key field leaders. Alphabetical.' },
  { href: '/about/board/', label: 'Board of Directors', desc: 'Volunteer governance. Five members, term-limited.' },
  { href: '/about/statement-of-faith/', label: 'Statement of Faith', desc: 'Doctrinal core. Where we stand.' },
  { href: '/about/accountability/', label: 'Accountability + Financials', desc: 'ECFA, 990s, audits, and the public profiles.' },
  { href: '/about/contact/', label: 'Contact', desc: 'Reach a real human on the US team.' },
];
---
<PageLayout
  title="About Favor International"
  description="Indigenous-led, prayer-birthed, partner-powered. The story, the team, the board, and the financials behind Favor International."
>
  <PageHero
    label="About"
    title="Indigenous-led. Prayer-birthed. Partner-powered."
    promise="The story, the team, the board, and the financials behind Favor International."
    image="/images/gift-bishoftu-tot.jpg"
    imageAlt="GIFT Institute training session"
  />

  <section class="band band--white">
    <div class="container">
      <header class="band__header">
        <p class="label">About sections</p>
        <h2>The full picture.</h2>
      </header>
      <div class="grid grid-4">
        {links.map((l) => (
          <a class="about-tile" href={l.href}>
            <h3>{l.label}</h3>
            <p>{l.desc}</p>
            <span class="about-tile__cta">Read →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <CtaBand
    heading="Reach out."
    body={`Real humans answer. Email ${SITE.emailGeneral} or call ${SITE.phone}, ${SITE.hours}.`}
    ctaLabel="Contact us"
    ctaHref="/about/contact/"
    variant="green"
  />
</PageLayout>

<style>
  .about-tile {
    display: flex; flex-direction: column; gap: var(--space-2);
    padding: var(--space-6);
    background: var(--color-cream);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-card);
    text-decoration: none; color: inherit;
    transition: border-color 160ms, transform 160ms;
  }
  .about-tile:hover { border-color: var(--color-gold); transform: translateY(-3px); }
  .about-tile h3 { margin: 0; color: var(--color-green); font-size: 1.05rem; }
  .about-tile p { margin: 0; color: var(--color-ink-soft); font-size: 0.9rem; }
  .about-tile__cta { margin-top: auto; font-weight: 700; color: var(--color-gold); font-size: 0.8rem; }
</style>
