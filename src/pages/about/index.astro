---
import PageLayout from '../../layouts/PageLayout.astro';
import PageHero from '../../components/band/PageHero.astro';
import OverlayCard from '../../components/global/OverlayCard.astro';
import CtaBand from '../../components/band/CtaBand.astro';
import { SITE } from '../../lib/site';

const links = [
  { href: '/about/mission-vision/', label: 'Mission and Vision', desc: 'What we believe Favor is for, and why we still exist.', image: '/images/hero-new-believers.jpg' },
  { href: '/about/our-story/', label: 'Our Story', desc: 'How Favor started and where the founding conviction came from.', image: '/images/about-original-house.jpg' },
  { href: '/about/where-we-work/', label: 'Where We Work', desc: 'The nations we serve, and how we got to each one.', image: '/images/hero-about-overview.jpg' },
  { href: '/about/team/', label: 'Team', desc: 'US staff and key field leaders.', image: '/images/about-leadership-training.jpg' },
  { href: '/about/board/', label: 'Board of Directors', desc: 'Volunteer governance, term-limited.', image: '/images/hero-tot-bishoftu.jpg' },
  { href: '/about/statement-of-faith/', label: 'Statement of Faith', desc: 'Doctrinal core. Where we stand.', image: '/images/hero-bibles-stacks.jpg' },
  { href: '/about/accountability/', label: 'Accountability + Financials', desc: 'ECFA, 990s, audits, and the public profiles.', image: '/images/hero-foundation-cohort.jpg' },
  { href: '/about/contact/', label: 'Contact', desc: 'Reach a real human on the US team.', image: '/images/hero-radio-broadcast.jpg' },
];
---
<PageLayout
  title="About Favor International"
  description="Indigenous-led, prayer-birthed, partner-powered. The story, the team, the board, and the financials behind Favor International."
>
  <PageHero
    label="About"
    title="Indigenous-led. Prayer-birthed. Partner-powered."
    promise="The story, the team, the board, and the financials behind Favor International."
    image="/images/hero-about-overview.jpg"
    imageAlt="A Favor community gathering in Yambio, South Sudan"
  />

  <section class="band band--white">
    <div class="container">
      <header class="band__header">
        <p class="label">About sections</p>
        <h2>The full picture.</h2>
      </header>
      <div class="about-grid">
        {links.map((l) => (
          <OverlayCard href={l.href} image={l.image} title={l.label} desc={l.desc} cta="Read" ratio="4 / 3" />
        ))}
      </div>
    </div>
  </section>

  <CtaBand
    heading="Reach out."
    body={`Real humans answer. Email ${SITE.emailGeneral} or call ${SITE.phone}, ${SITE.hours}.`}
    ctaLabel="Contact us"
    ctaHref="/about/contact/"
    variant="green"
  />
</PageLayout>

<style>
  .about-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: var(--space-6); }
  @media (max-width: 1000px) { .about-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 540px) { .about-grid { grid-template-columns: 1fr; } }
</style>
