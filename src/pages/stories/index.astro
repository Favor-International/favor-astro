---
import PageLayout from '../../layouts/PageLayout.astro';
import PageHero from '../../components/band/PageHero.astro';
import StoryCard from '../../components/story/StoryCard.astro';
import CtaBand from '../../components/band/CtaBand.astro';

const stories = [
  { title: 'From spear-masters to the Holy Spirit', country: 'South Sudan', outcome: 'A Taposa warrior cohort lays down their weapons after PBS training.', image: '/images/pillar-community.jpg', href: '/stories/from-spear-masters-to-holy-spirit/' },
  { title: 'The next generation’s leaders', country: 'Uganda', outcome: 'A GIFT graduate plants a church in his home village.', image: '/images/gift-bishoftu-tot.jpg', href: '/stories/the-next-generations-leaders/' },
  { title: 'More Bibles for Ethiopia', country: 'Ethiopia', outcome: 'Field teachers run out of Bibles — and a partner gives more.', image: '/images/hero-pbs-graduation.jpg', href: '/stories/more-bibles-for-ethiopia-please/' },
  { title: 'The Anaka crusade', country: 'Uganda', outcome: '1,400 first-time decisions in three days.', image: '/images/pillar-community.jpg', href: '/stories/the-anaka-crusade/' },
  { title: 'Emmy: from orphan to leader', country: 'Uganda', outcome: 'Top of her class. Now training her year-mates.', image: '/images/education-vlc-jondoru.jpg', href: '/stories/emmy-from-orphan-to-leader/' },
  { title: 'A timely word', country: 'South Sudan', outcome: 'A pastor’s prayer reaches a village he never knew about.', image: '/images/evangelism-discipleship.jpg', href: '/stories/a-timely-word/' },
];
---
<PageLayout
  title="Stories of Transformation"
  description="Real names. Real places. Real outcomes. Stories from the fourteen nations Favor International serves."
>
  <PageHero
    label="Stories"
    title="Real names. Real places. Real outcomes."
    promise="No anonymous outcomes. Every story carries a name, a country, and a verifiable outcome."
    image="/images/story-anaka-crusade.jpg"
    imageAlt="PBS graduation"
  />

  <section class="band band--white">
    <div class="container">
      <div class="grid grid-3">
        {stories.map((s) => <StoryCard {...s} />)}
      </div>
    </div>
  </section>

  <CtaBand
    heading="Get a story in your inbox every month."
    body="The field report carries one new story each month."
    ctaLabel="Send Me the Field Report"
    ctaHref="/newsletter/"
    variant="sage"
  />
</PageLayout>
