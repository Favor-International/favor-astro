---
import PageLayout from '../../layouts/PageLayout.astro';
import PageHero from '../../components/band/PageHero.astro';
import PostCard from '../../components/band/PostCard.astro';
import CtaBand from '../../components/band/CtaBand.astro';
import storiesData from '../../data/stories.json';

const stories = [...storiesData].sort(
  (a, b) => new Date(b.date).getTime() - new Date(a.date).getTime()
);
function excerpt(paras: string[], n = 150) {
  const t = paras && paras[0] ? paras[0] : '';
  return t.length > n ? t.slice(0, n).replace(/\s+\S*$/, '') + '…' : t;
}
---
<PageLayout
  title="Stories of Transformation"
  description="Real transformation stories from the field across East Africa, in the words of the Favor International teams who witnessed them."
>
  <PageHero
    label="Stories"
    title="Stories of transformation."
    promise="Every story here is a real person, in a real place, in a real work of God. Read them in the words of the teams who witnessed them."
    image="/images/story-anaka-crusade.jpg"
    imageAlt="A Favor field gathering"
  />

  <section class="band band--white">
    <div class="container">
      <p class="stories-count">{stories.length} stories from the field.</p>
      <div class="stories-grid">
        {stories.map((s) => (
          <PostCard
            href={`/stories/${s.slug}/`}
            image={s.image}
            imageAlt={s.title}
            chip={s.date}
            title={s.title}
            desc={excerpt(s.paragraphs)}
            actionLabel="Read the story"
          />
        ))}
      </div>
    </div>
  </section>

  <CtaBand
    heading="Get a story in your inbox every month."
    body="The field report carries one new story each month."
    ctaLabel="Send Me the Field Report"
    ctaHref="/newsletter/"
    variant="sage"
  />
</PageLayout>

<style>
  .stories-count {
    text-align: center;
    color: var(--color-sage);
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    font-size: 0.85rem;
    margin: 0 0 var(--space-8);
  }
  .stories-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-8);
  }
  @media (max-width: 900px) { .stories-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 600px) { .stories-grid { grid-template-columns: 1fr; } }
  .story-card {
    display: flex; flex-direction: column;
    background: var(--color-white);
    border-radius: var(--radius-card);
    box-shadow: var(--shadow-soft);
    overflow: hidden;
    text-decoration: none; color: inherit;
    transition: transform 180ms, box-shadow 180ms;
    height: 100%;
  }
  .story-card:hover { transform: translateY(-4px); box-shadow: var(--shadow-card); }
  .story-card__photo {
    aspect-ratio: 4 / 3;
    background-size: cover;
    background-position: center;
    background-color: var(--color-sage-light);
  }
  .story-card__body { padding: var(--space-6); display: flex; flex-direction: column; gap: var(--space-2); flex: 1; }
  .story-card__date {
    font-size: var(--font-size-label);
    font-weight: 600;
    letter-spacing: var(--letter-spacing-label);
    text-transform: uppercase;
    color: var(--color-terracotta);
  }
  .story-card h3 { font-size: 1.2rem; margin: 0; color: var(--color-green); line-height: 1.25; }
  .story-card p { font-size: 0.95rem; color: var(--color-ink-soft); margin: 0; }
  .story-card__cta { margin-top: auto; padding-top: var(--space-2); font-weight: 700; color: var(--color-gold); font-size: 0.9rem; }
</style>
